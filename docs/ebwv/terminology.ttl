webuild:socialrepresentative
        rdf:type                      skos:Concept;
        dcterms:created               "2026-04-28T14:58:11.984Z"^^xsd:dateTime;
        dcterms:modified              "2026-04-28T14:58:11.984Z"^^xsd:dateTime;
        skos:definition               "a person or entity designated to represent or assist an employer or posted worker in relation to social security, labour, employment or posting-related obligations during a posting period"@en;
        skos:inScheme                 webuild:;
        skos:note                     "In the Posted Worker Notification context, social representative should denote the representative identified for social, employment or posting-related matters in the host country. The representative may act as a contact point for authorities, provide or receive information, support compliance with posting obligations, or assist with documentation relating to the posted worker’s social security or labour-law status. The concept should be distinguished from the employer, the host entity, the legal representative of the company, the posted worker, and a purely technical or administrative contact person."@en;
        skos:prefLabel                <urn:uuid:1e19d696-b4d0-483d-84d7-7e83018ddda7>;
        suomi-meta:creator            "5dc030a4-740f-4dde-9548-4e6e797899d8";
        suomi-meta:modifier           "5dc030a4-740f-4dde-9548-4e6e797899d8";
        suomi-meta:publicationStatus  <http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT>;
        term:orderedNote              ( "In the Posted Worker Notification context, social representative should denote the representative identified for social, employment or posting-related matters in the host country. The representative may act as a contact point for authorities, provide or receive information, support compliance with posting obligations, or assist with documentation relating to the posted worker’s social security or labour-law status. The concept should be distinguished from the employer, the host entity, the legal representative of the company, the posted worker, and a purely technical or administrative contact person."@en ) .

<urn:uuid:1e19d696-b4d0-483d-84d7-7e83018ddda7>
