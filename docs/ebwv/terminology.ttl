        skos:altLabel                 <urn:uuid:38d50945-6756-45eb-966b-e8668571d25d>;
        skos:broader                  webuild:concept-93;
        skos:definition               "a set of data that enables the establishment of the identity of a European Business Wallet owner and that is issued by a provider of European Business Wallet owner identification data"@en;
        skos:inScheme                 webuild:;
        skos:note                     "At minimum, the \"EBWOID\" includes legal name + one or more legal identifiers (e.g., EUID or national identifier), and may include additional matching attributes under policy."@en;
