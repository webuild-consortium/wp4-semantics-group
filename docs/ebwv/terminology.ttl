webuild:concept-41  rdf:type          skos:Concept;
        dcterms:created               "2022-02-07T08:20:41Z";
        dcterms:modified              "2026-01-23T14:30:39.71Z"^^xsd:dateTime;
        <http://purl.org/termed/properties/id>
                "6364b7df-d2c8-4f56-ac4d-f53141e3d0df";
        skos:broader                  webuild:concept-95;
        skos:changeNote               "alternative definitions:\n\"an entity that can perform actions and participate in interactions (including legal, organisational, or business processes)\"\n\"an entity that is able to carry out actions\"";
        skos:definition               "an entity that can perform actions or be treated as acting within a process"@en;
        skos:inScheme                 webuild:;
        skos:narrower                 webuild:concept-1 , webuild:concept-6005 , webuild:concept-94 , webuild:concept-6006;
        skos:note                     "“Agent” is the broad umbrella concept covering actors that can participate in business/legal processes (e.g., natural persons, organisations, legal persons, legal entities). If you intend “agent” to include software agents, state that explicitly; otherwise keep it socio-legal and process-oriented."@en , "Umbrella concept for actors that can act/decide/commit in processes.\nIncludes natural persons and organisations (and therefore legal persons).\nIf you later want “software agent,” introduce it explicitly; do not imply it here unless your use cases require it."@en , "The term agent represents an upper class / broader concept that would encompass both natural persons, sole traders, organizations, registered organizations, legal entities and others that are capable of actions like \"doing business."@en;
        skos:prefLabel                <urn:uuid:14b229de-4ba0-48eb-9f7e-ff15a33d4ef4>;
        suomi-meta:creator            "5dc030a4-740f-4dde-9548-4e6e797899d8";
        suomi-meta:modifier           "5dc030a4-740f-4dde-9548-4e6e797899d8";
        suomi-meta:publicationStatus  <http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT>;
        term:orderedBroader           ( webuild:concept-95 );
        term:orderedNarrower          ( webuild:concept-1 webuild:concept-6005 webuild:concept-94 webuild:concept-6006 );
        term:orderedNote              ( "The term agent represents an upper class / broader concept that would encompass both natural persons, sole traders, organizations, registered organizations, legal entities and others that are capable of actions like \"doing business."@en "Umbrella concept for actors that can act/decide/commit in processes.\nIncludes natural persons and organisations (and therefore legal persons).\nIf you later want “software agent,” introduce it explicitly; do not imply it here unless your use cases require it."@en "“Agent” is the broad umbrella concept covering actors that can participate in business/legal processes (e.g., natural persons, organisations, legal persons, legal entities). If you intend “agent” to include software agents, state that explicitly; otherwise keep it socio-legal and process-oriented."@en ) .

