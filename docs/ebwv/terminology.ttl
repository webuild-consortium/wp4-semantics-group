webuild:givenname  rdf:type           skos:Concept;
        dcterms:created               "2026-02-03T14:23:56.234Z"^^xsd:dateTime;
        dcterms:modified              "2026-02-03T15:06:31.249Z"^^xsd:dateTime;
        dcterms:source                "https://semiceu.github.io/Core-Person-Vocabulary/releases/2.1.1/#Person.givenname";
        skos:altLabel                 <urn:uuid:78aaf59c-4a5b-4302-a32b-ba0948e31510> , <urn:uuid:da32a214-9b9c-4853-9adb-0a33ddeb3d21>;
        skos:definition               "the name(s) that identify the person within a family with a common surname"@en;
        skos:inScheme                 webuild:;
        skos:note                     "Usually a first name or forename. Given to a person by his or her parents at birth or legally recognised as 'given names' through a formal process. All given names are ordered in one property so that, for example, the given name for Johann Sebastian Bach is \"Johann Sebastian\"."@en;
        skos:prefLabel                <urn:uuid:c32d2a33-4acb-4bb7-bbc5-012479881295> , <urn:uuid:eae0090d-7b39-40cd-8062-190774fb3913>;
        suomi-meta:creator            "5dc030a4-740f-4dde-9548-4e6e797899d8";
        suomi-meta:modifier           "35c48e07-ad49-45c8-82a4-da1763c4fe4a";
        suomi-meta:publicationStatus  <http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT>;
        term:orderedNote              ( "Usually a first name or forename. Given to a person by his or her parents at birth or legally recognised as 'given names' through a formal process. All given names are ordered in one property so that, for example, the given name for Johann Sebastian Bach is \"Johann Sebastian\"."@en );
        term:orderedSource            ( "https://semiceu.github.io/Core-Person-Vocabulary/releases/2.1.1/#Person.givenname" );
        term:orderedSynonym           ( <urn:uuid:78aaf59c-4a5b-4302-a32b-ba0948e31510> <urn:uuid:da32a214-9b9c-4853-9adb-0a33ddeb3d21> ) .

