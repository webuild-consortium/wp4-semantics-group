webuild:familyname  rdf:type          skos:Concept;
        dcterms:created               "2026-02-03T14:35:30.647Z"^^xsd:dateTime;
        dcterms:modified              "2026-02-03T14:39:47.315Z"^^xsd:dateTime;
        dcterms:source                "https://semiceu.github.io/Core-Person-Vocabulary/releases/2.1.1/#Person.familyname";
        skos:altLabel                 <urn:uuid:02f56ac6-6624-4f76-8172-1717b56c6f8f> , <urn:uuid:95984217-b926-4ddc-a164-e3be2881f2e0>;
        skos:definition               "the hereditary surname of a family"@en;
        skos:inScheme                 webuild:;
        skos:note                     "Usually referring to a group of people related by blood, marriage or adoption. This attribute also carries prefixes or suffixes which are part of the family name, e.g. \"de Boer\", \"van de Putte\", \"von und zu Orlow\". Multiple family names, such as are commonly found in Hispanic countries, are recorded in the single family name property so that, for example, Miguel de Cervantes Saavedra's family name would be recorded as \"de Cervantes Saavedra\"."@en;
        skos:prefLabel                <urn:uuid:77bc98b9-3486-460a-a7ea-0f423f334180>;
        suomi-meta:creator            "5dc030a4-740f-4dde-9548-4e6e797899d8";
        suomi-meta:modifier           "5dc030a4-740f-4dde-9548-4e6e797899d8";
        suomi-meta:publicationStatus  <http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT>;
        term:orderedNote              ( "Usually referring to a group of people related by blood, marriage or adoption. This attribute also carries prefixes or suffixes which are part of the family name, e.g. \"de Boer\", \"van de Putte\", \"von und zu Orlow\". Multiple family names, such as are commonly found in Hispanic countries, are recorded in the single family name property so that, for example, Miguel de Cervantes Saavedra's family name would be recorded as \"de Cervantes Saavedra\"."@en );
        term:orderedSource            ( "https://semiceu.github.io/Core-Person-Vocabulary/releases/2.1.1/#Person.familyname" );
        term:orderedSynonym           ( <urn:uuid:02f56ac6-6624-4f76-8172-1717b56c6f8f> <urn:uuid:95984217-b926-4ddc-a164-e3be2881f2e0> ) .

