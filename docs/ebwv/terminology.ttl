webuild:legalname  rdf:type           skos:Concept;
        dcterms:created               "2026-02-03T14:56:47.143Z"^^xsd:dateTime;
        dcterms:modified              "2026-02-03T14:56:47.143Z"^^xsd:dateTime;
        dcterms:source                "https://semiceu.github.io/Core-Business-Vocabulary/releases/2.2.0/#LegalEntity.legalname";
        skos:altLabel                 <urn:uuid:b09248cf-2495-426b-9423-4a72dab92ddf> , <urn:uuid:21bfc130-0b34-4049-a37a-10f8fabbfcd5>;
        skos:definition               "the name under which the legal entity is legally registered"@en;
        skos:inScheme                 webuild:;
        skos:note                     "The legal name is different from the alternative (trade) name which is a pseudonym used by companies that do not operate under their registered company name. A business might have more than one legal name, particularly in countries with more than one official language. In such cases, and where the encoding technology allows, the language of the string should be identified."@en;
        skos:prefLabel                <urn:uuid:2515b85a-ef0e-4590-a7e6-76afab617224>;
        suomi-meta:creator            "5dc030a4-740f-4dde-9548-4e6e797899d8";
