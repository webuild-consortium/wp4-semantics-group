webuild:concept-110  rdf:type         skos:Concept;
        dcterms:created               "2026-01-23T12:19:25.358Z"^^xsd:dateTime;
        dcterms:modified              "2026-01-23T12:41:06.613Z"^^xsd:dateTime;
        skos:broader                  webuild:concept-7;
        skos:definition               "a unique identifier to identify economic operators"@en;
        skos:inScheme                 webuild:;
        skos:note                     "The EUID consists of the country code, a register identifier and a national registration number. At the moment it is undefined how an EUID would look like for economic operators that are natural persons and other types of economic operators that are not certain types of legal entities mentioned in the BRIS regulation.\n\nThe future EU Business Wallet regulation will designate the European unique identifier (EUID), as established and governed by Directive (EU) 2017/1132, as the unique identifier for European Business Wallet owners, and establishes a similar unique identifier for European Business Wallets owners to whom the European Unique Identifier is not available."@en;
        skos:prefLabel                <urn:uuid:391f5ee1-a1b9-4278-8e64-e98b65fd55bd>;
        skos:related                  webuild:concept-94;
        suomi-meta:creator            "5dc030a4-740f-4dde-9548-4e6e797899d8";
        suomi-meta:modifier           "5dc030a4-740f-4dde-9548-4e6e797899d8";
        suomi-meta:publicationStatus  <http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT>;
        term:orderedBroader           ( webuild:concept-7 );
        term:orderedNote              ( "The EUID consists of the country code, a register identifier and a national registration number. At the moment it is undefined how an EUID would look like for economic operators that are natural persons and other types of economic operators that are not certain types of legal entities mentioned in the BRIS regulation.\n\nThe future EU Business Wallet regulation will designate the European unique identifier (EUID), as established and governed by Directive (EU) 2017/1132, as the unique identifier for European Business Wallet owners, and establishes a similar unique identifier for European Business Wallets owners to whom the European Unique Identifier is not available."@en );
        term:orderedRelated           ( webuild:concept-94 ) .

