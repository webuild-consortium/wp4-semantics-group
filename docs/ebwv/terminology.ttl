webuild:concept-76  rdf:type          skos:Concept;
        dcterms:created               "2025-02-06T11:33:30.103Z"^^xsd:dateTime;
        dcterms:modified              "2025-02-06T12:21:51.164Z"^^xsd:dateTime;
        skos:altLabel                 <urn:uuid:7c812a06-a048-4e3d-a988-7e549bb33708> , <urn:uuid:74c2421b-6b2b-4662-9943-dbfce0d095d2> , <urn:uuid:f283c907-0eec-41e5-ad9e-3be9968d13b9> , <urn:uuid:a749dcf8-c9f6-4660-9fbd-0ecf9912b3ca> , <urn:uuid:7854f27d-e119-4674-8f66-84c162054342>;
        skos:broader                  webuild:concept-41;
        skos:definition               "an agent that grants authority to another agent to act on its behalf"@en;
        skos:inScheme                 webuild:;
        skos:note                     "Agent refers to either a person or a legal entity.  The authority to act on the other agents behalf is typically created through a formal agreement or legal instrument."@en;
        skos:prefLabel                <urn:uuid:e6138034-c31f-4307-9078-2fb61d1765c8>;
