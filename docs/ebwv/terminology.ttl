webuild:postedworker  rdf:type        skos:Concept;
        dcterms:created               "2026-04-28T14:47:17.976Z"^^xsd:dateTime;
        dcterms:modified              "2026-04-28T14:47:17.976Z"^^xsd:dateTime;
        skos:altLabel                 <urn:uuid:cd779356-62e9-48f1-a572-35ad9b0af95a> , <urn:uuid:71913d2d-1455-4b11-9fdd-8a4e9c84977f> , <urn:uuid:a9171cc2-39cc-4310-a26f-b208893f4acf>;
        skos:definition               "a worker who is sent by an employer to perform work temporarily in a country other than the country in which the worker normally works"@en;
        skos:example                  "A Finnish employer submits a Posted Worker Notification stating that a named employee is a posted worker assigned to a construction site in Belgium for three months."@en;
        skos:inScheme                 webuild:;
        skos:note                     "In the EBWV context, and especially in a Posted Worker Notification, posted worker denotes the person whose cross-border posting is being notified to the competent authority of the host country. The concept should be used for the worker subject to the posting arrangement, not for the posting employer, host entity, local contact person, legal representative, or service recipient. A posted worker normally remains employed by, or otherwise contractually connected to, the sending employer during the posting period."@en;
        skos:prefLabel                <urn:uuid:1a54f59d-de99-4734-b22b-25592d936381>;
        suomi-meta:creator            "5dc030a4-740f-4dde-9548-4e6e797899d8";
        suomi-meta:modifier           "5dc030a4-740f-4dde-9548-4e6e797899d8";
        suomi-meta:publicationStatus  <http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT>;
        term:orderedExample           ( "A Finnish employer submits a Posted Worker Notification stating that a named employee is a posted worker assigned to a construction site in Belgium for three months."@en );
        term:orderedNote              ( "In the EBWV context, and especially in a Posted Worker Notification, posted worker denotes the person whose cross-border posting is being notified to the competent authority of the host country. The concept should be used for the worker subject to the posting arrangement, not for the posting employer, host entity, local contact person, legal representative, or service recipient. A posted worker normally remains employed by, or otherwise contractually connected to, the sending employer during the posting period."@en );
        term:orderedSynonym           ( <urn:uuid:a9171cc2-39cc-4310-a26f-b208893f4acf> <urn:uuid:71913d2d-1455-4b11-9fdd-8a4e9c84977f> <urn:uuid:cd779356-62e9-48f1-a572-35ad9b0af95a> ) .

