webuild:concept-2000  rdf:type        skos:Concept;
        dcterms:created               "2022-10-24T09:29:07Z";
        dcterms:modified              "2025-12-11T15:31:10.054Z"^^xsd:dateTime;
        <http://purl.org/termed/properties/id>
                "d0c8878f-1c7f-4573-a913-aa1a9d32c0e1";
        skos:broader                  webuild:concept-2001;
        skos:definition               "an activity where resources are combined to produce specific goods or services"@en;
        skos:inScheme                 webuild:;
        skos:note                     "An economic activity is characterised by an input of resources (such as capital goods, labour, manufacturing techniques or intermediary products), a production process and an output of products (goods or services).  <br />Economic activity does not have to be carried out for profit or even regularly. When economic activities are carried out by agents in order to generate profit, the economic activity can be described as business activity. <br />Economic activity values should be expressed as values from a common codelist. In the NSG&amp;B context the values should be taken from NACE."@en;
        skos:prefLabel                <urn:uuid:74921b1d-b650-4c96-bdb5-11506f564948>;
        skos:related                  webuild:concept-94;
        suomi-meta:creator            "5dc030a4-740f-4dde-9548-4e6e797899d8";
        suomi-meta:modifier           "5dc030a4-740f-4dde-9548-4e6e797899d8";
        suomi-meta:publicationStatus  <http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT>;
        term:orderedBroader           ( webuild:concept-2001 );
        term:orderedNote              ( "An economic activity is characterised by an input of resources (such as capital goods, labour, manufacturing techniques or intermediary products), a production process and an output of products (goods or services).  <br />Economic activity does not have to be carried out for profit or even regularly. When economic activities are carried out by agents in order to generate profit, the economic activity can be described as business activity. <br />Economic activity values should be expressed as values from a common codelist. In the NSG&amp;B context the values should be taken from NACE."@en );
        term:orderedRelated           ( webuild:concept-94 ) .

