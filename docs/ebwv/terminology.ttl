webuild:economicoperator
        rdf:type                      skos:Concept;
        dcterms:created               "2026-04-14T05:45:50.887Z"^^xsd:dateTime;
        dcterms:modified              "2026-04-14T05:47:34.269Z"^^xsd:dateTime;
        skos:definition               "any natural or legal person, including but not limited to companies, partnerships, foundations, associations as well as sole-traders and self-employed persons or a group of such persons, acting in a commercial or professional capacity (EBW regulation definition; 3rd Presidency compromise)\n\nOR\n\nactor concept used in EU regulatory contexts for a natural or legal person, and in some instruments also a public entity or grouping, engaged in legally relevant economic operations"@en;
        skos:inScheme                 webuild:;
        skos:prefLabel                <urn:uuid:9dd6aa36-d9d6-41c2-81d8-3f268dbf5789>;
        skos:related                  webuild:economicactivity;
        suomi-meta:creator            "5dc030a4-740f-4dde-9548-4e6e797899d8";
        suomi-meta:modifier           "5dc030a4-740f-4dde-9548-4e6e797899d8";
        suomi-meta:publicationStatus  <http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT>;
        term:orderedRelated           ( webuild:economicactivity ) .

webuild:economicactivity
        rdf:type                      skos:Concept;
        dcterms:created               "2026-04-14T05:43:55.26Z"^^xsd:dateTime;
        dcterms:modified              "2026-04-14T05:46:26.677Z"^^xsd:dateTime;
        skos:altLabel                 <urn:uuid:538de649-c8ff-49d0-8ad6-7c80f0c76ad3> , <urn:uuid:9c8ac212-67a2-4fad-b6f2-df083426d020>;
        skos:broader                  webuild:activity;
        skos:definition               "activity in which resources are combined in a production process to produce goods or services; in EU law and policy, the concept also covers the offering of goods or services on a market"@en;
        skos:inScheme                 webuild:;
        skos:note                     "Use for activities relevant to NACE classification, business statistics, market participation, trade, procurement, compliance and EU Business Wallet attestations. An economic activity may be associated with an economic operator in the regulatory sense."@en;
        skos:prefLabel                <urn:uuid:8860fb3a-4231-47a8-8031-6ac8ea25d3db>;
        skos:related                  webuild:economicoperator;
        suomi-meta:creator            "5dc030a4-740f-4dde-9548-4e6e797899d8";
        suomi-meta:modifier           "5dc030a4-740f-4dde-9548-4e6e797899d8";
        suomi-meta:publicationStatus  <http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT>;
        term:orderedBroader           ( webuild:activity );
        term:orderedNote              ( "Use for activities relevant to NACE classification, business statistics, market participation, trade, procurement, compliance and EU Business Wallet attestations. An economic activity may be associated with an economic operator in the regulatory sense."@en );
        term:orderedRelated           ( webuild:economicoperator );
        term:orderedSynonym           ( <urn:uuid:538de649-c8ff-49d0-8ad6-7c80f0c76ad3> <urn:uuid:9c8ac212-67a2-4fad-b6f2-df083426d020> ) .

<urn:uuid:bc1436c2-d988-47a4-a14d-594086ea71c9>
        rdf:type                      skos-xl:Label;
        skos-xl:literalForm           "economic activity (not in use)"@en;
        suomi-meta:publicationStatus  <http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT> .

webuild:activity  rdf:type            skos:Concept;
        dcterms:created               "2026-04-14T05:40:40.657Z"^^xsd:dateTime;
        dcterms:modified              "2026-04-28T11:40:36.432Z"^^xsd:dateTime;
        skos:altLabel                 <urn:uuid:8425ef72-a782-4413-86e7-19c41413e5c1> , <urn:uuid:64abbb6a-818b-48d7-a70d-d9acc42aa6c2>;
        skos:definition               "organised doing, operation or process carried out for a purpose or result\n\nOR\n\na business-related undertaking, operation, or process carried out by a party or economic operator for a defined purpose within an economic, administrative, or regulatory context"@en;
        skos:inScheme                 webuild:;
        skos:narrower                 webuild:economicactivity;
        skos:note                     "Broad neutral concept. Use when the activity does not specifically need to be classified as economic, regulatory, administrative or other specialised activity.\n\nOR \n\nA more narrower concept that is anchored clearly in business, economic operators, and contextual purpose, rather than generic human action."@en;
        skos:prefLabel                <urn:uuid:760b4be2-8c0d-46e2-be0e-30d77cb2a146>;
        suomi-meta:creator            "5dc030a4-740f-4dde-9548-4e6e797899d8";
        suomi-meta:modifier           "5dc030a4-740f-4dde-9548-4e6e797899d8";
        suomi-meta:publicationStatus  <http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT>;
        term:orderedNarrower          ( webuild:economicactivity );
        term:orderedNote              ( "Broad neutral concept. Use when the activity does not specifically need to be classified as economic, regulatory, administrative or other specialised activity.\n\nOR \n\nA more narrower concept that is anchored clearly in business, economic operators, and contextual purpose, rather than generic human action."@en );
        term:orderedSynonym           ( <urn:uuid:8425ef72-a782-4413-86e7-19c41413e5c1> <urn:uuid:64abbb6a-818b-48d7-a70d-d9acc42aa6c2> ) .

