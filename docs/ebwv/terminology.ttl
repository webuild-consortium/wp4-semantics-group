webuild:scopeofauthorization
        rdf:type                      skos:Concept;
        dcterms:created               "2026-04-28T14:54:50.304Z"^^xsd:dateTime;
        dcterms:modified              "2026-04-28T14:55:57.693Z"^^xsd:dateTime;
        skos:altLabel                 <urn:uuid:6c756406-dc7f-4227-b9b8-d61c223b744e> , <urn:uuid:4d47342e-7130-42a5-b99e-84ae01af651c> , <urn:uuid:2c715e4f-6c4b-420e-ba14-aca2f41ed64c> , <urn:uuid:bd63d2bd-5e7f-465f-a199-d43e829665a8> , <urn:uuid:81e79908-5f43-4514-86e6-a57c87cba339>;
        skos:definition               "the actions, matters, transactions, roles or circumstances for which an agent is authorised to act on behalf of another person or entity"@en;
        skos:example                  "A power of attorney attestation states that the representative’s scope of authorization is limited to submitting VAT returns and receiving tax-related notifications on behalf of the company."@en;
        skos:inScheme                 webuild:;
        skos:note                     "In the EBWV context, scope of authorization should be used to describe the limits of an authorisation, mandate, power of attorney, representation right, access right or consent. It may specify what the authorised party may do, for whom, in which role, in relation to which subject matter, and under what conditions. The scope may be general or limited, and may be restricted by time, jurisdiction, transaction type, service, value threshold, document type, credential type or required joint action with another representative.\n\nIt should be distinguished from the authorised person or representative, who is the agent receiving the authority; the authorising party, who grants or is represented by the authority; and the legal basis, which explains why the authority exists."@en;
        skos:prefLabel                <urn:uuid:7b893c19-8b10-498a-a402-3d1bce8c3be2>;
        suomi-meta:creator            "5dc030a4-740f-4dde-9548-4e6e797899d8";
        suomi-meta:modifier           "5dc030a4-740f-4dde-9548-4e6e797899d8";
        suomi-meta:publicationStatus  <http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT>;
        term:orderedExample           ( "A power of attorney attestation states that the representative’s scope of authorization is limited to submitting VAT returns and receiving tax-related notifications on behalf of the company."@en );
        term:orderedNote              ( "In the EBWV context, scope of authorization should be used to describe the limits of an authorisation, mandate, power of attorney, representation right, access right or consent. It may specify what the authorised party may do, for whom, in which role, in relation to which subject matter, and under what conditions. The scope may be general or limited, and may be restricted by time, jurisdiction, transaction type, service, value threshold, document type, credential type or required joint action with another representative.\n\nIt should be distinguished from the authorised person or representative, who is the agent receiving the authority; the authorising party, who grants or is represented by the authority; and the legal basis, which explains why the authority exists."@en );
        term:orderedSynonym           ( <urn:uuid:81e79908-5f43-4514-86e6-a57c87cba339> <urn:uuid:bd63d2bd-5e7f-465f-a199-d43e829665a8> <urn:uuid:2c715e4f-6c4b-420e-ba14-aca2f41ed64c> <urn:uuid:4d47342e-7130-42a5-b99e-84ae01af651c> <urn:uuid:6c756406-dc7f-4227-b9b8-d61c223b744e> ) .

