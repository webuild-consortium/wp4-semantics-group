webuild:bankaccount  rdf:type         skos:Concept;
        dcterms:created               "2026-04-27T13:49:03.025Z"^^xsd:dateTime;
        dcterms:modified              "2026-04-27T13:49:03.025Z"^^xsd:dateTime;
        skos:altLabel                 <urn:uuid:4d58bc2c-3902-402a-812b-ce8f4771baed>;
        skos:definition               "an account held with a credit institution or payment service provider that enables a legal or natural person to receive, hold, and transfer funds, and that may be identified in an EU Business Wallet context by attributes such as an IBAN, account holder name, account servicing institution, currency, and account status\n\nOR\n\na financial account maintained by an account servicing institution for a natural or legal person, enabling the account holder to receive, hold, and transfer funds in the context of business, administrative, or regulatory transactions supported by an EU Business Wallet"@en;
        skos:inScheme                 webuild:;
        skos:note                     "Use this concept for the financial account used by an EU Business Wallet owner or represented party for payments, invoicing, refunds, tax reporting, procurement, trade finance, or other business transactions. The concept denotes the account as a business-relevant financial facility, not merely the account identifier such as an IBAN."@en;
        skos:prefLabel                <urn:uuid:c8b4e66f-eb2c-481f-9b2a-526dc5ad4733>;
        suomi-meta:creator            "5dc030a4-740f-4dde-9548-4e6e797899d8";
        suomi-meta:modifier           "5dc030a4-740f-4dde-9548-4e6e797899d8";
        suomi-meta:publicationStatus  <http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT>;
        term:orderedNote              ( "Use this concept for the financial account used by an EU Business Wallet owner or represented party for payments, invoicing, refunds, tax reporting, procurement, trade finance, or other business transactions. The concept denotes the account as a business-relevant financial facility, not merely the account identifier such as an IBAN."@en );
        term:orderedSynonym           ( <urn:uuid:4d58bc2c-3902-402a-812b-ce8f4771baed> ) .

