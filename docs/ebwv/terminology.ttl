webuild:name  rdf:type                skos:Concept;
        dcterms:created               "2026-04-28T14:30:47.195Z"^^xsd:dateTime;
        dcterms:modified              "2026-04-28T14:31:21.509Z"^^xsd:dateTime;
        skos:definition               "a word, phrase or structured set of name components used to identify, designate or refer to an entity"@en;
        skos:example                  "A business identity attestation includes the registered legal name of the company, while a person identification attestation includes the person’s given name and family name."@en;
        skos:inScheme                 webuild:;
        skos:narrower                 webuild:matronymicname , webuild:birthname , webuild:concept-6012 , webuild:concept-51 , webuild:concept-24 , webuild:concept-26 , webuild:givenname , webuild:familyname , webuild:legalname , webuild:postname , webuild:locatorname , webuild:alternativename;
        skos:note                     "In the EBWV context, name is a generic concept that may apply to a person, legal entity, organisation, product, place, service, document, credential or other identifiable thing. Where more precise concepts are available, they should be used instead, such as given name, family name, legal name, trade name, business name, registered name or preferred name. A name may be official, registered, commonly used, localised, multilingual, historical or context-specific."@en;
        skos:prefLabel                <urn:uuid:8f68402d-1d40-437a-954f-96e349246150>;
        suomi-meta:creator            "5dc030a4-740f-4dde-9548-4e6e797899d8";
        suomi-meta:modifier           "5dc030a4-740f-4dde-9548-4e6e797899d8";
        suomi-meta:publicationStatus  <http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT>;
        term:orderedExample           ( "A business identity attestation includes the registered legal name of the company, while a person identification attestation includes the person’s given name and family name."@en );
        term:orderedNarrower          ( webuild:familyname webuild:givenname webuild:postname webuild:locatorname webuild:alternativename webuild:matronymicname webuild:concept-24 webuild:legalname webuild:concept-51 webuild:concept-6012 webuild:concept-26 webuild:birthname );
        term:orderedNote              ( "In the EBWV context, name is a generic concept that may apply to a person, legal entity, organisation, product, place, service, document, credential or other identifiable thing. Where more precise concepts are available, they should be used instead, such as given name, family name, legal name, trade name, business name, registered name or preferred name. A name may be official, registered, commonly used, localised, multilingual, historical or context-specific."@en ) .

