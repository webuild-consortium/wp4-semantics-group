webuild:legalstatus  rdf:type         skos:Concept;
        dcterms:created               "2026-04-28T14:22:33.566Z"^^xsd:dateTime;
        dcterms:modified              "2026-04-28T14:23:26.264Z"^^xsd:dateTime;
        skos:altLabel                 <urn:uuid:33721b31-9d27-4906-afba-3ebf4b42d9f2> , <urn:uuid:96225b01-1181-4590-8e86-9079f6b14d47> , <urn:uuid:f2b3d796-28fe-40fb-a728-a3dbfee9fd9c> , <urn:uuid:7ad3a28c-d17d-488d-bbc9-3f1b99fa32f2>;
        skos:definition               "the officially recorded status of a registered business entity as determined or maintained by the competent register authority"@en;
        skos:example                  "An EU Company Certificate states that the company’s legal status is “active” according to the national business register."@en;
        skos:inScheme                 webuild:;
        skos:note                     "In the EBWV and EU Company Certificate context, legal status indicates the current or historical status of a business entity in an official register, such as whether it is active, registered, dissolved, liquidated, bankrupt, suspended, merged, struck off or otherwise subject to a register authority’s status classification. It should be distinguished from the entity’s legal form, which describes the type of entity, such as limited liability company, cooperative or branch, and from its legal capacity, which concerns the entity’s ability to hold rights and obligations or perform legal acts."@en;
        skos:prefLabel                <urn:uuid:dc4faf1a-15d4-4b3d-bf71-a3a43492bdb1>;
        suomi-meta:creator            "5dc030a4-740f-4dde-9548-4e6e797899d8";
        suomi-meta:modifier           "5dc030a4-740f-4dde-9548-4e6e797899d8";
        suomi-meta:publicationStatus  <http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT>;
        term:orderedExample           ( "An EU Company Certificate states that the company’s legal status is “active” according to the national business register."@en );
        term:orderedNote              ( "In the EBWV and EU Company Certificate context, legal status indicates the current or historical status of a business entity in an official register, such as whether it is active, registered, dissolved, liquidated, bankrupt, suspended, merged, struck off or otherwise subject to a register authority’s status classification. It should be distinguished from the entity’s legal form, which describes the type of entity, such as limited liability company, cooperative or branch, and from its legal capacity, which concerns the entity’s ability to hold rights and obligations or perform legal acts."@en );
        term:orderedSynonym           ( <urn:uuid:7ad3a28c-d17d-488d-bbc9-3f1b99fa32f2> <urn:uuid:f2b3d796-28fe-40fb-a728-a3dbfee9fd9c> <urn:uuid:96225b01-1181-4590-8e86-9079f6b14d47> <urn:uuid:33721b31-9d27-4906-afba-3ebf4b42d9f2> ) .

