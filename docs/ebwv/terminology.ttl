webuild:concept-42  rdf:type          skos:Concept;
        dcterms:created               "2022-02-07T08:21:55Z";
        dcterms:modified              "2024-04-23T08:59:37Z";
        <http://purl.org/termed/properties/id>
                "e616b6f1-6194-40ef-a1a5-99f8988250b7";
        skos:altLabel                 <urn:uuid:dbb62c87-ba54-403a-8e68-5e3db4436e3e>;
        skos:broader                  webuild:concept-4;
        skos:definition               "the address to which formal communications can be sent to the legal entity"@en;
        skos:inScheme                 webuild:;
        skos:note                     "The registered address is the address, where the legal entity or his or her representative is available for official matters. Most often this is the address of the main office, head office, registered office or headquarters of the agent.  For most companies the registered address is also the default address but an agent can also declare a specific postal address separately.\n\nEU Core Business Vocabulary definition for \"registered address\" = The address at which the Legal Entity is legally registered."@en;
        skos:prefLabel                <urn:uuid:b55cd908-a05c-41a2-8bb4-0eb93245b798>;
        skos:related                  webuild:concept-43;
        suomi-meta:creator            "5dc030a4-740f-4dde-9548-4e6e797899d8";
        suomi-meta:modifier           "4c00fd3e-ad5d-4ad6-8782-de29597a5d57";
        suomi-meta:publicationStatus  <http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT>;
        term:orderedBroader           ( webuild:concept-4 );
        term:orderedNote              ( "The registered address is the address, where the legal entity or his or her representative is available for official matters. Most often this is the address of the main office, head office, registered office or headquarters of the agent.  For most companies the registered address is also the default address but an agent can also declare a specific postal address separately.\n\nEU Core Business Vocabulary definition for \"registered address\" = The address at which the Legal Entity is legally registered."@en );
        term:orderedRelated           ( webuild:concept-43 );
        term:orderedSynonym           ( <urn:uuid:dbb62c87-ba54-403a-8e68-5e3db4436e3e> ) .

