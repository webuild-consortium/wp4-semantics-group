webuild:powerofattorney
        rdf:type                      skos:Concept;
        dcterms:created               "2026-02-04T11:00:17.579Z"^^xsd:dateTime;
        dcterms:modified              "2026-02-04T11:10:20.291Z"^^xsd:dateTime;
        skos:broader                  webuild:authorisation;
        skos:definition               "a legally effective authorization by which a natural person or legal person (the mandator) grants another agent (the mandatee) the right to act on the mandator’s behalf in one or more specified legal, administrative, or business matters, with defined scope, constraints, and validity, and which can be presented and verified in the EU Business Wallet as evidence of representation towards relying parties"@en;
        skos:inScheme                 webuild:;
        skos:prefLabel                <urn:uuid:5750efcd-f4ef-44bd-b31d-ea8976fb19f0>;
        suomi-meta:creator            "5dc030a4-740f-4dde-9548-4e6e797899d8";
