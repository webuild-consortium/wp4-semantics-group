webuild:thoroughfare  rdf:type        skos:Concept;
        dcterms:created               "2026-02-16T08:34:40.728Z"^^xsd:dateTime;
        dcterms:modified              "2026-02-16T09:05:35.455Z"^^xsd:dateTime;
        skos:altLabel                 <urn:uuid:cdc31107-5f91-4442-beeb-af09460bfc36>;
        skos:definition               "the name of a passage or way through from one location to another"@en;
        skos:inScheme                 webuild:;
        skos:note                     "The concept thoroughfare is just a part of \"streetAddress\" in Schema.org; example:\nstreetAddress: \"38 avenue de l'Opéra\"\nthoroughfare: \"avenue de l'Opéra\""@en , "A thoroughfare is usually a street, but it might be a waterway or some other feature. For example, \"Avenue des Champs-Élysées\".\n\nThe concept definition is based on the EU Core Location Vocabulary."@en;
        skos:prefLabel                <urn:uuid:95ed35c9-93af-471a-a4e1-63666ceebf92>;
        suomi-meta:creator            "5dc030a4-740f-4dde-9548-4e6e797899d8";
