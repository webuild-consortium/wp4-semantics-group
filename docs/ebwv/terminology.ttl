        skos-xl:literalForm           "mandate"@en;
        suomi-meta:publicationStatus  <http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT> .

webuild:mandate  rdf:type             skos:Concept;
        dcterms:created               "2026-02-04T11:18:03.431Z"^^xsd:dateTime;
        dcterms:modified              "2026-02-04T11:18:03.431Z"^^xsd:dateTime;
        skos:definition               "a legally effective authorization by which a natural person or legal person (the mandator) empowers another agent (the mandatee) to act on the mandator’s behalf for one or more specified legal, administrative, or business matters, with a defined scope, constraints, and validity, and which can be presented and verified in the EU Business Wallet as evidence of representation towards relying parties"@en;
        skos:inScheme                 webuild:;
        skos:prefLabel                <urn:uuid:fb45c8e1-c3f2-4dbd-a7c8-2920df2b2cb6>;
