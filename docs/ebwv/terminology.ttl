webuild:postcode  rdf:type            skos:Concept;
        dcterms:created               "2026-02-16T09:20:13.753Z"^^xsd:dateTime;
        dcterms:modified              "2026-02-16T09:20:13.753Z"^^xsd:dateTime;
        skos:altLabel                 <urn:uuid:2db94de6-528c-446a-bf19-cb6ddb304bb1> , <urn:uuid:cea10550-075a-4a78-825b-dc1e10ce4088>;
        skos:definition               "The code created and maintained for postal purposes to identify a subdivision of addresses and postal delivery points."@en;
        skos:inScheme                 webuild:;
        skos:note                     "Post codes are common elements in many countries' postal address systems. One of the many post codes of Paris is for example \"75000\"."@en;
        skos:prefLabel                <urn:uuid:6c0db615-c25c-4cdb-9e4b-de383983a6f1>;
        suomi-meta:creator            "5dc030a4-740f-4dde-9548-4e6e797899d8";
        suomi-meta:modifier           "5dc030a4-740f-4dde-9548-4e6e797899d8";
        suomi-meta:publicationStatus  <http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT>;
        term:orderedNote              ( "Post codes are common elements in many countries' postal address systems. One of the many post codes of Paris is for example \"75000\"."@en );
        term:orderedSynonym           ( <urn:uuid:2db94de6-528c-446a-bf19-cb6ddb304bb1> <urn:uuid:cea10550-075a-4a78-825b-dc1e10ce4088> ) .

webuild:concept-94  rdf:type          skos:Concept;
        dcterms:created               "2025-12-04T12:47:24.424Z"^^xsd:dateTime;
        dcterms:modified              "2026-03-03T06:05:42.321Z"^^xsd:dateTime;
        dcterms:source                "COM(2025) 838 - Proposal for a Regulation on the establishment of European Business Wallets";
        skos:broader                  webuild:concept-41;
        skos:changeNote               "alternative definitions:\n\"a natural person, legal person or group of such persons, including temporary associations of undertakings, when acting in a commercial or professional capacity for purposes related to their trade, business, craft or profession\"\n\"any natural or legal person or public entity or group of such persons and/or entities, including any temporary association of undertakings, which offers the execution of works and/or a work, the supply of products or the provision of services on the market\"";
        skos:definition               "an agent acting in a commercial or professional capacity for purposes related to its trade, business, craft, or profession"@en;
        skos:inScheme                 webuild:;
        skos:note                     "NB: the exact scope of the \"economic operator\" concept depends on the legal instrument (procurement vs market surveillance vs sector laws)."@en , "Natural persons can be economic operators; whether they are treated as “legal entities” depends on whether they have a legally recognised registered business identity in the relevant legal context."@en , "“Economic operator” is a capacity/role. \n\nThe same underlying entity may or may not be an economic operator depending on context. \n\nEconomic operators frequently correspond to \"legal entities\" for regulated processes, but the precise coverage depends on the applicable legal instrument."@en;
        skos:prefLabel                <urn:uuid:a53404ff-d71b-40bc-999e-01588fddb37f> , <urn:uuid:b369f9d8-b167-44bd-a5a5-8c72b4b3363b> , <urn:uuid:0fd08ec7-8001-446d-a3a3-aab584f573bf>;
        skos:related                  webuild:concept-109 , webuild:concept-6005 , webuild:concept-6006;
        suomi-meta:creator            "5dc030a4-740f-4dde-9548-4e6e797899d8";
        suomi-meta:modifier           "5dc030a4-740f-4dde-9548-4e6e797899d8";
        suomi-meta:publicationStatus  <http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT>;
        term:orderedBroader           ( webuild:concept-41 );
        term:orderedNote              ( "“Economic operator” is a capacity/role. \n\nThe same underlying entity may or may not be an economic operator depending on context. \n\nEconomic operators frequently correspond to \"legal entities\" for regulated processes, but the precise coverage depends on the applicable legal instrument."@en "Natural persons can be economic operators; whether they are treated as “legal entities” depends on whether they have a legally recognised registered business identity in the relevant legal context."@en "NB: the exact scope of the \"economic operator\" concept depends on the legal instrument (procurement vs market surveillance vs sector laws)."@en );
        term:orderedRelated           ( webuild:concept-6006 webuild:concept-109 webuild:concept-6005 );
        term:orderedSource            ( "COM(2025) 838 - Proposal for a Regulation on the establishment of European Business Wallets" ) .

