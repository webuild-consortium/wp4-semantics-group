webuild:legalPersonIdentificationData
        rdf:type                      skos:Concept;
        dcterms:created               "2026-01-12T16:28:32.455Z"^^xsd:dateTime;
        dcterms:modified              "2026-01-12T16:28:32.455Z"^^xsd:dateTime;
        skos:definition               "a set of data that enables the establishment of the identity of a legal person and that is issued by a LPID provider. The LPID is the credential subject of an LPID-Credential. A LPID credential allows a legal person to authenticate against a relying party."@en;
        skos:inScheme                 webuild:;
        skos:prefLabel                <urn:uuid:37e77d0d-ad8c-438a-8b3a-8683e2a4cd85>;
        suomi-meta:creator            "f7193db9-3c93-4d56-9d57-d5c3f1132fe9";
        suomi-meta:modifier           "f7193db9-3c93-4d56-9d57-d5c3f1132fe9";
        suomi-meta:publicationStatus  <http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT> .

webuild:concept-6005  rdf:type        skos:Concept;
        dcterms:created               "2023-11-09T13:22:34Z";
        dcterms:modified              "2026-01-23T14:35:37.069Z"^^xsd:dateTime;
        <http://purl.org/termed/properties/id>
                "e0c8e09b-5707-412a-ba06-511d77a5f769";
        skos:altLabel                 <urn:uuid:1745f367-be49-46e2-912d-52ceb818d72b> , <urn:uuid:3a9a7dda-073a-4520-b699-8bdf5534bc23>;
        skos:broader                  webuild:concept-41;
        skos:changeNote               "alternative definition:\n\"an individual human being who may be dead or alive, but not imaginary\"";
        skos:definition               "a human being recognized by law as an individual subject of rights and obligations"@en;
        skos:inScheme                 webuild:;
        skos:note                     "A natural person exists independently of registration. A natural person may act in a private capacity or in a professional/economic capacity (e.g., sole trader). Acting economically does not transform the person into a legal person; it expresses the economic operator capacity."@en , "A natural person exists independently of registration, but her/his legal capacity may be restricted (minor, guardianship, incapacity). \n\nA natural person can act\n- in a private capacity or\n- in a professional or economic capacity (sole trader, freelancer, craftsman, farmer)\n\nA natural person does not cease to be a natural person when conducting business. Economic activity does not transform the person into a legal person, but the natural person can then be considered an economic operator."@en;
        skos:prefLabel                <urn:uuid:d415b619-215c-44cc-b893-cab5df27b067>;
        skos:related                  webuild:concept-94 , webuild:concept-109;
        suomi-meta:creator            "4c00fd3e-ad5d-4ad6-8782-de29597a5d57";
        suomi-meta:modifier           "5dc030a4-740f-4dde-9548-4e6e797899d8";
        suomi-meta:publicationStatus  <http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT>;
        term:orderedBroader           ( webuild:concept-41 );
        term:orderedNote              ( "A natural person exists independently of registration, but her/his legal capacity may be restricted (minor, guardianship, incapacity). \n\nA natural person can act\n- in a private capacity or\n- in a professional or economic capacity (sole trader, freelancer, craftsman, farmer)\n\nA natural person does not cease to be a natural person when conducting business. Economic activity does not transform the person into a legal person, but the natural person can then be considered an economic operator."@en "A natural person exists independently of registration. A natural person may act in a private capacity or in a professional/economic capacity (e.g., sole trader). Acting economically does not transform the person into a legal person; it expresses the economic operator capacity."@en );
        term:orderedRelated           ( webuild:concept-109 webuild:concept-94 );
        term:orderedSynonym           ( <urn:uuid:1745f367-be49-46e2-912d-52ceb818d72b> <urn:uuid:3a9a7dda-073a-4520-b699-8bdf5534bc23> ) .

