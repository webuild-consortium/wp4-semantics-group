webuild:typeofemployment
        rdf:type                      skos:Concept;
        dcterms:created               "2026-04-28T15:04:07.672Z"^^xsd:dateTime;
        dcterms:modified              "2026-04-28T15:04:07.672Z"^^xsd:dateTime;
        skos:altLabel                 <urn:uuid:782efa4d-40a8-4931-be9a-37b98f96ca4c> , <urn:uuid:45d9582e-10e8-40ef-b67d-53ce26ec2506> , <urn:uuid:0e2d5b67-58ce-4e12-b359-c6b3121b1b62> , <urn:uuid:edaa44ed-13c7-44ac-ba65-f86d21618e43>;
        skos:definition               "the category or form of an employment relationship, indicating how a worker is employed or engaged by an employer"@en;
        skos:example                  "A Posted Worker Notification states that the posted worker’s type of employment is “fixed-term employment”."@en;
        skos:inScheme                 webuild:;
        skos:note                     "In the EBWV context, type of employment should be used as a generic property of an employment relationship. It may describe whether the employment is permanent, fixed-term, temporary, seasonal, part-time, full-time, agency-based, apprenticeship-based, probationary or another recognised employment form.\n\nIn the Posted Worker Notification context, this concept helps describe the employment arrangement under which the posted worker is employed by the sending employer during the posting period. It should be distinguished from job title, which names the worker’s role or position; employment status, which may describe whether a person is employed, self-employed, unemployed or otherwise active; and working time, which describes the hours or pattern of work."@en;
        skos:prefLabel                <urn:uuid:90d215a5-19dc-49eb-80ee-9abd063d94c2>;
        skos:related                  webuild:employer , webuild:postedworker;
        suomi-meta:creator            "5dc030a4-740f-4dde-9548-4e6e797899d8";
        suomi-meta:modifier           "5dc030a4-740f-4dde-9548-4e6e797899d8";
        suomi-meta:publicationStatus  <http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT>;
        term:orderedExample           ( "A Posted Worker Notification states that the posted worker’s type of employment is “fixed-term employment”."@en );
        term:orderedNote              ( "In the EBWV context, type of employment should be used as a generic property of an employment relationship. It may describe whether the employment is permanent, fixed-term, temporary, seasonal, part-time, full-time, agency-based, apprenticeship-based, probationary or another recognised employment form.\n\nIn the Posted Worker Notification context, this concept helps describe the employment arrangement under which the posted worker is employed by the sending employer during the posting period. It should be distinguished from job title, which names the worker’s role or position; employment status, which may describe whether a person is employed, self-employed, unemployed or otherwise active; and working time, which describes the hours or pattern of work."@en );
        term:orderedRelated           ( webuild:postedworker webuild:employer );
        term:orderedSynonym           ( <urn:uuid:edaa44ed-13c7-44ac-ba65-f86d21618e43> <urn:uuid:0e2d5b67-58ce-4e12-b359-c6b3121b1b62> <urn:uuid:45d9582e-10e8-40ef-b67d-53ce26ec2506> <urn:uuid:782efa4d-40a8-4931-be9a-37b98f96ca4c> ) .

