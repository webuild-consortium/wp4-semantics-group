webuild:owner  rdf:type               skos:Concept;
        dcterms:created               "2026-04-28T14:33:54.697Z"^^xsd:dateTime;
        dcterms:modified              "2026-04-28T14:33:54.697Z"^^xsd:dateTime;
        skos:altLabel                 <urn:uuid:546286f2-b1bb-4171-8c5b-e63e5e34194b> , <urn:uuid:16dd4abb-94eb-49ee-a6d0-12d2212cb748> , <urn:uuid:435db1fa-57ee-4415-9024-3330288dc35e> , <urn:uuid:7099ac3e-8950-41b9-88b8-5e6733d26d39>;
        skos:definition               "an agent that holds an ownership right, title or legally recognised control over an asset, resource, business entity, credential, account, property or other object"@en;
        skos:inScheme                 webuild:;
        skos:note                     "In the EBWV context, owner should be used for the party that is legally or administratively recognised as owning something. The owned object may be tangible, intangible, digital, financial or organisational, such as a business, vehicle, bank account, real estate asset, wallet, credential, product or intellectual property right. The concept should be distinguished from holder, controller, user, possessor, custodian, operator, beneficial owner and legal representative. In particular, an owner may not be the same party as the person using, controlling, representing or holding the object."@en;
        skos:prefLabel                <urn:uuid:c0fc6aa7-31b6-44c7-afab-b23e746820b1>;
        suomi-meta:creator            "5dc030a4-740f-4dde-9548-4e6e797899d8";
        suomi-meta:modifier           "5dc030a4-740f-4dde-9548-4e6e797899d8";
        suomi-meta:publicationStatus  <http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT>;
        term:orderedNote              ( "In the EBWV context, owner should be used for the party that is legally or administratively recognised as owning something. The owned object may be tangible, intangible, digital, financial or organisational, such as a business, vehicle, bank account, real estate asset, wallet, credential, product or intellectual property right. The concept should be distinguished from holder, controller, user, possessor, custodian, operator, beneficial owner and legal representative. In particular, an owner may not be the same party as the person using, controlling, representing or holding the object."@en );
        term:orderedSynonym           ( <urn:uuid:546286f2-b1bb-4171-8c5b-e63e5e34194b> <urn:uuid:16dd4abb-94eb-49ee-a6d0-12d2212cb748> <urn:uuid:435db1fa-57ee-4415-9024-3330288dc35e> <urn:uuid:7099ac3e-8950-41b9-88b8-5e6733d26d39> ) .

