        suomi-meta:publicationStatus  <http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT>;
        term:orderedNarrower          ( webuild:concept-14 );
        term:orderedNote              ( "In the context of business related information, the main identifier for a business entity is usually the \"legal identifier\", which is the identifier given to the business entity when it is registered by a competent authority in a specific jurisdiction."@en );
        term:orderedRelated           ( webuild:concept-100 webuild:concept-30 ) .

