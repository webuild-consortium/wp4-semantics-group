webuild:site  rdf:type                skos:Concept;
        dcterms:created               "2026-04-13T09:03:04.359Z"^^xsd:dateTime;
        dcterms:modified              "2026-04-14T05:35:41.952Z"^^xsd:dateTime;
        skos:altLabel                 <urn:uuid:45cbcb6a-1d8a-4bc3-a819-94e242819a38> , <urn:uuid:9a70f8e9-d8ad-4730-a551-51ef1af4b318> , <urn:uuid:7052e039-5382-49dd-a2c1-5447f8765b3c>;
        skos:definition               "a place, premises or location at which an organisation is present or located\n\nOR\n\na physical place, premises or location whose boundaries help determine the spatial extent of a local unit"@en;
        skos:inScheme                 webuild:;
        skos:note                     "Use only for the location or premises layer. Do not use for the enterprise (economic operator) sub-unit itself when the intended meaning is a local operating or statistical unit."@en , "Alternatively:\nUse only for the physical-location layer. Do not use as the main concept for the statistical unit of an enterprise."@en;
        skos:prefLabel                <urn:uuid:31764b48-c0eb-43d0-9be0-0132a7f971f0>;
        skos:related                  webuild:localunit , webuild:establishment;
        suomi-meta:creator            "5dc030a4-740f-4dde-9548-4e6e797899d8";
        suomi-meta:modifier           "5dc030a4-740f-4dde-9548-4e6e797899d8";
        suomi-meta:publicationStatus  <http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT>;
        term:orderedNote              ( "Use only for the location or premises layer. Do not use for the enterprise (economic operator) sub-unit itself when the intended meaning is a local operating or statistical unit."@en "Alternatively:\nUse only for the physical-location layer. Do not use as the main concept for the statistical unit of an enterprise."@en );
        term:orderedRelated           ( webuild:establishment webuild:localunit );
        term:orderedSynonym           ( <urn:uuid:7052e039-5382-49dd-a2c1-5447f8765b3c> <urn:uuid:9a70f8e9-d8ad-4730-a551-51ef1af4b318> <urn:uuid:45cbcb6a-1d8a-4bc3-a819-94e242819a38> ) .

webuild:establishment
        rdf:type                      skos:Concept;
        dcterms:created               "2026-04-13T09:00:06.166Z"^^xsd:dateTime;
        dcterms:modified              "2026-04-14T05:34:09.427Z"^^xsd:dateTime;
        skos:altLabel                 <urn:uuid:2d417a04-4f47-48ba-87bd-5f8ec691cb2a> , <urn:uuid:c4ecbb22-137e-47e3-a563-41e376461896> , <urn:uuid:2c2e6807-7dc1-4f71-8c41-75f65180e8b2>;
        skos:broader                  webuild:localunit;
        skos:definition               "a local unit that constitutes a production unit mainly engaged in one kind of economic activity, corresponding to the local part of a kind-of-activity unit\n\nOR\n\na local unit viewed through both the activity dimension and the locality dimension; in the European statistical context this corresponds to the local kind-of-activity unit"@en;
        skos:inScheme                 webuild:;
        skos:note                     "Use when the concept is not merely a local operating presence but a production-oriented local unit characterised by a principal activity. In Eurostat and related statistical contexts this corresponds to the local kind-of-activity unit."@en , "Alternatively:\nUse when the intended concept is the more specific production-oriented unit used for industry and national accounts purposes, rather than the broader local unit."@en;
        skos:prefLabel                <urn:uuid:56d0149c-0df4-4f8d-97e2-2a6a14e0d089>;
        skos:related                  webuild:site;
        suomi-meta:creator            "5dc030a4-740f-4dde-9548-4e6e797899d8";
        suomi-meta:modifier           "5dc030a4-740f-4dde-9548-4e6e797899d8";
        suomi-meta:publicationStatus  <http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT>;
        term:orderedBroader           ( webuild:localunit );
        term:orderedNote              ( "Use when the concept is not merely a local operating presence but a production-oriented local unit characterised by a principal activity. In Eurostat and related statistical contexts this corresponds to the local kind-of-activity unit."@en "Alternatively:\nUse when the intended concept is the more specific production-oriented unit used for industry and national accounts purposes, rather than the broader local unit."@en );
        term:orderedRelated           ( webuild:site );
        term:orderedSynonym           ( <urn:uuid:c4ecbb22-137e-47e3-a563-41e376461896> <urn:uuid:2c2e6807-7dc1-4f71-8c41-75f65180e8b2> <urn:uuid:2d417a04-4f47-48ba-87bd-5f8ec691cb2a> ) .

webuild:localunit  rdf:type           skos:Concept;
        dcterms:created               "2026-04-13T08:57:42.11Z"^^xsd:dateTime;
        dcterms:modified              "2026-04-14T05:30:57.466Z"^^xsd:dateTime;
        skos:altLabel                 <urn:uuid:61c6c603-f0d3-465c-b98b-7de9f47ea6e4> , <urn:uuid:f24baf81-de6c-4b42-b8be-39899b601321>;
        skos:definition               "an enterprise or part of an enterprise situated in a geographically identified place, from or at which economic activity is carried out and for which one or more persons work\n\nOR\n\nan enterprise or part thereof situated in a geographically identified place, from or at which economic activity is carried out"@en;
        skos:inScheme                 webuild:;
        skos:narrower                 webuild:establishment;
        skos:note                     "Use as the general EU-wide concept for a geographically delimited operating unit of an enterprise (economic operator). This is the preferred broad concept in a Eurostat-oriented model."@en , "Alternatively:\nUse as the broad EU statistical concept for a geographically delimited operating unit of an enterprise. A local unit may contain more than one activity, may consist only of ancillary activities, and may in some cases be the registered office even if nobody works there."@en;
        skos:prefLabel                <urn:uuid:f1412668-6642-4b34-9a8f-dc7e358522a0>;
        skos:related                  webuild:site;
        suomi-meta:creator            "5dc030a4-740f-4dde-9548-4e6e797899d8";
        suomi-meta:modifier           "5dc030a4-740f-4dde-9548-4e6e797899d8";
        suomi-meta:publicationStatus  <http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT>;
        term:orderedNarrower          ( webuild:establishment );
        term:orderedNote              ( "Use as the general EU-wide concept for a geographically delimited operating unit of an enterprise (economic operator). This is the preferred broad concept in a Eurostat-oriented model."@en "Alternatively:\nUse as the broad EU statistical concept for a geographically delimited operating unit of an enterprise. A local unit may contain more than one activity, may consist only of ancillary activities, and may in some cases be the registered office even if nobody works there."@en );
        term:orderedRelated           ( webuild:site );
        term:orderedSynonym           ( <urn:uuid:f24baf81-de6c-4b42-b8be-39899b601321> <urn:uuid:61c6c603-f0d3-465c-b98b-7de9f47ea6e4> ) .

webuild:legalform  rdf:type           skos:Concept;
        dcterms:created               "2026-03-24T09:00:17.295Z"^^xsd:dateTime;
        dcterms:modified              "2026-03-24T09:00:17.295Z"^^xsd:dateTime;
        skos:definition               "the juridical classification of a [legal entity] according to the law under which it is constituted, determining its legal personality, governance structure, and liability regime"@en;
        skos:inScheme                 webuild:;
        skos:note                     "Legal form is typically expressed using nationally defined classifications, such as company types or partnership forms, which may be represented as codes or controlled concepts in business registers."@en , "The reference in the definition to \"legal entity\" reflects the existing EU Core Business Vocabulary structure, but the label of the key actor type might change during WE BUILD LSP (discussions about introducing the more generic \"economic operator\" instead)."@en;
        skos:prefLabel                <urn:uuid:ec6a9ff0-b2c3-4411-aabd-c295d0c23de3>;
        suomi-meta:creator            "5dc030a4-740f-4dde-9548-4e6e797899d8";
        suomi-meta:modifier           "5dc030a4-740f-4dde-9548-4e6e797899d8";
        suomi-meta:publicationStatus  <http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT>;
        term:orderedNote              ( "Legal form is typically expressed using nationally defined classifications, such as company types or partnership forms, which may be represented as codes or controlled concepts in business registers."@en "The reference in the definition to \"legal entity\" reflects the existing EU Core Business Vocabulary structure, but the label of the key actor type might change during WE BUILD LSP (discussions about introducing the more generic \"economic operator\" instead)."@en ) .

<urn:uuid:ec6a9ff0-b2c3-4411-aabd-c295d0c23de3>
        rdf:type                      skos-xl:Label;
        skos-xl:literalForm           "legal form"@en;
        suomi-meta:publicationStatus  <http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT> .

<urn:uuid:e1b64573-537b-440b-bdcd-78a3980d4e1d>
        rdf:type                      skos-xl:Label;
        skos-xl:literalForm           "locator designator"@en;
        suomi-meta:publicationStatus  <http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT> .

webuild:locatordesignator
        rdf:type                      skos:Concept;
        dcterms:created               "2026-02-17T14:00:13.214Z"^^xsd:dateTime;
        dcterms:modified              "2026-02-17T14:00:13.214Z"^^xsd:dateTime;
        skos:definition               "an alphanumeric identifier assigned within a thoroughfare or property context to designate a specific access point, building, unit, or sub-unit"@en;
        skos:inScheme                 webuild:;
        skos:note                     "A locator designator uniquely identifies a physical entry point or unit within a structured address system.\n\nIt commonly corresponds to:\nBuilding number; House number; Entrance identifier; Staircase identifier; Apartment or unit number\n\nThe locator designator is distinct from the thoroughfare name and from the post code.\nIt forms part of a structured postal or geographical address."@en;
        skos:prefLabel                <urn:uuid:e1b64573-537b-440b-bdcd-78a3980d4e1d>;
        suomi-meta:creator            "5dc030a4-740f-4dde-9548-4e6e797899d8";
        suomi-meta:modifier           "5dc030a4-740f-4dde-9548-4e6e797899d8";
        suomi-meta:publicationStatus  <http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT>;
        term:orderedNote              ( "A locator designator uniquely identifies a physical entry point or unit within a structured address system.\n\nIt commonly corresponds to:\nBuilding number; House number; Entrance identifier; Staircase identifier; Apartment or unit number\n\nThe locator designator is distinct from the thoroughfare name and from the post code.\nIt forms part of a structured postal or geographical address."@en ) .

webuild:countryofdeath
        rdf:type                      skos:Concept;
        dcterms:created               "2026-02-16T14:38:58.599Z"^^xsd:dateTime;
        dcterms:modified              "2026-02-16T14:38:58.599Z"^^xsd:dateTime;
        skos:definition               "the sovereign state within whose territory a person’s death was officially registered"@en;
        skos:inScheme                 webuild:;
        skos:note                     "Country of death refers to the state associated with the place where the death occurred and was legally recorded."@en , "It reflects territorial jurisdiction at the time of death registration and does not imply:\nCitizenship; Residence; Nationality; Place of burial\n\nWhere geopolitical changes have occurred, the country of death shall correspond to the state recognised in the official death record."@en;
        skos:prefLabel                <urn:uuid:e45b390b-ef56-493a-a925-585c8b8a2ac4>;
        suomi-meta:creator            "5dc030a4-740f-4dde-9548-4e6e797899d8";
        suomi-meta:modifier           "5dc030a4-740f-4dde-9548-4e6e797899d8";
        suomi-meta:publicationStatus  <http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT>;
        term:orderedNote              ( "Country of death refers to the state associated with the place where the death occurred and was legally recorded."@en "It reflects territorial jurisdiction at the time of death registration and does not imply:\nCitizenship; Residence; Nationality; Place of burial\n\nWhere geopolitical changes have occurred, the country of death shall correspond to the state recognised in the official death record."@en ) .

<urn:uuid:e45b390b-ef56-493a-a925-585c8b8a2ac4>
        rdf:type                      skos-xl:Label;
        skos-xl:literalForm           "country of death"@en;
        suomi-meta:publicationStatus  <http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT> .

<urn:uuid:84772a6e-0544-4831-8109-6ab322108783>
        rdf:type                      skos-xl:Label;
        skos-xl:literalForm           "country of birth"@en;
        suomi-meta:publicationStatus  <http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT> .

webuild:countryofbirth
        rdf:type                      skos:Concept;
        dcterms:created               "2026-02-16T14:37:17.229Z"^^xsd:dateTime;
        dcterms:modified              "2026-02-16T14:37:17.229Z"^^xsd:dateTime;
        skos:definition               "the sovereign state within whose territory a person’s birth was officially registered"@en;
        skos:inScheme                 webuild:;
        skos:note                     "Country of birth refers to the state associated with the place of birth at the time of birth registration.\nIt reflects territorial jurisdiction and does not imply citizenship, nationality, ethnicity, or residence."@en , "Where historical territorial changes have occurred, the country of birth shall correspond to the state recognised in the official birth record."@en;
        skos:prefLabel                <urn:uuid:84772a6e-0544-4831-8109-6ab322108783>;
        suomi-meta:creator            "5dc030a4-740f-4dde-9548-4e6e797899d8";
        suomi-meta:modifier           "5dc030a4-740f-4dde-9548-4e6e797899d8";
        suomi-meta:publicationStatus  <http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT>;
        term:orderedNote              ( "Country of birth refers to the state associated with the place of birth at the time of birth registration.\nIt reflects territorial jurisdiction and does not imply citizenship, nationality, ethnicity, or residence."@en "Where historical territorial changes have occurred, the country of birth shall correspond to the state recognised in the official birth record."@en ) .

webuild:contactpoint  rdf:type        skos:Concept;
        dcterms:created               "2026-02-16T14:35:36.043Z"^^xsd:dateTime;
        dcterms:modified              "2026-02-16T14:35:36.043Z"^^xsd:dateTime;
        skos:definition               "a designated communication channel or organisational function through which an entity can be contacted for a specific purpose"@en;
        skos:inScheme                 webuild:;
        skos:note                     "A contact point may also represent a functional role (e.g. “Customer Support”, “Procurement Office”) rather than an individual person."@en , "A contact point represents the means or role by which communication is established with a person, organisation, or public authority."@en;
        skos:prefLabel                <urn:uuid:4e663008-7541-4488-8982-d8914121f66c>;
        suomi-meta:creator            "5dc030a4-740f-4dde-9548-4e6e797899d8";
        suomi-meta:modifier           "5dc030a4-740f-4dde-9548-4e6e797899d8";
        suomi-meta:publicationStatus  <http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT>;
        term:orderedNote              ( "A contact point represents the means or role by which communication is established with a person, organisation, or public authority."@en "A contact point may also represent a functional role (e.g. “Customer Support”, “Procurement Office”) rather than an individual person."@en ) .

<urn:uuid:4e663008-7541-4488-8982-d8914121f66c>
        rdf:type                      skos-xl:Label;
        skos-xl:literalForm           "contact point"@en;
        suomi-meta:publicationStatus  <http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT> .

webuild:citizenship  rdf:type         skos:Concept;
        dcterms:created               "2026-02-16T14:33:41.961Z"^^xsd:dateTime;
        dcterms:modified              "2026-02-16T14:33:41.961Z"^^xsd:dateTime;
        skos:definition               "the legal bond between a natural person and a state, recognised under national law, which establishes membership in that state and entails associated rights and obligations"@en;
        skos:inScheme                 webuild:;
        skos:note                     "Citizenship expresses the formal legal relationship between a person and a sovereign state.\nA person may hold one or multiple citizenships, depending on applicable national laws.\nCitizenship is distinct from residence, domicile, ethnicity, or nationality as used in cultural contexts."@en;
        skos:prefLabel                <urn:uuid:03ddfe13-d938-4add-a4e2-8febb7dd2f5c>;
        suomi-meta:creator            "5dc030a4-740f-4dde-9548-4e6e797899d8";
        suomi-meta:modifier           "5dc030a4-740f-4dde-9548-4e6e797899d8";
        suomi-meta:publicationStatus  <http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT>;
        term:notRecommendedSynonym    <urn:uuid:604c0d24-4524-4905-8d8a-6e01e8925b4b>;
        term:orderedNotRecommendedSynonym
                ( <urn:uuid:604c0d24-4524-4905-8d8a-6e01e8925b4b> );
        term:orderedNote              ( "Citizenship expresses the formal legal relationship between a person and a sovereign state.\nA person may hold one or multiple citizenships, depending on applicable national laws.\nCitizenship is distinct from residence, domicile, ethnicity, or nationality as used in cultural contexts."@en ) .

<urn:uuid:604c0d24-4524-4905-8d8a-6e01e8925b4b>
        rdf:type                      skos-xl:Label;
        skos-xl:literalForm           "nationality"@en;
        suomi-meta:publicationStatus  <http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT> .

<urn:uuid:03ddfe13-d938-4add-a4e2-8febb7dd2f5c>
        rdf:type                      skos-xl:Label;
        skos-xl:literalForm           "citizenship"@en;
        suomi-meta:publicationStatus  <http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT> .

webuild:birthname  rdf:type           skos:Concept;
        dcterms:created               "2026-02-16T14:30:14.763Z"^^xsd:dateTime;
        dcterms:modified              "2026-02-16T14:30:14.763Z"^^xsd:dateTime;
        skos:broader                  webuild:concept-18;
        skos:definition               "the name assigned to a person at birth and recorded in the official birth registration"@en;
        skos:inScheme                 webuild:;
        skos:note                     "A birth name may consist of one or more given names and one or more family names, depending on national naming systems."@en , "A birth name is the legally recognised name entered in the civil register at the time of birth.\nIt may later change due to marriage, adoption, gender recognition, legal name change, or other lawful modification."@en;
        skos:prefLabel                <urn:uuid:6f7bd3f5-0226-46f2-a7cb-7c18c22d5afc>;
        suomi-meta:creator            "5dc030a4-740f-4dde-9548-4e6e797899d8";
        suomi-meta:modifier           "5dc030a4-740f-4dde-9548-4e6e797899d8";
        suomi-meta:publicationStatus  <http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT>;
        term:orderedBroader           ( webuild:concept-18 );
        term:orderedNote              ( "A birth name is the legally recognised name entered in the civil register at the time of birth.\nIt may later change due to marriage, adoption, gender recognition, legal name change, or other lawful modification."@en "A birth name may consist of one or more given names and one or more family names, depending on national naming systems."@en ) .

<urn:uuid:6f7bd3f5-0226-46f2-a7cb-7c18c22d5afc>
        rdf:type                      skos-xl:Label;
        skos-xl:literalForm           "birth name"@en;
        suomi-meta:publicationStatus  <http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT> .

<urn:uuid:6c16487d-78cb-4803-92c4-93b8d35ed9c6>
        rdf:type                      skos-xl:Label;
        skos-xl:literalForm           "alternative name"@en;
        suomi-meta:publicationStatus  <http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT> .

webuild:alternativename
        rdf:type                      skos:Concept;
        dcterms:created               "2026-02-16T14:28:16.846Z"^^xsd:dateTime;
        dcterms:modified              "2026-02-16T14:28:16.846Z"^^xsd:dateTime;
        skos:broader                  webuild:concept-18;
        skos:definition               "a name by which a person, organisation, or other identified entity is known in addition to its primary or legally registered name"@en;
        skos:example                  "A company’s registered legal name: Nordic Timber Export Oy\nAlternative name: NordTimber (trade name)\n\nA person’s legal name: Aleksandra Nowak\nAlternative name: Aleksandra Kowalska (former name)"@en;
        skos:inScheme                 webuild:;
        skos:note                     "An alternative name may include, for example, a trade name, previous name, alias, pseudonym, commonly used name, or name expressed in another language or script.\nIt does not replace the primary or legal name but exists in parallel as an additional identifier used in specific contexts."@en;
        skos:prefLabel                <urn:uuid:6c16487d-78cb-4803-92c4-93b8d35ed9c6>;
        suomi-meta:creator            "5dc030a4-740f-4dde-9548-4e6e797899d8";
        suomi-meta:modifier           "5dc030a4-740f-4dde-9548-4e6e797899d8";
        suomi-meta:publicationStatus  <http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT>;
        term:orderedBroader           ( webuild:concept-18 );
        term:orderedExample           ( "A company’s registered legal name: Nordic Timber Export Oy\nAlternative name: NordTimber (trade name)\n\nA person’s legal name: Aleksandra Nowak\nAlternative name: Aleksandra Kowalska (former name)"@en );
        term:orderedNote              ( "An alternative name may include, for example, a trade name, previous name, alias, pseudonym, commonly used name, or name expressed in another language or script.\nIt does not replace the primary or legal name but exists in parallel as an additional identifier used in specific contexts."@en ) .

<urn:uuid:9f364117-46ae-4e12-b887-ed617d30edfa>
        rdf:type                      skos-xl:Label;
        skos-xl:literalForm           "address area"@en;
        suomi-meta:publicationStatus  <http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT> .

webuild:addressarea  rdf:type         skos:Concept;
        dcterms:created               "2026-02-16T09:51:14.436Z"^^xsd:dateTime;
        dcterms:modified              "2026-02-16T09:52:42.366Z"^^xsd:dateTime;
        skos:definition               "the name of a geographic area that groups addresses"@en;
        skos:inScheme                 webuild:;
        skos:note                     "This would typically be part of a city, a neighbourhood or village, e.g. the area Stenstaden in the city of Sundsvall (SE) or Kreuzberg in the city of Berlin (DE). Address area is not an administrative unit."@en;
        skos:prefLabel                <urn:uuid:9f364117-46ae-4e12-b887-ed617d30edfa>;
        suomi-meta:creator            "5dc030a4-740f-4dde-9548-4e6e797899d8";
        suomi-meta:modifier           "5dc030a4-740f-4dde-9548-4e6e797899d8";
        suomi-meta:publicationStatus  <http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT>;
        term:orderedNote              ( "This would typically be part of a city, a neighbourhood or village, e.g. the area Stenstaden in the city of Sundsvall (SE) or Kreuzberg in the city of Berlin (DE). Address area is not an administrative unit."@en ) .

webuild:adminUnitL1  rdf:type         skos:Concept;
        dcterms:created               "2026-02-16T09:45:53.956Z"^^xsd:dateTime;
        dcterms:modified              "2026-02-16T09:45:53.956Z"^^xsd:dateTime;
        skos:definition               "the name of the uppermost level of the address, almost always a country"@en;
        skos:inScheme                 webuild:;
        skos:note                     "Best practice is to use the ISO 3166-1 code but if this is inappropriate for the context, country names should be provided in a consistent manner to reduce ambiguity. For example, either write 'France' or 'FRA' consistently throughout the dataset and avoid mixing the two. The Country controlled vocabulary from the Publications Office can be reused for this."@en;
        skos:prefLabel                <urn:uuid:019632ce-2305-44a9-882c-19e924ea43db>;
        suomi-meta:creator            "5dc030a4-740f-4dde-9548-4e6e797899d8";
        suomi-meta:modifier           "5dc030a4-740f-4dde-9548-4e6e797899d8";
        suomi-meta:publicationStatus  <http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT>;
        term:orderedNote              ( "Best practice is to use the ISO 3166-1 code but if this is inappropriate for the context, country names should be provided in a consistent manner to reduce ambiguity. For example, either write 'France' or 'FRA' consistently throughout the dataset and avoid mixing the two. The Country controlled vocabulary from the Publications Office can be reused for this."@en ) .

<urn:uuid:019632ce-2305-44a9-882c-19e924ea43db>
        rdf:type                      skos-xl:Label;
        skos-xl:literalForm           "administrative unit level 1"@en;
        suomi-meta:publicationStatus  <http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT> .

<urn:uuid:bbcad48c-8f22-47e2-a7d1-fda424b1120b>
        rdf:type                      skos-xl:Label;
        skos-xl:literalForm           "administrative unit level 2"@en;
        suomi-meta:publicationStatus  <http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT> .

webuild:adminUnitL2  rdf:type         skos:Concept;
        dcterms:created               "2026-02-16T09:41:59.829Z"^^xsd:dateTime;
        dcterms:modified              "2026-02-16T09:43:22.551Z"^^xsd:dateTime;
        skos:definition               "The name of a secondary level/region of the address, usually a county, state or other such area that typically encompasses several localities."@en;
        skos:inScheme                 webuild:;
        skos:prefLabel                <urn:uuid:bbcad48c-8f22-47e2-a7d1-fda424b1120b>;
        suomi-meta:creator            "5dc030a4-740f-4dde-9548-4e6e797899d8";
