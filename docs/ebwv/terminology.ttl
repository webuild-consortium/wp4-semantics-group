<urn:uuid:e254905d-b7aa-47d3-85c8-1545b363c478>
        rdf:type                      skos-xl:Label;
        skos-xl:literalForm           "matronymic name"@en;
        suomi-meta:publicationStatus  <http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT> .

webuild:matronymicname
        rdf:type                      skos:Concept;
        dcterms:created               "2026-04-28T14:28:12.076Z"^^xsd:dateTime;
        dcterms:modified              "2026-04-28T14:28:48.086Z"^^xsd:dateTime;
        skos:definition               "a name component derived from the given name of a person’s mother"@en;
        skos:example                  "A person record includes a matronymic name formed from the given name of the person’s mother, where this is part of the person’s officially recognised name structure."@en;
        skos:inScheme                 webuild:;
        skos:note                     "In the EBWV context, matronymic name should be used only for a person-name component that is formed from the mother’s given name, according to the naming rules or practices of a relevant jurisdiction or culture. It should not be confused with a family name inherited through the mother’s family line, a mother’s maiden name, or a general maternal surname. It is the maternal counterpart of a patronymic name."@en;
        skos:prefLabel                <urn:uuid:e254905d-b7aa-47d3-85c8-1545b363c478>;
        skos:related                  webuild:givenname;
        suomi-meta:creator            "5dc030a4-740f-4dde-9548-4e6e797899d8";
        suomi-meta:modifier           "5dc030a4-740f-4dde-9548-4e6e797899d8";
        suomi-meta:publicationStatus  <http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT>;
        term:orderedExample           ( "A person record includes a matronymic name formed from the given name of the person’s mother, where this is part of the person’s officially recognised name structure."@en );
        term:orderedNote              ( "In the EBWV context, matronymic name should be used only for a person-name component that is formed from the mother’s given name, according to the naming rules or practices of a relevant jurisdiction or culture. It should not be confused with a family name inherited through the mother’s family line, a mother’s maiden name, or a general maternal surname. It is the maternal counterpart of a patronymic name."@en );
        term:orderedRelated           ( webuild:givenname ) .

webuild:lei  rdf:type                 skos:Concept;
        dcterms:created               "2026-04-28T14:25:13.054Z"^^xsd:dateTime;
        dcterms:modified              "2026-04-28T14:25:13.054Z"^^xsd:dateTime;
        skos:altLabel                 <urn:uuid:427d3424-d925-4b76-b6ef-47af9b8eb768>;
        skos:definition               "a globally unique reference code assigned under the Global LEI System to identify a legal entity participating in financial, business or regulatory transactions"@en;
        skos:inScheme                 webuild:;
        skos:note                     "In the EBWV context, LEI denotes the identifier issued through the Global LEI System and maintained under the governance of GLEIF-accredited Local Operating Units. It identifies a legal entity, not a natural person acting in a private capacity, and should be used as an identifier value for an LEI-eligible entity. The LEI is especially relevant for cross-border business identification, financial reporting, procurement, trade, sanctions screening and regulatory verification."@en;
        skos:prefLabel                <urn:uuid:643b36a8-4c6b-4682-af25-9f2f4568de6b>;
        suomi-meta:creator            "5dc030a4-740f-4dde-9548-4e6e797899d8";
        suomi-meta:modifier           "5dc030a4-740f-4dde-9548-4e6e797899d8";
        suomi-meta:publicationStatus  <http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT>;
        term:orderedNote              ( "In the EBWV context, LEI denotes the identifier issued through the Global LEI System and maintained under the governance of GLEIF-accredited Local Operating Units. It identifies a legal entity, not a natural person acting in a private capacity, and should be used as an identifier value for an LEI-eligible entity. The LEI is especially relevant for cross-border business identification, financial reporting, procurement, trade, sanctions screening and regulatory verification."@en );
        term:orderedSynonym           ( <urn:uuid:427d3424-d925-4b76-b6ef-47af9b8eb768> ) .

