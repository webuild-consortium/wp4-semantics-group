webuild:subscribedcapital
        rdf:type                      skos:Concept;
        dcterms:created               "2026-02-03T15:31:29.16Z"^^xsd:dateTime;
        dcterms:modified              "2026-02-17T14:06:02.308Z"^^xsd:dateTime;
        skos:definition               "the total monetary amount of capital that shareholders or members have formally committed to contribute to a company under its constitutive documents"@en;
        skos:example                  "A private limited company with registered subscribed capital of 25,000 EUR.\nA public limited company with subscribed capital of 100,000 EUR, partially paid."@en;
        skos:inScheme                 webuild:;
        skos:note                     "Subscribed capital represents a legally binding commitment of capital participation in a company.\nIt may be fully or partially paid and is recorded in official company registration or statutory documents.\nIt applies primarily to capital-based legal entities."@en;
        skos:prefLabel                <urn:uuid:847a0421-d786-4fa4-b5e5-59a139eac626>;
        suomi-meta:creator            "5dc030a4-740f-4dde-9548-4e6e797899d8";
        suomi-meta:modifier           "5dc030a4-740f-4dde-9548-4e6e797899d8";
        suomi-meta:publicationStatus  <http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT>;
        term:orderedExample           ( "A private limited company with registered subscribed capital of 25,000 EUR.\nA public limited company with subscribed capital of 100,000 EUR, partially paid."@en );
        term:orderedNote              ( "Subscribed capital represents a legally binding commitment of capital participation in a company.\nIt may be fully or partially paid and is recorded in official company registration or statutory documents.\nIt applies primarily to capital-based legal entities."@en ) .

