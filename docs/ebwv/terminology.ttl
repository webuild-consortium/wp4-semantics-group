        dcterms:created               "2025-01-09T12:45:32.29Z"^^xsd:dateTime;
        dcterms:modified              "2026-01-23T15:08:29.857Z"^^xsd:dateTime;
        skos:altLabel                 <urn:uuid:066ae5c3-2faa-4f97-8d92-9e97283e0dd3> , <urn:uuid:20bf563a-35b8-4435-920a-06e6d0136e24> , <urn:uuid:49221e2a-9a25-4075-b180-cbeac87b8ad2>;
        skos:broader                  webuild:concept-18;
        skos:definition               "a name under which the legal entity is registered"@en;
        skos:inScheme                 webuild:;
        skos:note                     "The legal name is the authoritative registered/recorded name for legal and regulated contexts; it may differ from trading name(s); it may also have multilingual forms."@en , "The EU Core Business Vocabulary defines \"legal name\" as:\n\"The name under which the Legal Entity is legally registered.\""@en;
        skos:prefLabel                <urn:uuid:b7e1dd0b-5275-4de3-830c-94456e05fe3f>;
        skos:related                  webuild:concept-14 , webuild:concept-6006;
