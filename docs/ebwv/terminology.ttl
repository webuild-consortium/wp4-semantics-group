webuild:countryofbirth
        rdf:type                      skos:Concept;
        dcterms:created               "2026-02-16T14:37:17.229Z"^^xsd:dateTime;
        dcterms:modified              "2026-02-16T14:37:17.229Z"^^xsd:dateTime;
        skos:definition               "the sovereign state within whose territory a person’s birth was officially registered"@en;
        skos:inScheme                 webuild:;
        skos:note                     "Where historical territorial changes have occurred, the country of birth shall correspond to the state recognised in the official birth record."@en , "Country of birth refers to the state associated with the place of birth at the time of birth registration.\nIt reflects territorial jurisdiction and does not imply citizenship, nationality, ethnicity, or residence."@en;
        skos:prefLabel                <urn:uuid:84772a6e-0544-4831-8109-6ab322108783>;
        suomi-meta:creator            "5dc030a4-740f-4dde-9548-4e6e797899d8";
        suomi-meta:modifier           "5dc030a4-740f-4dde-9548-4e6e797899d8";
        suomi-meta:publicationStatus  <http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT>;
        term:orderedNote              ( "Country of birth refers to the state associated with the place of birth at the time of birth registration.\nIt reflects territorial jurisdiction and does not imply citizenship, nationality, ethnicity, or residence."@en "Where historical territorial changes have occurred, the country of birth shall correspond to the state recognised in the official birth record."@en ) .

