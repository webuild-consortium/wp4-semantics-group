webuild:placeofwork  rdf:type         skos:Concept;
        dcterms:created               "2026-04-28T14:44:57.898Z"^^xsd:dateTime;
        dcterms:modified              "2026-04-28T14:44:57.898Z"^^xsd:dateTime;
        skos:altLabel                 <urn:uuid:d936318b-ae72-4c8b-8486-270260979c68> , <urn:uuid:6e3c6430-a1df-4998-8eff-4c20826bc035> , <urn:uuid:974c0a4a-840a-458f-971b-8ff4c98eb2d7> , <urn:uuid:ab4596a9-c0b1-4217-96b8-84a37c80c6de>;
        skos:definition               "the location where a worker performs, is expected to perform, or is assigned to perform work during an employment, posting or work assignment"@en;
        skos:example                  "A Posted Worker Notification states that the worker’s place of work is a construction site operated by the host entity in Antwerp, Belgium."@en;
        skos:inScheme                 webuild:;
        skos:note                     "In the Posted Worker Notification context, place of work denotes the location in the host country where the posted worker will carry out the posted work. It may be a construction site, office, factory, vessel, service location, client premises, branch, establishment or another identifiable work site. The concept should be distinguished from the worker’s domicile or residence, the employer’s registered address, the host entity’s registered address, and the administrative address used for correspondence. Where the work is performed at several locations, the notification may need to list multiple places of work or describe the area or route of work."@en;
        skos:prefLabel                <urn:uuid:a22da038-f911-47fc-95b7-79be7d7ef8ea>;
        suomi-meta:creator            "5dc030a4-740f-4dde-9548-4e6e797899d8";
        suomi-meta:modifier           "5dc030a4-740f-4dde-9548-4e6e797899d8";
        suomi-meta:publicationStatus  <http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT>;
        term:orderedExample           ( "A Posted Worker Notification states that the worker’s place of work is a construction site operated by the host entity in Antwerp, Belgium."@en );
        term:orderedNote              ( "In the Posted Worker Notification context, place of work denotes the location in the host country where the posted worker will carry out the posted work. It may be a construction site, office, factory, vessel, service location, client premises, branch, establishment or another identifiable work site. The concept should be distinguished from the worker’s domicile or residence, the employer’s registered address, the host entity’s registered address, and the administrative address used for correspondence. Where the work is performed at several locations, the notification may need to list multiple places of work or describe the area or route of work."@en );
        term:orderedSynonym           ( <urn:uuid:ab4596a9-c0b1-4217-96b8-84a37c80c6de> <urn:uuid:974c0a4a-840a-458f-971b-8ff4c98eb2d7> <urn:uuid:6e3c6430-a1df-4998-8eff-4c20826bc035> <urn:uuid:d936318b-ae72-4c8b-8486-270260979c68> ) .

