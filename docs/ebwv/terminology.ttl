webuild:concept-98  rdf:type          skos:Concept;
        dcterms:created               "2025-12-04T12:57:50.496Z"^^xsd:dateTime;
        dcterms:modified              "2026-01-23T15:10:44.566Z"^^xsd:dateTime;
        skos:broader                  webuild:concept-6006;
        skos:definition               "an economic operator or public sector body that owns, or has a right of use of, a European Business Wallet under the regulation"@en;
        skos:inScheme                 webuild:;
        skos:note                     "It is important to notice that this concept does not refer to the ultimate beneficial owner of the economic operator but only to the economic operator entity that controls the instance of the wallet."@en;
        skos:prefLabel                <urn:uuid:e734dc6d-3e88-41e8-8b77-620971460acc>;
        skos:related                  webuild:concept-6006 , webuild:concept-100 , webuild:concept-94 , webuild:concept-96;
