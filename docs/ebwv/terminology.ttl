webuild:scope  rdf:type               skos:Concept;
        dcterms:created               "2026-02-04T11:06:10.028Z"^^xsd:dateTime;
        dcterms:modified              "2026-02-04T11:06:10.028Z"^^xsd:dateTime;
        skos:definition               "the set of actions, powers, and subject matters for which a power of attorney (mandate) authorizes the mandatee to act on behalf of the mandator, including any functional, domain, or process limitations (and, where applicable, exclusions) that determine what the mandatee is permitted to do and what falls outside the authorization"@en;
        skos:inScheme                 webuild:;
        skos:prefLabel                <urn:uuid:96cbd269-b0bb-45f0-8e68-fb3db51bf229>;
        suomi-meta:creator            "5dc030a4-740f-4dde-9548-4e6e797899d8";
        suomi-meta:modifier           "5dc030a4-740f-4dde-9548-4e6e797899d8";
        suomi-meta:publicationStatus  <http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT> .

<urn:uuid:10f9266e-1ea9-402c-b8d1-5160132cfd99>
        rdf:type                      skos-xl:Label;
        skos-xl:literalForm           "mandatee"@en;
        suomi-meta:publicationStatus  <http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT> .

webuild:mandatee  rdf:type            skos:Concept;
        dcterms:created               "2026-02-04T11:04:13.713Z"^^xsd:dateTime;
        dcterms:modified              "2026-02-04T11:04:13.713Z"^^xsd:dateTime;
        skos:definition               "an agent — a natural person or legal person — that is granted a mandate (power of attorney) by a mandator to act on the mandator’s behalf in one or more specified legal, administrative, or business matters, within the defined scope, constraints, and validity of that authorization, and whose authority can be presented and verified towards relying parties in the EU Business Wallet"@en;
        skos:inScheme                 webuild:;
        skos:prefLabel                <urn:uuid:10f9266e-1ea9-402c-b8d1-5160132cfd99>;
        suomi-meta:creator            "5dc030a4-740f-4dde-9548-4e6e797899d8";
