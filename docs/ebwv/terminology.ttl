        suomi-meta:publicationStatus  <http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT> .

<urn:uuid:51431892-cf81-4682-877e-11b4210237f1>
        rdf:type                      skos-xl:Label;
        skos-xl:literalForm           "full address"@en;
        suomi-meta:publicationStatus  <http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT> .

webuild:fulladdress  rdf:type         skos:Concept;
        dcterms:created               "2026-02-16T09:39:42.984Z"^^xsd:dateTime;
        dcterms:modified              "2026-02-16T09:39:42.984Z"^^xsd:dateTime;
        skos:definition               "the complete address written as a string"@en;
        skos:inScheme                 webuild:;
        skos:note                     "An example of a full address is \"Champ de Mars, 5 Avenue Anatole France, 75007 Paris, France\"."@en;
        skos:prefLabel                <urn:uuid:51431892-cf81-4682-877e-11b4210237f1>;
        suomi-meta:creator            "5dc030a4-740f-4dde-9548-4e6e797899d8";
        suomi-meta:modifier           "5dc030a4-740f-4dde-9548-4e6e797899d8";
        suomi-meta:publicationStatus  <http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT>;
        term:orderedNote              ( "An example of a full address is \"Champ de Mars, 5 Avenue Anatole France, 75007 Paris, France\"."@en ) .

<urn:uuid:cd69f4e6-4db1-4042-a611-59e438c87de8>
        rdf:type                      skos-xl:Label;
        skos-xl:literalForm           "locator designator"@en;
        suomi-meta:publicationStatus  <http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT> .

webuild:locationdesignator
        rdf:type                      skos:Concept;
        dcterms:created               "2026-02-16T09:36:36.703Z"^^xsd:dateTime;
        dcterms:modified              "2026-02-16T09:36:36.703Z"^^xsd:dateTime;
        skos:definition               "A number or sequence of characters that uniquely identifies the locator within the relevant scope."@en;
        skos:inScheme                 webuild:;
        skos:note                     "In simpler terms, this is the building number, apartment number, etc. For an address such as \"Flat 3, 17 Bridge Street\", the locator is \"flat 3, 17\". A German example: \"Hauptstrasse 6 A\", the locator is \"6 A\"."@en;
        skos:prefLabel                <urn:uuid:cd69f4e6-4db1-4042-a611-59e438c87de8>;
        suomi-meta:creator            "5dc030a4-740f-4dde-9548-4e6e797899d8";
        suomi-meta:modifier           "5dc030a4-740f-4dde-9548-4e6e797899d8";
        suomi-meta:publicationStatus  <http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT>;
        term:orderedNote              ( "In simpler terms, this is the building number, apartment number, etc. For an address such as \"Flat 3, 17 Bridge Street\", the locator is \"flat 3, 17\". A German example: \"Hauptstrasse 6 A\", the locator is \"6 A\"."@en ) .

webuild:locatorname  rdf:type         skos:Concept;
        dcterms:created               "2026-02-16T09:30:01.03Z"^^xsd:dateTime;
        dcterms:modified              "2026-02-16T09:30:01.03Z"^^xsd:dateTime;
        skos:definition               "Proper noun(s) applied to the real world entity identified by the locator. The locator name could be the name of the property or complex, of the building or part of the building, or it could be the name of a room inside a building."@en;
        skos:inScheme                 webuild:;
        skos:note                     "The locator name could be the name of the property or complex, of the building or part of the building, or it could be the name of a room inside a building.\n\nThe key difference between a locator designator and a locator name is that the latter is a proper name and is unlikely to include digits. For example, \"Shumann, Berlaymont\" is a meeting room within the European Commission headquarters for which locator name is more appropriate than locator."@en;
        skos:prefLabel                <urn:uuid:4f64d4c4-0896-4276-a110-115f26e495ec>;
        suomi-meta:creator            "5dc030a4-740f-4dde-9548-4e6e797899d8";
        suomi-meta:modifier           "5dc030a4-740f-4dde-9548-4e6e797899d8";
        suomi-meta:publicationStatus  <http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT>;
        term:orderedNote              ( "The locator name could be the name of the property or complex, of the building or part of the building, or it could be the name of a room inside a building.\n\nThe key difference between a locator designator and a locator name is that the latter is a proper name and is unlikely to include digits. For example, \"Shumann, Berlaymont\" is a meeting room within the European Commission headquarters for which locator name is more appropriate than locator."@en ) .

<urn:uuid:4f64d4c4-0896-4276-a110-115f26e495ec>
        rdf:type                      skos-xl:Label;
        skos-xl:literalForm           "locator name"@en;
        suomi-meta:publicationStatus  <http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT> .

webuild:pobox  rdf:type               skos:Concept;
        dcterms:created               "2026-02-16T09:25:06.808Z"^^xsd:dateTime;
        dcterms:modified              "2026-02-16T09:25:06.808Z"^^xsd:dateTime;
        skos:definition               "A location designator for a postal delivery point at a post office, usually a number."@en;
        skos:inScheme                 webuild:;
        skos:note                     "INSPIRE's name for this is \"postalDeliveryIdentifier\" for which it uses the locator designator property with a type attribute of that name. This vocabulary separates out the Post Office Box for greater independence of technology. An example post office box number is \"9383\"."@en;
