        suomi-meta:publicationStatus  <http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT>;
        term:orderedBroader           ( webuild:concept-4 );
        term:orderedNote              ( "The registered address is the address, where the legal entity or his or her representative is available for official matters. Most often this is the address of the main office, head office, registered office or headquarters of the agent.  For most companies the registered address is also the default address but an agent can also declare a specific postal address separately.\n\nEU Core Business Vocabulary definition for \"registered address\" = The address at which the Legal Entity is legally registered."@en );
        term:orderedRelated           ( webuild:concept-43 );
        term:orderedSynonym           ( <urn:uuid:dbb62c87-ba54-403a-8e68-5e3db4436e3e> ) .

