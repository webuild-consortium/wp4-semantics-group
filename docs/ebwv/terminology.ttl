webuild:concept-109  rdf:type         skos:Concept;
        dcterms:created               "2026-01-07T10:43:28.799Z"^^xsd:dateTime;
        dcterms:modified              "2026-01-23T15:05:31.732Z"^^xsd:dateTime;
        skos:broader                  webuild:concept-1;
        skos:definition               "an entity other than a natural person that is recognised by law as having legal personality, enabling it to hold rights and obligations independently of the natural persons associated with it"@en;
        skos:inScheme                 webuild:;
        skos:note                     "Core characteristics for a legal person:\n- A legal person is created through a legal act (registration, statute, treaty)\n- It has a separate legal personality\n- It acts through representatives\n- It has continuity beyond individual members\n\nTypical narrower concepts:\n- Company / Corporation\n- Association\n- Foundation\n- Cooperative\n- Public authority (NB: public bodies may be legal persons depending on national law)\n- International organisation"@en;
        skos:prefLabel                <urn:uuid:c94fbb43-9e60-49fb-8fea-452995505450>;
        skos:related                  webuild:concept-6005 , webuild:concept-94;
        suomi-meta:creator            "5dc030a4-740f-4dde-9548-4e6e797899d8";
        suomi-meta:modifier           "5dc030a4-740f-4dde-9548-4e6e797899d8";
        suomi-meta:publicationStatus  <http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT>;
        term:orderedBroader           ( webuild:concept-1 );
        term:orderedNote              ( "Core characteristics for a legal person:\n- A legal person is created through a legal act (registration, statute, treaty)\n- It has a separate legal personality\n- It acts through representatives\n- It has continuity beyond individual members\n\nTypical narrower concepts:\n- Company / Corporation\n- Association\n- Foundation\n- Cooperative\n- Public authority (NB: public bodies may be legal persons depending on national law)\n- International organisation"@en );
        term:orderedRelated           ( webuild:concept-6005 webuild:concept-94 ) .

webuild:concept-105  rdf:type         skos:Concept;
        dcterms:created               "2025-01-09T12:45:32.29Z"^^xsd:dateTime;
        dcterms:modified              "2026-04-14T07:13:05.804Z"^^xsd:dateTime;
        skos:altLabel                 <urn:uuid:602507ce-5a2f-42c5-ac2b-294a26b18096> , <urn:uuid:75da39c3-ad77-443b-b21e-634e2c61aa34> , <urn:uuid:ba8b6757-41f0-4bfb-a3db-947fca50b8ae>;
        skos:broader                  webuild:concept-18;
        skos:definition               "a name under which the legal entity is registered"@en;
        skos:inScheme                 webuild:;
        skos:note                     "The EU Core Business Vocabulary defines \"legal name\" as:\n\"The name under which the Legal Entity is legally registered.\""@en , "The legal name is the authoritative registered/recorded name for legal and regulated contexts; it may differ from trading name(s); it may also have multilingual forms."@en;
        skos:prefLabel                <urn:uuid:366211ea-ba2d-4b7d-b633-d7a6097c9c2d>;
        skos:related                  webuild:concept-6006 , webuild:concept-14;
        suomi-meta:creator            "4c00fd3e-ad5d-4ad6-8782-de29597a5d57";
        suomi-meta:modifier           "5dc030a4-740f-4dde-9548-4e6e797899d8";
        suomi-meta:publicationStatus  <http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT>;
        term:orderedBroader           ( webuild:concept-18 );
        term:orderedNote              ( "The EU Core Business Vocabulary defines \"legal name\" as:\n\"The name under which the Legal Entity is legally registered.\""@en "The legal name is the authoritative registered/recorded name for legal and regulated contexts; it may differ from trading name(s); it may also have multilingual forms."@en );
        term:orderedRelated           ( webuild:concept-6006 webuild:concept-14 );
        term:orderedSynonym           ( <urn:uuid:602507ce-5a2f-42c5-ac2b-294a26b18096> <urn:uuid:75da39c3-ad77-443b-b21e-634e2c61aa34> <urn:uuid:ba8b6757-41f0-4bfb-a3db-947fca50b8ae> ) .

webuild:concept-7  rdf:type           skos:Concept;
        dcterms:created               "2021-12-13T14:42:43Z";
        dcterms:modified              "2026-04-14T05:49:04.049Z"^^xsd:dateTime;
        <http://purl.org/termed/properties/id>
                "34a93245-36f6-4b98-a1cc-60fcf66fac99";
        skos:definition               "a structured reference that identifies an entity"@en;
        skos:inScheme                 webuild:;
        skos:narrower                 webuild:concept-14;
        skos:note                     "In the context of business related information, the main identifier for a business entity is usually the \"legal identifier\", which is the identifier given to the business entity when it is registered by a competent authority in a specific jurisdiction."@en;
        skos:prefLabel                <urn:uuid:8b376364-58c7-4435-ba1e-bafdcbc4d0fd> , <urn:uuid:4b4b9460-6371-40b3-b360-ed7f5bc67773> , <urn:uuid:34fda745-a8e5-4a35-bb3a-ab297cc30a1f>;
