webuild:partner  rdf:type             skos:Concept;
        dcterms:created               "2026-04-28T14:36:56.799Z"^^xsd:dateTime;
        dcterms:modified              "2026-04-28T14:36:56.799Z"^^xsd:dateTime;
        skos:altLabel                 <urn:uuid:58012364-8330-413b-953c-1f34852d19c7> , <urn:uuid:76bd10e9-95ee-43e9-a5ea-16209eeebad7>;
        skos:definition               "a person or legal [entity] that is a member of a partnership or comparable company-law entity and whose status as partner is recorded or recognised by the competent business register or company register"@en;
        skos:example                  "An EU Company Certificate for a limited partnership identifies a natural person as a limited partner and a legal entity as a general partner."@en;
        skos:inScheme                 webuild:;
        skos:note                     "Use partner only where the source register or legal form identifies the entity as a partner in a partnership-type entity. For companies limited by shares, the more appropriate concept is usually shareholder, member, beneficial owner, or legal representative, depending on the intended meaning."@en , "In the EBWV context, and especially in the EU Company Certificate context, partner should be understood as a company-law role in a partnership or similar registered entity. It refers to an entity that participates in the legal structure of the company as a partner, not to a commercial counterparty, cooperation partner, customer, supplier, spouse, or informal business collaborator.\n\nThe term is relevant because the EU Company Certificate introduced by Article 16b of Directive (EU) 2017/1132, as amended by Directive (EU) 2025/25, is intended to provide standardised company-register evidence across Member States, including core company information and, for relevant entity types, information about persons or entities connected to the company’s legal structure. Directive (EU) 2025/25 also extends digital company-law disclosure to certain partnerships listed in the new Annex IIB."@en;
        skos:prefLabel                <urn:uuid:cd11d154-3c55-4ec0-924e-02730c239d2f>;
        suomi-meta:creator            "5dc030a4-740f-4dde-9548-4e6e797899d8";
        suomi-meta:modifier           "5dc030a4-740f-4dde-9548-4e6e797899d8";
        suomi-meta:publicationStatus  <http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT>;
        term:orderedExample           ( "An EU Company Certificate for a limited partnership identifies a natural person as a limited partner and a legal entity as a general partner."@en );
        term:orderedNote              ( "In the EBWV context, and especially in the EU Company Certificate context, partner should be understood as a company-law role in a partnership or similar registered entity. It refers to an entity that participates in the legal structure of the company as a partner, not to a commercial counterparty, cooperation partner, customer, supplier, spouse, or informal business collaborator.\n\nThe term is relevant because the EU Company Certificate introduced by Article 16b of Directive (EU) 2017/1132, as amended by Directive (EU) 2025/25, is intended to provide standardised company-register evidence across Member States, including core company information and, for relevant entity types, information about persons or entities connected to the company’s legal structure. Directive (EU) 2025/25 also extends digital company-law disclosure to certain partnerships listed in the new Annex IIB."@en "Use partner only where the source register or legal form identifies the entity as a partner in a partnership-type entity. For companies limited by shares, the more appropriate concept is usually shareholder, member, beneficial owner, or legal representative, depending on the intended meaning."@en );
        term:orderedSynonym           ( <urn:uuid:76bd10e9-95ee-43e9-a5ea-16209eeebad7> <urn:uuid:58012364-8330-413b-953c-1f34852d19c7> ) .

