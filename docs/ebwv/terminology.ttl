webuild:concept-6006  rdf:type        skos:Concept;
        dcterms:created               "2023-11-09T13:34:04Z";
        dcterms:modified              "2026-01-23T14:38:10.967Z"^^xsd:dateTime;
        <http://purl.org/termed/properties/id>
                "42ea77c6-99e7-44fd-91b4-33a2f179018d";
        skos:broader                  webuild:concept-41;
        skos:changeNote               "alternative definitions:\n1. \"a natural person or a legal person that is recognised by a legal system as capable of holding rights and obligations\"\n2. \"a formal organization that is involved in economic activity\"";
        skos:definition               "an agent whose identity is legally recognised for transactions and that can be referenced unambiguously by a legal identifier issued or recognised by a competent authority"@en;
        skos:inScheme                 webuild:;
        skos:narrower                 webuild:concept-98;
        skos:note                     "In WE BUILD, “legal entity” is intended as the transactional/legal identity used in B2B/B2G processes. It can include: a legal person (e.g., company), and in jurisdictions where applicable, a natural person acting as a registered business actor (e.g., sole trader) whose business identity is legally recognised and identifiable."@en , "In the WE BUILD context a \"legal entity\" is a company, business, sole trader, non-profit association or similar entity that is registered with a business registration authority or other public authority; most \"economic operators\" are therefore also \"legal entities\"."@en;
        skos:prefLabel                <urn:uuid:2eaee03b-3e77-4da9-8afd-2f29361a1080>;
        skos:related                  webuild:concept-6005 , webuild:concept-109 , webuild:concept-105 , webuild:concept-7 , webuild:concept-94;
        suomi-meta:creator            "4c00fd3e-ad5d-4ad6-8782-de29597a5d57";
        suomi-meta:modifier           "5dc030a4-740f-4dde-9548-4e6e797899d8";
        suomi-meta:publicationStatus  <http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT>;
        term:orderedBroader           ( webuild:concept-41 );
        term:orderedNarrower          ( webuild:concept-98 );
        term:orderedNote              ( "In the WE BUILD context a \"legal entity\" is a company, business, sole trader, non-profit association or similar entity that is registered with a business registration authority or other public authority; most \"economic operators\" are therefore also \"legal entities\"."@en "In WE BUILD, “legal entity” is intended as the transactional/legal identity used in B2B/B2G processes. It can include: a legal person (e.g., company), and in jurisdictions where applicable, a natural person acting as a registered business actor (e.g., sole trader) whose business identity is legally recognised and identifiable."@en );
        term:orderedRelated           ( webuild:concept-6005 webuild:concept-109 webuild:concept-94 webuild:concept-105 webuild:concept-7 ) .

