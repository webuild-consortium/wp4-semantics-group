        suomi-meta:publicationStatus  <http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT> .

webuild:authorisation
        rdf:type                      skos:Concept;
        dcterms:created               "2026-02-04T11:09:41.396Z"^^xsd:dateTime;
        dcterms:modified              "2026-02-04T11:09:41.396Z"^^xsd:dateTime;
        skos:definition               "a legally or contractually valid empowerment by which an agent is granted the right to perform one or more actions, exercise specified powers, or act in a defined capacity towards other parties, within a stated scope and validity, and which may be presented and verified as evidence of authority in the EU Business Wallet context"@en;
        skos:inScheme                 webuild:;
        skos:narrower                 webuild:powerofattorney , webuild:concept-75;
        skos:prefLabel                <urn:uuid:846f3541-0f10-4020-b2c3-3a1decc4bbc2>;
        suomi-meta:creator            "5dc030a4-740f-4dde-9548-4e6e797899d8";
