webuild:locationdesignator
        rdf:type                      skos:Concept;
        dcterms:created               "2026-02-16T09:36:36.703Z"^^xsd:dateTime;
        dcterms:modified              "2026-02-16T09:36:36.703Z"^^xsd:dateTime;
        skos:definition               "A number or sequence of characters that uniquely identifies the locator within the relevant scope."@en;
        skos:inScheme                 webuild:;
        skos:note                     "In simpler terms, this is the building number, apartment number, etc. For an address such as \"Flat 3, 17 Bridge Street\", the locator is \"flat 3, 17\". A German example: \"Hauptstrasse 6 A\", the locator is \"6 A\"."@en;
        skos:prefLabel                <urn:uuid:cd69f4e6-4db1-4042-a611-59e438c87de8>;
        suomi-meta:creator            "5dc030a4-740f-4dde-9548-4e6e797899d8";
        suomi-meta:modifier           "5dc030a4-740f-4dde-9548-4e6e797899d8";
        suomi-meta:publicationStatus  <http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT>;
        term:orderedNote              ( "In simpler terms, this is the building number, apartment number, etc. For an address such as \"Flat 3, 17 Bridge Street\", the locator is \"flat 3, 17\". A German example: \"Hauptstrasse 6 A\", the locator is \"6 A\"."@en ) .

