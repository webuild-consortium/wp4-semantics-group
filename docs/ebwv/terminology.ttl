webuild:legalidentifier
        rdf:type                      skos:Concept;
        dcterms:created               "2026-02-03T15:04:12.908Z"^^xsd:dateTime;
        dcterms:modified              "2026-04-14T07:13:47.273Z"^^xsd:dateTime;
        dcterms:source                "https://semiceu.github.io/Core-Business-Vocabulary/releases/2.2.0/#LegalEntity.legalidentifier";
        skos:broader                  webuild:identifier;
        skos:definition               "the unambiguous structured reference assigned to the legal entity by the legal authority that registered it"@en;
        skos:inScheme                 webuild:;
        skos:note                     "Legal Entity must have a unique identification number, allowing it to be clearly identified in communication across business registers. The Core vocabulary sets no restriction on the type of legal identifier. In many countries, the business register's identifier is the relevant data point.\n\nRemoved: \"The details of the registration are provided as properties of the Identifier class.\""@en;
        skos:prefLabel                <urn:uuid:6fb558b9-ac6f-44e5-938f-c2c6989b7cbe>;
        suomi-meta:creator            "5dc030a4-740f-4dde-9548-4e6e797899d8";
        suomi-meta:modifier           "5dc030a4-740f-4dde-9548-4e6e797899d8";
        suomi-meta:publicationStatus  <http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT>;
        term:orderedBroader           ( webuild:identifier );
        term:orderedNote              ( "Legal Entity must have a unique identification number, allowing it to be clearly identified in communication across business registers. The Core vocabulary sets no restriction on the type of legal identifier. In many countries, the business register's identifier is the relevant data point.\n\nRemoved: \"The details of the registration are provided as properties of the Identifier class.\""@en );
        term:orderedSource            ( "https://semiceu.github.io/Core-Business-Vocabulary/releases/2.2.0/#LegalEntity.legalidentifier" ) .

webuild:legalname  rdf:type           skos:Concept;
        dcterms:created               "2026-02-03T14:56:47.143Z"^^xsd:dateTime;
        dcterms:modified              "2026-02-03T14:56:47.143Z"^^xsd:dateTime;
        dcterms:source                "https://semiceu.github.io/Core-Business-Vocabulary/releases/2.2.0/#LegalEntity.legalname";
        skos:altLabel                 <urn:uuid:21bfc130-0b34-4049-a37a-10f8fabbfcd5> , <urn:uuid:b09248cf-2495-426b-9423-4a72dab92ddf>;
        skos:definition               "the name under which the legal entity is legally registered"@en;
        skos:inScheme                 webuild:;
        skos:note                     "The legal name is different from the alternative (trade) name which is a pseudonym used by companies that do not operate under their registered company name. A business might have more than one legal name, particularly in countries with more than one official language. In such cases, and where the encoding technology allows, the language of the string should be identified."@en;
        skos:prefLabel                <urn:uuid:2515b85a-ef0e-4590-a7e6-76afab617224>;
        suomi-meta:creator            "5dc030a4-740f-4dde-9548-4e6e797899d8";
        suomi-meta:modifier           "5dc030a4-740f-4dde-9548-4e6e797899d8";
        suomi-meta:publicationStatus  <http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT>;
        term:orderedNote              ( "The legal name is different from the alternative (trade) name which is a pseudonym used by companies that do not operate under their registered company name. A business might have more than one legal name, particularly in countries with more than one official language. In such cases, and where the encoding technology allows, the language of the string should be identified."@en );
        term:orderedSource            ( "https://semiceu.github.io/Core-Business-Vocabulary/releases/2.2.0/#LegalEntity.legalname" );
        term:orderedSynonym           ( <urn:uuid:b09248cf-2495-426b-9423-4a72dab92ddf> <urn:uuid:21bfc130-0b34-4049-a37a-10f8fabbfcd5> ) .

