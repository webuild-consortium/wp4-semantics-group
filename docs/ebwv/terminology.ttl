webuild:residency  rdf:type           skos:Concept;
        dcterms:created               "2026-04-28T14:51:03.792Z"^^xsd:dateTime;
        dcterms:modified              "2026-04-28T14:52:50.651Z"^^xsd:dateTime;
        skos:altLabel                 <urn:uuid:8d5ed253-0eee-4e45-a7b5-699433c26e74> , <urn:uuid:94049a93-dad2-4171-ab1a-af40f3db90a8> , <urn:uuid:82673e05-b0ef-4ebb-806e-6176b899c171> , <urn:uuid:36edeff8-d162-4a0a-8041-507eadff3446> , <urn:uuid:049ffcfe-48d1-43be-930a-3af889bbb412>;
        skos:definition               "a jurisdiction in which a person has their dwelling or is officially regarded as living or residing"@en;
        skos:example                  "A person identity attestation states that the person’s residency is Finland, represented as a jurisdiction rather than as a street address."@en;
        skos:inScheme                 webuild:;
        skos:note                     "In the EBWV context, residency should be used for a person’s legally or administratively relevant jurisdiction of residence. It should not be modelled as a postal address or physical address field. It should be distinguished from domicile, which the EU Core Person Vocabulary defines as the place the person treats as their permanent home and models with range Address; residency, by contrast, is linked to a Jurisdiction."@en;
        skos:prefLabel                <urn:uuid:7c8172e4-c222-473b-b4c4-1318dd6386e8>;
        skos:related                  webuild:jurisdiction;
        suomi-meta:creator            "5dc030a4-740f-4dde-9548-4e6e797899d8";
        suomi-meta:modifier           "5dc030a4-740f-4dde-9548-4e6e797899d8";
        suomi-meta:publicationStatus  <http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT>;
        term:orderedExample           ( "A person identity attestation states that the person’s residency is Finland, represented as a jurisdiction rather than as a street address."@en );
        term:orderedNote              ( "In the EBWV context, residency should be used for a person’s legally or administratively relevant jurisdiction of residence. It should not be modelled as a postal address or physical address field. It should be distinguished from domicile, which the EU Core Person Vocabulary defines as the place the person treats as their permanent home and models with range Address; residency, by contrast, is linked to a Jurisdiction."@en );
        term:orderedRelated           ( webuild:jurisdiction );
        term:orderedSynonym           ( <urn:uuid:94049a93-dad2-4171-ab1a-af40f3db90a8> <urn:uuid:82673e05-b0ef-4ebb-806e-6176b899c171> <urn:uuid:36edeff8-d162-4a0a-8041-507eadff3446> <urn:uuid:049ffcfe-48d1-43be-930a-3af889bbb412> <urn:uuid:8d5ed253-0eee-4e45-a7b5-699433c26e74> ) .

webuild:provider  rdf:type            skos:Concept;
        dcterms:created               "2026-04-28T14:49:37.489Z"^^xsd:dateTime;
        dcterms:modified              "2026-04-28T14:49:37.489Z"^^xsd:dateTime;
        skos:altLabel                 <urn:uuid:2958dd8a-5ed7-4da4-adf0-4420dcba1438> , <urn:uuid:25b2a89d-d6bb-4699-a181-177427e791b8> , <urn:uuid:f2bdb766-80ff-4054-9b87-62473b764aab>;
        skos:definition               "an agent that offers, supplies or makes available a service, account, facility or other capability to another party"@en;
        skos:inScheme                 webuild:;
        skos:note                     "In the EBWV context, and especially in relation to bank accounts or similar services, provider denotes the organisation or other agent that makes the service available to a customer, account holder, user or beneficiary. For a bank account, the provider is typically the bank, payment institution, electronic money institution or other regulated financial service provider that maintains or offers the account. The concept should be distinguished from the account holder, owner, user, beneficiary, intermediary and issuer of a credential. In regulated contexts, a more precise subtype such as payment service provider, account servicing payment service provider, credit institution or electronic money institution should be used where available."@en;
        skos:prefLabel                <urn:uuid:62080bc2-4e07-4bb0-980e-385371867e61>;
        suomi-meta:creator            "5dc030a4-740f-4dde-9548-4e6e797899d8";
        suomi-meta:modifier           "5dc030a4-740f-4dde-9548-4e6e797899d8";
        suomi-meta:publicationStatus  <http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT>;
        term:orderedNote              ( "In the EBWV context, and especially in relation to bank accounts or similar services, provider denotes the organisation or other agent that makes the service available to a customer, account holder, user or beneficiary. For a bank account, the provider is typically the bank, payment institution, electronic money institution or other regulated financial service provider that maintains or offers the account. The concept should be distinguished from the account holder, owner, user, beneficiary, intermediary and issuer of a credential. In regulated contexts, a more precise subtype such as payment service provider, account servicing payment service provider, credit institution or electronic money institution should be used where available."@en );
        term:orderedSynonym           ( <urn:uuid:2958dd8a-5ed7-4da4-adf0-4420dcba1438> <urn:uuid:25b2a89d-d6bb-4699-a181-177427e791b8> <urn:uuid:f2bdb766-80ff-4054-9b87-62473b764aab> ) .

