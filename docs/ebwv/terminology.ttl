webuild:adminUnitL1  rdf:type         skos:Concept;
        dcterms:created               "2026-02-16T09:45:53.956Z"^^xsd:dateTime;
        dcterms:modified              "2026-02-16T09:45:53.956Z"^^xsd:dateTime;
        skos:definition               "the name of the uppermost level of the address, almost always a country"@en;
        skos:inScheme                 webuild:;
        skos:note                     "Best practice is to use the ISO 3166-1 code but if this is inappropriate for the context, country names should be provided in a consistent manner to reduce ambiguity. For example, either write 'France' or 'FRA' consistently throughout the dataset and avoid mixing the two. The Country controlled vocabulary from the Publications Office can be reused for this."@en;
        skos:prefLabel                <urn:uuid:019632ce-2305-44a9-882c-19e924ea43db>;
        suomi-meta:creator            "5dc030a4-740f-4dde-9548-4e6e797899d8";
        suomi-meta:modifier           "5dc030a4-740f-4dde-9548-4e6e797899d8";
        suomi-meta:publicationStatus  <http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT>;
        term:orderedNote              ( "Best practice is to use the ISO 3166-1 code but if this is inappropriate for the context, country names should be provided in a consistent manner to reduce ambiguity. For example, either write 'France' or 'FRA' consistently throughout the dataset and avoid mixing the two. The Country controlled vocabulary from the Publications Office can be reused for this."@en ) .

