webuild:legalidentifier
        rdf:type                      skos:Concept;
        dcterms:created               "2026-02-03T15:04:12.908Z"^^xsd:dateTime;
        dcterms:modified              "2026-02-03T15:04:12.908Z"^^xsd:dateTime;
        dcterms:source                "https://semiceu.github.io/Core-Business-Vocabulary/releases/2.2.0/#LegalEntity.legalidentifier";
        skos:definition               "the unambiguous structured reference assigned to the legal entity by the legal authority that registered it"@en;
        skos:inScheme                 webuild:;
        skos:note                     "Legal Entity must have a unique identification number, allowing it to be clearly identified in communication across business registers. The Core vocabulary sets no restriction on the type of legal identifier. In many countries, the business register's identifier is the relevant data point.\n\nRemoved: \"The details of the registration are provided as properties of the Identifier class.\""@en;
        skos:prefLabel                <urn:uuid:6338be59-797f-4b3c-a77c-c2e7ef473114>;
        suomi-meta:creator            "5dc030a4-740f-4dde-9548-4e6e797899d8";
        suomi-meta:modifier           "5dc030a4-740f-4dde-9548-4e6e797899d8";
        suomi-meta:publicationStatus  <http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT>;
        term:orderedNote              ( "Legal Entity must have a unique identification number, allowing it to be clearly identified in communication across business registers. The Core vocabulary sets no restriction on the type of legal identifier. In many countries, the business register's identifier is the relevant data point.\n\nRemoved: \"The details of the registration are provided as properties of the Identifier class.\""@en );
        term:orderedSource            ( "https://semiceu.github.io/Core-Business-Vocabulary/releases/2.2.0/#LegalEntity.legalidentifier" ) .

