        term:orderedBroader           ( webuild:concept-41 );
        term:orderedNote              ( "Agent refers to either a person or a legal entity.  The authority to act on the other agents behalf is typically created through a formal agreement or legal instrument."@en );
        term:orderedRelated           ( webuild:concept-75 webuild:concept-77 );
        term:orderedSynonym           ( <urn:uuid:7854f27d-e119-4674-8f66-84c162054342> <urn:uuid:74c2421b-6b2b-4662-9943-dbfce0d095d2> <urn:uuid:f283c907-0eec-41e5-ad9e-3be9968d13b9> <urn:uuid:a749dcf8-c9f6-4660-9fbd-0ecf9912b3ca> <urn:uuid:7c812a06-a048-4e3d-a988-7e549bb33708> ) .

webuild:concept-77  rdf:type          skos:Concept;
        dcterms:created               "2025-02-06T12:19:26.755Z"^^xsd:dateTime;
        dcterms:modified              "2025-02-06T12:26:55.498Z"^^xsd:dateTime;
        skos:altLabel                 <urn:uuid:0f0b2940-71df-44da-8cc8-917138ba9e61> , <urn:uuid:a9e0a092-534f-449f-a097-49eb8475d5c9> , <urn:uuid:8afba972-8d8e-4e26-a4b3-d752ce0b4361> , <urn:uuid:6cb7c90a-310b-4e89-bc78-223fd201cf56> , <urn:uuid:76b2de0f-6073-4f80-8821-d1d77bdc553d>;
