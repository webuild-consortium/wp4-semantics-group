webuild:placeofbirth  rdf:type        skos:Concept;
        dcterms:created               "2026-04-28T14:41:22.938Z"^^xsd:dateTime;
        dcterms:modified              "2026-04-28T14:41:42.981Z"^^xsd:dateTime;
        skos:altLabel                 <urn:uuid:53cfd7af-d6ad-4e90-97ef-bcec9052e0b3> , <urn:uuid:20283923-7f34-45f9-9c3c-4f3a6841cf79> , <urn:uuid:b26c663e-9861-4d63-ad24-cad6cc7802b1> , <urn:uuid:85bd8c78-7c60-4ec8-b460-f2677767225e>;
        skos:definition               "the location where a person was born"@en;
        skos:example                  "A person identification attestation states that the person’s place of birth is Helsinki, Finland."@en;
        skos:inScheme                 webuild:;
        skos:note                     "In the EBWV context, place of birth should be used for the officially recorded or attested location of a person’s birth. The value may be represented as a structured location, such as a municipality, city, region or other named place, and may be supported by a geographic identifier. It should be distinguished from country of birth, which identifies only the country, and from domicile, residence or address, which describe where the person lives or is treated as living."@en;
        skos:prefLabel                <urn:uuid:94efcb37-30a1-45df-9c85-c30cb900adfd>;
        skos:related                  webuild:person;
        suomi-meta:creator            "5dc030a4-740f-4dde-9548-4e6e797899d8";
        suomi-meta:modifier           "5dc030a4-740f-4dde-9548-4e6e797899d8";
        suomi-meta:publicationStatus  <http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT>;
        term:orderedExample           ( "A person identification attestation states that the person’s place of birth is Helsinki, Finland."@en );
        term:orderedNote              ( "In the EBWV context, place of birth should be used for the officially recorded or attested location of a person’s birth. The value may be represented as a structured location, such as a municipality, city, region or other named place, and may be supported by a geographic identifier. It should be distinguished from country of birth, which identifies only the country, and from domicile, residence or address, which describe where the person lives or is treated as living."@en );
        term:orderedRelated           ( webuild:person );
        term:orderedSynonym           ( <urn:uuid:20283923-7f34-45f9-9c3c-4f3a6841cf79> <urn:uuid:b26c663e-9861-4d63-ad24-cad6cc7802b1> <urn:uuid:85bd8c78-7c60-4ec8-b460-f2677767225e> <urn:uuid:53cfd7af-d6ad-4e90-97ef-bcec9052e0b3> ) .

