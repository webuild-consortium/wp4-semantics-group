webuild:temporaryaddress
        rdf:type                      skos:Concept;
        dcterms:created               "2026-04-28T15:01:00.98Z"^^xsd:dateTime;
        dcterms:modified              "2026-04-28T15:01:00.98Z"^^xsd:dateTime;
        skos:altLabel                 <urn:uuid:d460c34c-abb0-4508-a7b5-ab134bd1d998> , <urn:uuid:aa7bffd5-55f9-49d1-8ed6-303a0a5f747a> , <urn:uuid:904a6fad-c09c-4e21-b6c0-39b14564c791> , <urn:uuid:4f3702d9-14a7-4036-a94f-f220320fcb5e>;
        skos:broader                  webuild:address;
        skos:definition               "an address at which a person resides, stays or can be reached for a limited period, without it being the person’s permanent home or domicile address"@en;
        skos:example                  "A Posted Worker Notification states that the worker’s domicile address is in Finland, while the worker’s temporary address during the posting period is an apartment in Belgium."@en;
        skos:inScheme                 webuild:;
        skos:note                     "In the EBWV context, temporary address should be used for an address that is valid only for a specific period, stay, assignment, posting, visit or other temporary circumstance. It should be distinguished from domicile, which refers to the place a person treats as their permanent home, and from a general postal address, which may be used only for receiving correspondence. In a Posted Worker Notification, a temporary address may identify the worker’s accommodation or residence in the host country during the posting period."@en;
        skos:prefLabel                <urn:uuid:83ec4bbf-a811-46d7-ab42-eaf887c2e0b0>;
        suomi-meta:creator            "5dc030a4-740f-4dde-9548-4e6e797899d8";
        suomi-meta:modifier           "5dc030a4-740f-4dde-9548-4e6e797899d8";
        suomi-meta:publicationStatus  <http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT>;
        term:orderedBroader           ( webuild:address );
        term:orderedExample           ( "A Posted Worker Notification states that the worker’s domicile address is in Finland, while the worker’s temporary address during the posting period is an apartment in Belgium."@en );
        term:orderedNote              ( "In the EBWV context, temporary address should be used for an address that is valid only for a specific period, stay, assignment, posting, visit or other temporary circumstance. It should be distinguished from domicile, which refers to the place a person treats as their permanent home, and from a general postal address, which may be used only for receiving correspondence. In a Posted Worker Notification, a temporary address may identify the worker’s accommodation or residence in the host country during the posting period."@en );
        term:orderedSynonym           ( <urn:uuid:4f3702d9-14a7-4036-a94f-f220320fcb5e> <urn:uuid:904a6fad-c09c-4e21-b6c0-39b14564c791> <urn:uuid:aa7bffd5-55f9-49d1-8ed6-303a0a5f747a> <urn:uuid:d460c34c-abb0-4508-a7b5-ab134bd1d998> ) .

