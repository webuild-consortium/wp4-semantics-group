webuild:companystatus
        rdf:type                      skos:Concept;
        dcterms:created               "2026-02-03T16:01:27.274Z"^^xsd:dateTime;
        dcterms:modified              "2026-02-03T16:01:52.249Z"^^xsd:dateTime;
        dcterms:source                "https://semiceu.github.io/Core-Business-Vocabulary/releases/2.2.0/#LegalEntity.legalentitystatus";
        skos:altLabel                 <urn:uuid:d4895be1-944d-47a2-a2f3-3f2ded35be95> , <urn:uuid:a3c69f99-3c1b-466e-b3ba-2ac7eb99984d> , <urn:uuid:6e96ab9c-2b81-4471-a912-5e5b1a39254b>;
        skos:definition               "information about the viability of the current position of the legal entity"@en;
        skos:inScheme                 webuild:;
        skos:note                     "Recording the status of a company presents the same issues as its type. The terms 'insolvent', 'bankrupt' and 'in receivership,' for example, are likely to mean slightly different things with different legal implications in different jurisdictions. Best practice for recording various other status levels is to use the relevant jurisdiction's terms and to identify the controlled vocabulary used."@en;
        skos:prefLabel                <urn:uuid:071db069-50b3-4054-a5e4-57bd9b3055c1>;
        suomi-meta:creator            "5dc030a4-740f-4dde-9548-4e6e797899d8";
        suomi-meta:modifier           "5dc030a4-740f-4dde-9548-4e6e797899d8";
        suomi-meta:publicationStatus  <http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT>;
        term:orderedNote              ( "Recording the status of a company presents the same issues as its type. The terms 'insolvent', 'bankrupt' and 'in receivership,' for example, are likely to mean slightly different things with different legal implications in different jurisdictions. Best practice for recording various other status levels is to use the relevant jurisdiction's terms and to identify the controlled vocabulary used."@en );
        term:orderedSource            ( "https://semiceu.github.io/Core-Business-Vocabulary/releases/2.2.0/#LegalEntity.legalentitystatus" );
        term:orderedSynonym           ( <urn:uuid:a3c69f99-3c1b-466e-b3ba-2ac7eb99984d> <urn:uuid:d4895be1-944d-47a2-a2f3-3f2ded35be95> <urn:uuid:6e96ab9c-2b81-4471-a912-5e5b1a39254b> ) .

