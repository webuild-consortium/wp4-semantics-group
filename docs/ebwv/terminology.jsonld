            },
            "http://purl.org/termed/properties/id": "ede07a51-68db-42a3-9713-ab618f5fbe66",
            "skos:broader": {
                "@id": "webuild:concept-7"
            },
            "skos:changeNote": "alternative definition:\n\"an identifier that is given to a legal entity at registration\"",
            "skos:definition": {
                "@language": "en",
                "@value": "an unambiguous structured identifier assigned to a legal entity by the competent authority that registered or recognised it"
            },
            "skos:inScheme": {
