        {
            "@id": "webuild:locatorname",
            "suomi-meta:publicationStatus": {
                "@id": "http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT"
            },
            "suomi-meta:modifier": "5dc030a4-740f-4dde-9548-4e6e797899d8",
            "skos:definition": {
                "@language": "en",
                "@value": "Proper noun(s) applied to the real world entity identified by the locator. The locator name could be the name of the property or complex, of the building or part of the building, or it could be the name of a room inside a building."
            },
            "dcterms:modified": {
                "@value": "2026-02-16T09:30:01.03Z",
                "@type": "xsd:dateTime"
            },
            "suomi-meta:creator": "5dc030a4-740f-4dde-9548-4e6e797899d8",
            "skos:note": {
                "@language": "en",
                "@value": "The locator name could be the name of the property or complex, of the building or part of the building, or it could be the name of a room inside a building.\n\nThe key difference between a locator designator and a locator name is that the latter is a proper name and is unlikely to include digits. For example, \"Shumann, Berlaymont\" is a meeting room within the European Commission headquarters for which locator name is more appropriate than locator."
            },
            "dcterms:created": {
                "@value": "2026-02-16T09:30:01.03Z",
                "@type": "xsd:dateTime"
            },
            "term:orderedNote": {
                "@list": [
                    {
                        "@language": "en",
                        "@value": "The locator name could be the name of the property or complex, of the building or part of the building, or it could be the name of a room inside a building.\n\nThe key difference between a locator designator and a locator name is that the latter is a proper name and is unlikely to include digits. For example, \"Shumann, Berlaymont\" is a meeting room within the European Commission headquarters for which locator name is more appropriate than locator."
                    }
                ]
            },
            "skos:inScheme": {
                "@id": "https://iri.suomi.fi/terminology/webuild/"
            },
            "skos:prefLabel": {
                "@id": "urn:uuid:4f64d4c4-0896-4276-a110-115f26e495ec"
            },
            "@type": "skos:Concept"
        },
