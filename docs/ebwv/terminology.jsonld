        {
            "@id": "webuild:thoroughfare",
            "term:orderedSynonym": {
                "@list": [
                    {
                        "@id": "urn:uuid:cdc31107-5f91-4442-beeb-af09460bfc36"
                    }
                ]
            },
            "term:orderedNote": {
                "@list": [
                    {
                        "@language": "en",
                        "@value": "A thoroughfare is usually a street, but it might be a waterway or some other feature. For example, \"Avenue des Champs-Élysées\".\n\nThe concept definition is based on the EU Core Location Vocabulary."
                    },
                    {
                        "@language": "en",
                        "@value": "The concept thoroughfare is just a part of \"streetAddress\" in Schema.org; example:\nstreetAddress: \"38 avenue de l'Opéra\"\nthoroughfare: \"avenue de l'Opéra\""
                    }
                ]
            },
            "suomi-meta:publicationStatus": {
                "@id": "http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT"
            },
            "suomi-meta:modifier": "5dc030a4-740f-4dde-9548-4e6e797899d8",
