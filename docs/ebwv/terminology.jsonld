            },
            "skos-xl:literalForm": {
                "@language": "en",
                "@value": "administrative unit level 1"
            },
            "@type": "skos-xl:Label"
        },
        {
            "@id": "urn:uuid:bbcad48c-8f22-47e2-a7d1-fda424b1120b",
            "suomi-meta:publicationStatus": {
                "@id": "http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT"
            },
            "skos-xl:literalForm": {
