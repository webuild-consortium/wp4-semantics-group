        {
            "@id": "urn:uuid:64cc969e-51ba-47a1-a677-eb9dcf80c4ab",
            "suomi-meta:publicationStatus": {
                "@id": "http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/SUGGESTED"
