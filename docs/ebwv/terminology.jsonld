            "term:orderedNote": {
                "@list": [
                    {
                        "@language": "en",
                        "@value": "A representation rule can express that a person in a certain position in a company (agent) can represent the company alone or jointly together with others or simply state that a specific person has been granted this right without being previously affiliated to the company (agent)."
                    }
                ]
            },
