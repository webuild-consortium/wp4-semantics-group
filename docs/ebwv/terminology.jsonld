        },
        {
            "@id": "webuild:concept-23",
            "suomi-meta:modifier": "4c00fd3e-ad5d-4ad6-8782-de29597a5d57",
            "skos:definition": {
                "@language": "en",
                "@value": "an indication of whether a registration authority has registered some extraordinary proceedings for the legal entity"
            },
            "dcterms:modified": {
                "@value": "2025-01-13T13:01:56.295Z",
                "@type": "xsd:dateTime"
            },
            "dcterms:created": "2022-02-03T09:22:28Z",
            "term:orderedSynonym": {
                "@list": [
                    {
                        "@id": "urn:uuid:ea0e33ac-3be7-4f31-966b-b010d25c5214"
                    }
                ]
            },
            "http://purl.org/termed/properties/id": "0da96952-6a0b-4bbb-b204-ad2f329e6d67",
            "skos:prefLabel": {
                "@id": "urn:uuid:1a25adae-bf9b-49ec-87fd-a8c62fe88c57"
            },
            "term:orderedRelated": {
                "@list": [
                    {
                        "@id": "webuild:concept-41"
                    }
                ]
            },
            "skos:inScheme": {
                "@id": "https://iri.suomi.fi/terminology/webuild/"
            },
            "skos:related": {
                "@id": "webuild:concept-41"
            },
            "suomi-meta:creator": "5dc030a4-740f-4dde-9548-4e6e797899d8",
            "term:orderedNote": {
                "@list": [
                    {
                        "@language": "en",
                        "@value": "Reason for a definition that is different from the EU Core Business Vocabulary:\nEU Core Business Vocabulary definition for \"Legal entity status\" = Information about the viability of the current position of the legal entity.\n1. The registration authority might not have the full picture about the viability of the current postion of the legal entity.\n1."
                    },
                    {
                        "@language": "en",
                        "@value": "The nationally registered legal status of the agent. In the context of this model, the national values for legal status are mapped to the codes: * NONE - no extraordinary circumstances registered. The registration authority does not have anything registered but note that this doesn&#039;t say anything about for example financial status of the agent at this point in time. * SOME - some extraordinary circumstances registered. The registration authority have registered information on for example thet bankruptcy proceedings have started. To know the exact nationally registered legal status you need to check that national register. * ENDED - The registration authority have registered information on for example bankruptcy. The legal entity is no longer able to do buiness."
                    }
                ]
            },
            "@type": "skos:Concept",
            "skos:note": [
                {
                    "@language": "en",
                    "@value": "The nationally registered legal status of the agent. In the context of this model, the national values for legal status are mapped to the codes: * NONE - no extraordinary circumstances registered. The registration authority does not have anything registered but note that this doesn&#039;t say anything about for example financial status of the agent at this point in time. * SOME - some extraordinary circumstances registered. The registration authority have registered information on for example thet bankruptcy proceedings have started. To know the exact nationally registered legal status you need to check that national register. * ENDED - The registration authority have registered information on for example bankruptcy. The legal entity is no longer able to do buiness."
                },
                {
                    "@language": "en",
                    "@value": "Reason for a definition that is different from the EU Core Business Vocabulary:\nEU Core Business Vocabulary definition for \"Legal entity status\" = Information about the viability of the current position of the legal entity.\n1. The registration authority might not have the full picture about the viability of the current postion of the legal entity.\n1."
                }
            ],
            "suomi-meta:publicationStatus": {
                "@id": "http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT"
            },
            "skos:altLabel": {
                "@id": "urn:uuid:ea0e33ac-3be7-4f31-966b-b010d25c5214"
            }
        },
