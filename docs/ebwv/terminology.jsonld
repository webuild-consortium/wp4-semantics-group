            "skos:definition": {
                "@language": "en",
                "@value": "a digital solution that allows European Business Wallet owners to securely store, manage and present owner identification data and electronic attestations of attributes to relying parties and other entities, including through European Digital Identity Wallets, for purposes such as authentication, use of electronic signatures and seals, and management and delegation of mandates, in accordance with the regulation"
            },
            "@type": "skos:Concept"
        },
        {
            "@id": "webuild:concept-94",
            "skos:inScheme": {
                "@id": "https://iri.suomi.fi/terminology/webuild/"
            },
            "skos:broader": {
                "@id": "webuild:concept-41"
            },
            "dcterms:created": {
                "@value": "2025-12-04T12:47:24.424Z",
                "@type": "xsd:dateTime"
            },
            "skos:related": [
                {
                    "@id": "webuild:concept-109"
                },
                {
                    "@id": "webuild:concept-6005"
                },
                {
                    "@id": "webuild:concept-6006"
                }
            ],
            "term:orderedNote": {
                "@list": [
                    {
                        "@language": "en",
                        "@value": "“Economic operator” is a capacity/role. \n\nThe same underlying entity may or may not be an economic operator depending on context. \n\nEconomic operators frequently correspond to \"legal entities\" for regulated processes, but the precise coverage depends on the applicable legal instrument."
                    },
                    {
                        "@language": "en",
                        "@value": "Natural persons can be economic operators; whether they are treated as “legal entities” depends on whether they have a legally recognised registered business identity in the relevant legal context."
                    },
                    {
                        "@language": "en",
                        "@value": "NB: the exact scope of the \"economic operator\" concept depends on the legal instrument (procurement vs market surveillance vs sector laws)."
                    }
                ]
            },
            "suomi-meta:modifier": "5dc030a4-740f-4dde-9548-4e6e797899d8",
            "dcterms:source": "COM(2025) 838 - Proposal for a Regulation on the establishment of European Business Wallets",
            "term:orderedSource": {
                "@list": [
                    "COM(2025) 838 - Proposal for a Regulation on the establishment of European Business Wallets"
                ]
            },
            "skos:prefLabel": [
                {
                    "@id": "urn:uuid:a53404ff-d71b-40bc-999e-01588fddb37f"
                },
                {
                    "@id": "urn:uuid:b369f9d8-b167-44bd-a5a5-8c72b4b3363b"
                },
                {
                    "@id": "urn:uuid:0fd08ec7-8001-446d-a3a3-aab584f573bf"
                }
            ],
            "skos:definition": {
                "@language": "en",
                "@value": "an agent acting in a commercial or professional capacity for purposes related to its trade, business, craft, or profession"
            },
            "skos:note": [
                {
                    "@language": "en",
                    "@value": "NB: the exact scope of the \"economic operator\" concept depends on the legal instrument (procurement vs market surveillance vs sector laws)."
                },
                {
                    "@language": "en",
                    "@value": "Natural persons can be economic operators; whether they are treated as “legal entities” depends on whether they have a legally recognised registered business identity in the relevant legal context."
                },
                {
                    "@language": "en",
                    "@value": "“Economic operator” is a capacity/role. \n\nThe same underlying entity may or may not be an economic operator depending on context. \n\nEconomic operators frequently correspond to \"legal entities\" for regulated processes, but the precise coverage depends on the applicable legal instrument."
                }
            ],
            "suomi-meta:publicationStatus": {
                "@id": "http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT"
            },
            "term:orderedRelated": {
                "@list": [
                    {
                        "@id": "webuild:concept-6006"
                    },
                    {
                        "@id": "webuild:concept-109"
                    },
                    {
                        "@id": "webuild:concept-6005"
                    }
                ]
            },
            "skos:changeNote": "alternative definitions:\n\"a natural person, legal person or group of such persons, including temporary associations of undertakings, when acting in a commercial or professional capacity for purposes related to their trade, business, craft or profession\"\n\"any natural or legal person or public entity or group of such persons and/or entities, including any temporary association of undertakings, which offers the execution of works and/or a work, the supply of products or the provision of services on the market\"",
            "@type": "skos:Concept",
            "term:orderedBroader": {
                "@list": [
                    {
                        "@id": "webuild:concept-41"
                    }
                ]
            },
            "suomi-meta:creator": "5dc030a4-740f-4dde-9548-4e6e797899d8",
            "dcterms:modified": {
                "@value": "2026-03-03T06:05:42.321Z",
                "@type": "xsd:dateTime"
            }
        },
        {
