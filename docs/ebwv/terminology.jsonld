            },
            "skos-xl:literalForm": {
                "@language": "en",
                "@value": "citizenship"
            },
            "@type": "skos-xl:Label"
        },
        {
            "@id": "webuild:concept-18",
            "term:orderedNote": {
                "@list": [
                    {
                        "@language": "en",
                        "@value": "EU Core Business Vocabulary definition for \"legal name\" = The name under which the Legal Entity is legally registered."
                    }
                ]
            },
            "@type": "skos:Concept",
            "dcterms:created": "2022-02-02T10:51:49Z",
