                "@value": "mandator"
            },
            "@type": "skos-xl:Label"
        },
        {
            "@id": "webuild:concept-3002",
            "suomi-meta:creator": "5dc030a4-740f-4dde-9548-4e6e797899d8",
            "dcterms:modified": {
                "@value": "2025-01-13T14:57:09.285Z",
                "@type": "xsd:dateTime"
            },
            "http://purl.org/termed/properties/id": "1b4df410-9b43-4eb0-8380-803ba4d9f411",
            "@type": "skos:Concept",
            "suomi-meta:publicationStatus": {
                "@id": "http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT"
            },
            "skos:note": {
                "@language": "en",
                "@value": "The question whether a natural person actually &quot;owns&quot; or &quot;controls&quot; the agent is decided separately in each national jurisdiction. It is also dependent on the legal form of the agent. <br />Based on Directive (EU) 2015/849 Artcicle 3, section 6"
            },
            "skos:inScheme": {
                "@id": "https://iri.suomi.fi/terminology/webuild/"
            },
            "skos:broader": {
                "@id": "webuild:concept-6005"
            },
            "skos:prefLabel": {
                "@id": "urn:uuid:21c855a5-fc02-43d9-b3f2-4c913109e99f"
            },
            "term:orderedBroader": {
                "@list": [
                    {
                        "@id": "webuild:concept-6005"
                    }
                ]
            },
            "skos:definition": {
                "@language": "en",
                "@value": "a person or persons who ultimately owns or controls an agent"
            },
            "term:orderedNote": {
                "@list": [
                    {
                        "@language": "en",
                        "@value": "The question whether a natural person actually &quot;owns&quot; or &quot;controls&quot; the agent is decided separately in each national jurisdiction. It is also dependent on the legal form of the agent. <br />Based on Directive (EU) 2015/849 Artcicle 3, section 6"
                    }
                ]
            },
            "skos:related": {
                "@id": "webuild:concept-41"
            },
