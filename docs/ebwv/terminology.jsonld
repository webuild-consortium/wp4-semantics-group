                "@language": "en",
                "@value": "patronymic name"
            },
            "@type": "skos-xl:Label"
        },
        {
            "@id": "webuild:matronymicname",
            "term:orderedRelated": {
                "@list": [
                    {
                        "@id": "webuild:givenname"
                    }
                ]
            },
            "term:orderedNote": {
                "@list": [
                    {
                        "@language": "en",
                        "@value": "In the EBWV context, matronymic name should be used only for a person-name component that is formed from the mother’s given name, according to the naming rules or practices of a relevant jurisdiction or culture. It should not be confused with a family name inherited through the mother’s family line, a mother’s maiden name, or a general maternal surname. It is the maternal counterpart of a patronymic name."
                    }
                ]
            },
            "term:orderedExample": {
                "@list": [
                    {
                        "@language": "en",
                        "@value": "A person record includes a matronymic name formed from the given name of the person’s mother, where this is part of the person’s officially recognised name structure."
                    }
                ]
            },
            "suomi-meta:publicationStatus": {
                "@id": "http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT"
            },
            "suomi-meta:modifier": "5dc030a4-740f-4dde-9548-4e6e797899d8",
            "suomi-meta:creator": "5dc030a4-740f-4dde-9548-4e6e797899d8",
            "skos:related": {
                "@id": "webuild:givenname"
            },
            "skos:prefLabel": {
                "@id": "urn:uuid:e254905d-b7aa-47d3-85c8-1545b363c478"
            },
            "skos:note": {
                "@language": "en",
                "@value": "In the EBWV context, matronymic name should be used only for a person-name component that is formed from the mother’s given name, according to the naming rules or practices of a relevant jurisdiction or culture. It should not be confused with a family name inherited through the mother’s family line, a mother’s maiden name, or a general maternal surname. It is the maternal counterpart of a patronymic name."
            },
            "skos:inScheme": {
                "@id": "https://iri.suomi.fi/terminology/webuild/"
            },
            "skos:example": {
                "@language": "en",
                "@value": "A person record includes a matronymic name formed from the given name of the person’s mother, where this is part of the person’s officially recognised name structure."
            },
            "skos:definition": {
                "@language": "en",
                "@value": "a name component derived from the given name of a person’s mother"
            },
            "dcterms:modified": {
                "@value": "2026-04-28T14:28:48.086Z",
                "@type": "xsd:dateTime"
            },
            "dcterms:created": {
                "@value": "2026-04-28T14:28:12.076Z",
                "@type": "xsd:dateTime"
            },
            "@type": "skos:Concept"
        },
        {
            "@id": "webuild:name",
            "term:orderedNote": {
                "@list": [
                    {
                        "@language": "en",
                        "@value": "In the EBWV context, name is a generic concept that may apply to a person, legal entity, organisation, product, place, service, document, credential or other identifiable thing. Where more precise concepts are available, they should be used instead, such as given name, family name, legal name, trade name, business name, registered name or preferred name. A name may be official, registered, commonly used, localised, multilingual, historical or context-specific."
                    }
                ]
            },
            "term:orderedNarrower": {
                "@list": [
                    {
                        "@id": "webuild:familyname"
                    },
                    {
                        "@id": "webuild:givenname"
