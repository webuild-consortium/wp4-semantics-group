            },
            "skos:note": {
                "@language": "en",
                "@value": "Post codes are common elements in many countries' postal address systems. One of the many post codes of Paris is for example \"75000\"."
            },
            "skos:inScheme": {
                "@id": "https://iri.suomi.fi/terminology/webuild/"
            },
            "skos:definition": {
                "@language": "en",
                "@value": "The code created and maintained for postal purposes to identify a subdivision of addresses and postal delivery points."
            },
