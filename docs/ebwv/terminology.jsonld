            },
            "dcterms:created": {
                "@value": "2026-02-16T08:42:54.145Z",
                "@type": "xsd:dateTime"
            },
            "@type": "skos:Concept"
        },
        {
            "@id": "webuild:givenname",
            "term:orderedSynonym": {
                "@list": [
                    {
                        "@id": "urn:uuid:78aaf59c-4a5b-4302-a32b-ba0948e31510"
                    },
                    {
                        "@id": "urn:uuid:da32a214-9b9c-4853-9adb-0a33ddeb3d21"
                    }
                ]
            },
            "@type": "skos:Concept",
            "dcterms:created": {
                "@value": "2026-02-03T14:23:56.234Z",
                "@type": "xsd:dateTime"
            },
            "dcterms:modified": {
                "@value": "2026-02-03T15:06:31.249Z",
                "@type": "xsd:dateTime"
            },
            "dcterms:source": "https://semiceu.github.io/Core-Person-Vocabulary/releases/2.1.1/#Person.givenname",
            "skos:altLabel": [
                {
                    "@id": "urn:uuid:da32a214-9b9c-4853-9adb-0a33ddeb3d21"
                },
                {
                    "@id": "urn:uuid:78aaf59c-4a5b-4302-a32b-ba0948e31510"
                }
            ],
            "skos:definition": {
                "@language": "en",
                "@value": "the name(s) that identify the person within a family with a common surname"
            },
            "skos:inScheme": {
                "@id": "https://iri.suomi.fi/terminology/webuild/"
            },
            "skos:note": {
                "@language": "en",
                "@value": "Usually a first name or forename. Given to a person by his or her parents at birth or legally recognised as 'given names' through a formal process. All given names are ordered in one property so that, for example, the given name for Johann Sebastian Bach is \"Johann Sebastian\"."
            },
            "skos:prefLabel": [
                {
                    "@id": "urn:uuid:c32d2a33-4acb-4bb7-bbc5-012479881295"
                },
                {
                    "@id": "urn:uuid:eae0090d-7b39-40cd-8062-190774fb3913"
                }
            ],
            "suomi-meta:creator": "5dc030a4-740f-4dde-9548-4e6e797899d8",
            "suomi-meta:modifier": "35c48e07-ad49-45c8-82a4-da1763c4fe4a",
            "suomi-meta:publicationStatus": {
                "@id": "http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT"
            },
            "term:orderedNote": {
                "@list": [
                    {
                        "@language": "en",
                        "@value": "Usually a first name or forename. Given to a person by his or her parents at birth or legally recognised as 'given names' through a formal process. All given names are ordered in one property so that, for example, the given name for Johann Sebastian Bach is \"Johann Sebastian\"."
                    }
                ]
            },
            "term:orderedSource": {
                "@list": [
                    "https://semiceu.github.io/Core-Person-Vocabulary/releases/2.1.1/#Person.givenname"
                ]
            }
        },
        {
            "@id": "webuild:familyname",
            "term:orderedSynonym": {
                "@list": [
                    {
                        "@id": "urn:uuid:02f56ac6-6624-4f76-8172-1717b56c6f8f"
                    },
                    {
                        "@id": "urn:uuid:95984217-b926-4ddc-a164-e3be2881f2e0"
                    }
                ]
            },
            "term:orderedSource": {
                "@list": [
                    "https://semiceu.github.io/Core-Person-Vocabulary/releases/2.1.1/#Person.familyname"
                ]
            },
            "term:orderedNote": {
                "@list": [
                    {
                        "@language": "en",
                        "@value": "Usually referring to a group of people related by blood, marriage or adoption. This attribute also carries prefixes or suffixes which are part of the family name, e.g. \"de Boer\", \"van de Putte\", \"von und zu Orlow\". Multiple family names, such as are commonly found in Hispanic countries, are recorded in the single family name property so that, for example, Miguel de Cervantes Saavedra's family name would be recorded as \"de Cervantes Saavedra\"."
                    }
                ]
            },
            "suomi-meta:publicationStatus": {
                "@id": "http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT"
            },
            "suomi-meta:modifier": "5dc030a4-740f-4dde-9548-4e6e797899d8",
            "suomi-meta:creator": "5dc030a4-740f-4dde-9548-4e6e797899d8",
            "skos:prefLabel": {
                "@id": "urn:uuid:77bc98b9-3486-460a-a7ea-0f423f334180"
            },
            "skos:note": {
                "@language": "en",
                "@value": "Usually referring to a group of people related by blood, marriage or adoption. This attribute also carries prefixes or suffixes which are part of the family name, e.g. \"de Boer\", \"van de Putte\", \"von und zu Orlow\". Multiple family names, such as are commonly found in Hispanic countries, are recorded in the single family name property so that, for example, Miguel de Cervantes Saavedra's family name would be recorded as \"de Cervantes Saavedra\"."
            },
            "skos:inScheme": {
                "@id": "https://iri.suomi.fi/terminology/webuild/"
            },
            "skos:definition": {
                "@language": "en",
                "@value": "the hereditary surname of a family"
            },
            "skos:altLabel": [
                {
                    "@id": "urn:uuid:02f56ac6-6624-4f76-8172-1717b56c6f8f"
                },
                {
                    "@id": "urn:uuid:95984217-b926-4ddc-a164-e3be2881f2e0"
                }
            ],
            "dcterms:source": "https://semiceu.github.io/Core-Person-Vocabulary/releases/2.1.1/#Person.familyname",
            "dcterms:modified": {
                "@value": "2026-02-03T14:39:47.315Z",
                "@type": "xsd:dateTime"
            },
            "dcterms:created": {
                "@value": "2026-02-03T14:35:30.647Z",
                "@type": "xsd:dateTime"
            },
            "@type": "skos:Concept"
        },
