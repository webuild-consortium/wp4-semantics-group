        },
        {
            "@id": "webuild:adminUnitL2",
            "suomi-meta:publicationStatus": {
                "@id": "http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT"
            },
            "suomi-meta:modifier": "5dc030a4-740f-4dde-9548-4e6e797899d8",
            "suomi-meta:creator": "5dc030a4-740f-4dde-9548-4e6e797899d8",
            "skos:prefLabel": {
                "@id": "urn:uuid:bbcad48c-8f22-47e2-a7d1-fda424b1120b"
            },
            "skos:inScheme": {
                "@id": "https://iri.suomi.fi/terminology/webuild/"
            },
            "skos:definition": {
                "@language": "en",
                "@value": "The name of a secondary level/region of the address, usually a county, state or other such area that typically encompasses several localities."
            },
            "dcterms:modified": {
                "@value": "2026-02-16T09:43:22.551Z",
                "@type": "xsd:dateTime"
            },
            "dcterms:created": {
                "@value": "2026-02-16T09:41:59.829Z",
                "@type": "xsd:dateTime"
            },
            "@type": "skos:Concept"
        },
        {
            "@id": "urn:uuid:51431892-cf81-4682-877e-11b4210237f1",
            "suomi-meta:publicationStatus": {
                "@id": "http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT"
            },
            "skos-xl:literalForm": {
                "@language": "en",
                "@value": "full address"
            },
            "@type": "skos-xl:Label"
        },
        {
            "@id": "urn:uuid:cd69f4e6-4db1-4042-a611-59e438c87de8",
            "suomi-meta:publicationStatus": {
                "@id": "http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT"
            },
            "skos-xl:literalForm": {
                "@language": "en",
                "@value": "locator designator"
            },
            "@type": "skos-xl:Label"
        },
        {
            "@id": "webuild:locationdesignator",
            "term:orderedNote": {
                "@list": [
                    {
                        "@language": "en",
                        "@value": "In simpler terms, this is the building number, apartment number, etc. For an address such as \"Flat 3, 17 Bridge Street\", the locator is \"flat 3, 17\". A German example: \"Hauptstrasse 6 A\", the locator is \"6 A\"."
                    }
                ]
            },
            "suomi-meta:publicationStatus": {
                "@id": "http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT"
            },
            "suomi-meta:modifier": "5dc030a4-740f-4dde-9548-4e6e797899d8",
            "suomi-meta:creator": "5dc030a4-740f-4dde-9548-4e6e797899d8",
            "skos:prefLabel": {
                "@id": "urn:uuid:cd69f4e6-4db1-4042-a611-59e438c87de8"
            },
            "skos:note": {
                "@language": "en",
                "@value": "In simpler terms, this is the building number, apartment number, etc. For an address such as \"Flat 3, 17 Bridge Street\", the locator is \"flat 3, 17\". A German example: \"Hauptstrasse 6 A\", the locator is \"6 A\"."
            },
            "skos:inScheme": {
                "@id": "https://iri.suomi.fi/terminology/webuild/"
            },
            "skos:definition": {
                "@language": "en",
                "@value": "A number or sequence of characters that uniquely identifies the locator within the relevant scope."
            },
            "dcterms:modified": {
                "@value": "2026-02-16T09:36:36.703Z",
                "@type": "xsd:dateTime"
            },
            "dcterms:created": {
                "@value": "2026-02-16T09:36:36.703Z",
                "@type": "xsd:dateTime"
            },
            "@type": "skos:Concept"
        },
        {
            "@id": "urn:uuid:4f64d4c4-0896-4276-a110-115f26e495ec",
            "suomi-meta:publicationStatus": {
                "@id": "http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT"
            },
            "skos-xl:literalForm": {
                "@language": "en",
                "@value": "locator name"
            },
            "@type": "skos-xl:Label"
        },
        {
            "@id": "webuild:pobox",
            "term:orderedNote": {
                "@list": [
                    {
                        "@language": "en",
                        "@value": "INSPIRE's name for this is \"postalDeliveryIdentifier\" for which it uses the locator designator property with a type attribute of that name. This vocabulary separates out the Post Office Box for greater independence of technology. An example post office box number is \"9383\"."
                    }
                ]
            },
            "suomi-meta:publicationStatus": {
                "@id": "http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT"
            },
            "suomi-meta:modifier": "5dc030a4-740f-4dde-9548-4e6e797899d8",
            "suomi-meta:creator": "5dc030a4-740f-4dde-9548-4e6e797899d8",
            "skos:prefLabel": {
                "@id": "urn:uuid:12a94e94-4ee3-4759-bfb8-6d1f7bc3c89a"
            },
            "skos:note": {
                "@language": "en",
                "@value": "INSPIRE's name for this is \"postalDeliveryIdentifier\" for which it uses the locator designator property with a type attribute of that name. This vocabulary separates out the Post Office Box for greater independence of technology. An example post office box number is \"9383\"."
            },
            "skos:inScheme": {
                "@id": "https://iri.suomi.fi/terminology/webuild/"
            },
            "skos:definition": {
                "@language": "en",
                "@value": "A location designator for a postal delivery point at a post office, usually a number."
            },
            "dcterms:modified": {
                "@value": "2026-02-16T09:25:06.808Z",
                "@type": "xsd:dateTime"
            },
            "dcterms:created": {
                "@value": "2026-02-16T09:25:06.808Z",
                "@type": "xsd:dateTime"
            },
            "@type": "skos:Concept"
        },
        {
            "@id": "urn:uuid:12a94e94-4ee3-4759-bfb8-6d1f7bc3c89a",
            "suomi-meta:publicationStatus": {
                "@id": "http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT"
            },
            "skos-xl:literalForm": {
                "@language": "en",
                "@value": "postal office box"
            },
            "@type": "skos-xl:Label"
        },
        {
            "@id": "urn:uuid:cea10550-075a-4a78-825b-dc1e10ce4088",
            "suomi-meta:publicationStatus": {
                "@id": "http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT"
            },
