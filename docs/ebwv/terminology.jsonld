            "skos:definition": {
                "@language": "en",
                "@value": "a set of data that enables the establishment of the identity of a European Business Wallet owner and that is issued by a provider of European Business Wallet owner identification data"
            },
            "suomi-meta:creator": "5dc030a4-740f-4dde-9548-4e6e797899d8",
            "suomi-meta:publicationStatus": {
                "@id": "http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT"
            },
            "term:orderedBroader": {
                "@list": [
                    {
                        "@id": "webuild:concept-93"
                    }
                ]
            },
            "term:orderedNote": {
                "@list": [
                    {
                        "@language": "en",
                        "@value": "At minimum, the \"EBWOID\" includes legal name + one or more legal identifiers (e.g., EUID or national identifier), and may include additional matching attributes under policy."
                    }
                ]
            },
            "dcterms:created": {
                "@value": "2025-12-04T13:05:46.444Z",
                "@type": "xsd:dateTime"
            },
            "suomi-meta:modifier": "5dc030a4-740f-4dde-9548-4e6e797899d8"
        },
