            },
            "dcterms:source": "https://schema.org/postalCode",
            "@type": "skos-xl:Label"
        },
        {
            "@id": "webuild:citizenship",
            "skos:inScheme": {
                "@id": "https://iri.suomi.fi/terminology/webuild/"
            },
            "term:notRecommendedSynonym": {
                "@id": "urn:uuid:604c0d24-4524-4905-8d8a-6e01e8925b4b"
            },
            "suomi-meta:publicationStatus": {
                "@id": "http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT"
            },
            "skos:prefLabel": {
                "@id": "urn:uuid:03ddfe13-d938-4add-a4e2-8febb7dd2f5c"
            },
            "skos:note": {
                "@language": "en",
                "@value": "Citizenship expresses the formal legal relationship between a person and a sovereign state.\nA person may hold one or multiple citizenships, depending on applicable national laws.\nCitizenship is distinct from residence, domicile, ethnicity, or nationality as used in cultural contexts."
            },
            "suomi-meta:creator": "5dc030a4-740f-4dde-9548-4e6e797899d8",
            "@type": "skos:Concept",
            "term:orderedNotRecommendedSynonym": {
                "@list": [
                    {
                        "@id": "urn:uuid:604c0d24-4524-4905-8d8a-6e01e8925b4b"
                    }
                ]
            },
            "skos:definition": {
                "@language": "en",
                "@value": "the legal bond between a natural person and a state, recognised under national law, which establishes membership in that state and entails associated rights and obligations"
            },
            "term:orderedNote": {
                "@list": [
                    {
                        "@language": "en",
                        "@value": "Citizenship expresses the formal legal relationship between a person and a sovereign state.\nA person may hold one or multiple citizenships, depending on applicable national laws.\nCitizenship is distinct from residence, domicile, ethnicity, or nationality as used in cultural contexts."
                    }
                ]
            },
            "dcterms:created": {
                "@value": "2026-02-16T14:33:41.961Z",
                "@type": "xsd:dateTime"
            },
            "suomi-meta:modifier": "5dc030a4-740f-4dde-9548-4e6e797899d8",
            "dcterms:modified": {
                "@value": "2026-02-16T14:33:41.961Z",
                "@type": "xsd:dateTime"
            }
        },
