            "@type": "skos-xl:Label"
        },
        {
            "@id": "webuild:partner",
            "term:orderedSynonym": {
                "@list": [
                    {
                        "@id": "urn:uuid:76bd10e9-95ee-43e9-a5ea-16209eeebad7"
                    },
                    {
                        "@id": "urn:uuid:58012364-8330-413b-953c-1f34852d19c7"
                    }
                ]
            },
            "@type": "skos:Concept",
            "dcterms:created": {
                "@value": "2026-04-28T14:36:56.799Z",
                "@type": "xsd:dateTime"
            },
            "dcterms:modified": {
                "@value": "2026-04-28T14:36:56.799Z",
                "@type": "xsd:dateTime"
            },
            "skos:altLabel": [
                {
                    "@id": "urn:uuid:58012364-8330-413b-953c-1f34852d19c7"
                },
                {
                    "@id": "urn:uuid:76bd10e9-95ee-43e9-a5ea-16209eeebad7"
                }
            ],
            "skos:definition": {
                "@language": "en",
                "@value": "a person or legal [entity] that is a member of a partnership or comparable company-law entity and whose status as partner is recorded or recognised by the competent business register or company register"
            },
            "skos:example": {
                "@language": "en",
                "@value": "An EU Company Certificate for a limited partnership identifies a natural person as a limited partner and a legal entity as a general partner."
            },
            "skos:inScheme": {
                "@id": "https://iri.suomi.fi/terminology/webuild/"
            },
            "skos:note": [
                {
                    "@language": "en",
                    "@value": "Use partner only where the source register or legal form identifies the entity as a partner in a partnership-type entity. For companies limited by shares, the more appropriate concept is usually shareholder, member, beneficial owner, or legal representative, depending on the intended meaning."
                },
                {
                    "@language": "en",
                    "@value": "In the EBWV context, and especially in the EU Company Certificate context, partner should be understood as a company-law role in a partnership or similar registered entity. It refers to an entity that participates in the legal structure of the company as a partner, not to a commercial counterparty, cooperation partner, customer, supplier, spouse, or informal business collaborator.\n\nThe term is relevant because the EU Company Certificate introduced by Article 16b of Directive (EU) 2017/1132, as amended by Directive (EU) 2025/25, is intended to provide standardised company-register evidence across Member States, including core company information and, for relevant entity types, information about persons or entities connected to the company’s legal structure. Directive (EU) 2025/25 also extends digital company-law disclosure to certain partnerships listed in the new Annex IIB."
                }
            ],
            "skos:prefLabel": {
                "@id": "urn:uuid:cd11d154-3c55-4ec0-924e-02730c239d2f"
            },
            "suomi-meta:creator": "5dc030a4-740f-4dde-9548-4e6e797899d8",
            "suomi-meta:modifier": "5dc030a4-740f-4dde-9548-4e6e797899d8",
            "suomi-meta:publicationStatus": {
                "@id": "http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT"
            },
            "term:orderedExample": {
                "@list": [
                    {
                        "@language": "en",
                        "@value": "An EU Company Certificate for a limited partnership identifies a natural person as a limited partner and a legal entity as a general partner."
                    }
                ]
            },
            "term:orderedNote": {
                "@list": [
                    {
                        "@language": "en",
                        "@value": "In the EBWV context, and especially in the EU Company Certificate context, partner should be understood as a company-law role in a partnership or similar registered entity. It refers to an entity that participates in the legal structure of the company as a partner, not to a commercial counterparty, cooperation partner, customer, supplier, spouse, or informal business collaborator.\n\nThe term is relevant because the EU Company Certificate introduced by Article 16b of Directive (EU) 2017/1132, as amended by Directive (EU) 2025/25, is intended to provide standardised company-register evidence across Member States, including core company information and, for relevant entity types, information about persons or entities connected to the company’s legal structure. Directive (EU) 2025/25 also extends digital company-law disclosure to certain partnerships listed in the new Annex IIB."
                    },
                    {
                        "@language": "en",
                        "@value": "Use partner only where the source register or legal form identifies the entity as a partner in a partnership-type entity. For companies limited by shares, the more appropriate concept is usually shareholder, member, beneficial owner, or legal representative, depending on the intended meaning."
                    }
                ]
            }
        },
        {
