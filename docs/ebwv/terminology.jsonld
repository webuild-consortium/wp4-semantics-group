        },
        {
            "@id": "webuild:mandate",
            "suomi-meta:publicationStatus": {
                "@id": "http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT"
            },
            "suomi-meta:modifier": "5dc030a4-740f-4dde-9548-4e6e797899d8",
            "suomi-meta:creator": "5dc030a4-740f-4dde-9548-4e6e797899d8",
            "skos:prefLabel": {
                "@id": "urn:uuid:fb45c8e1-c3f2-4dbd-a7c8-2920df2b2cb6"
            },
            "skos:inScheme": {
                "@id": "https://iri.suomi.fi/terminology/webuild/"
            },
            "skos:definition": {
                "@language": "en",
                "@value": "a legally effective authorization by which a natural person or legal person (the mandator) empowers another agent (the mandatee) to act on the mandator’s behalf for one or more specified legal, administrative, or business matters, with a defined scope, constraints, and validity, and which can be presented and verified in the EU Business Wallet as evidence of representation towards relying parties"
            },
            "dcterms:modified": {
                "@value": "2026-02-04T11:18:03.431Z",
                "@type": "xsd:dateTime"
            },
            "dcterms:created": {
                "@value": "2026-02-04T11:18:03.431Z",
                "@type": "xsd:dateTime"
            },
            "@type": "skos:Concept"
        },
        {
            "@id": "webuild:alternativename",
            "suomi-meta:creator": "5dc030a4-740f-4dde-9548-4e6e797899d8",
            "skos:inScheme": {
                "@id": "https://iri.suomi.fi/terminology/webuild/"
            },
            "term:orderedNote": {
                "@list": [
                    {
                        "@language": "en",
                        "@value": "An alternative name may include, for example, a trade name, previous name, alias, pseudonym, commonly used name, or name expressed in another language or script.\nIt does not replace the primary or legal name but exists in parallel as an additional identifier used in specific contexts."
                    }
                ]
            },
            "suomi-meta:publicationStatus": {
                "@id": "http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT"
            },
            "suomi-meta:modifier": "5dc030a4-740f-4dde-9548-4e6e797899d8",
            "skos:example": {
                "@language": "en",
                "@value": "A company’s registered legal name: Nordic Timber Export Oy\nAlternative name: NordTimber (trade name)\n\nA person’s legal name: Aleksandra Nowak\nAlternative name: Aleksandra Kowalska (former name)"
            },
            "dcterms:created": {
                "@value": "2026-02-16T14:28:16.846Z",
                "@type": "xsd:dateTime"
            },
            "term:orderedExample": {
                "@list": [
                    {
                        "@language": "en",
                        "@value": "A company’s registered legal name: Nordic Timber Export Oy\nAlternative name: NordTimber (trade name)\n\nA person’s legal name: Aleksandra Nowak\nAlternative name: Aleksandra Kowalska (former name)"
                    }
                ]
            },
            "skos:definition": {
                "@language": "en",
                "@value": "a name by which a person, organisation, or other identified entity is known in addition to its primary or legally registered name"
            },
            "@type": "skos:Concept",
            "skos:prefLabel": {
                "@id": "urn:uuid:6c16487d-78cb-4803-92c4-93b8d35ed9c6"
            },
            "term:orderedBroader": {
                "@list": [
                    {
                        "@id": "webuild:concept-18"
                    }
                ]
            },
            "skos:broader": {
                "@id": "webuild:concept-18"
            },
            "dcterms:modified": {
                "@value": "2026-02-16T14:28:16.846Z",
                "@type": "xsd:dateTime"
            },
            "skos:note": {
                "@language": "en",
                "@value": "An alternative name may include, for example, a trade name, previous name, alias, pseudonym, commonly used name, or name expressed in another language or script.\nIt does not replace the primary or legal name but exists in parallel as an additional identifier used in specific contexts."
            }
        },
        {
            "@id": "webuild:postcode",
            "dcterms:modified": {
                "@value": "2026-02-16T09:20:13.753Z",
                "@type": "xsd:dateTime"
            },
            "suomi-meta:creator": "5dc030a4-740f-4dde-9548-4e6e797899d8",
            "skos:inScheme": {
                "@id": "https://iri.suomi.fi/terminology/webuild/"
            },
            "dcterms:created": {
