            "http://purl.org/termed/properties/id": "5ca689cc-9e85-4c74-99d0-d276a4040ad8",
            "skos:definition": {
                "@language": "en",
                "@value": "a word or a combination of characters by which an agent is designated, called, or known"
            },
            "skos:inScheme": {
