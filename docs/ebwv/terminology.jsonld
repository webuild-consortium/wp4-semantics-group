            },
            "@type": "skos:Concept"
        },
        {
            "@id": "webuild:residency",
            "term:orderedSynonym": {
                "@list": [
                    {
                        "@id": "urn:uuid:94049a93-dad2-4171-ab1a-af40f3db90a8"
                    },
                    {
                        "@id": "urn:uuid:82673e05-b0ef-4ebb-806e-6176b899c171"
                    },
                    {
                        "@id": "urn:uuid:36edeff8-d162-4a0a-8041-507eadff3446"
                    },
                    {
                        "@id": "urn:uuid:049ffcfe-48d1-43be-930a-3af889bbb412"
                    },
                    {
                        "@id": "urn:uuid:8d5ed253-0eee-4e45-a7b5-699433c26e74"
                    }
                ]
            },
            "term:orderedRelated": {
                "@list": [
                    {
                        "@id": "webuild:jurisdiction"
                    }
                ]
            },
            "term:orderedNote": {
                "@list": [
                    {
                        "@language": "en",
                        "@value": "In the EBWV context, residency should be used for a person’s legally or administratively relevant jurisdiction of residence. It should not be modelled as a postal address or physical address field. It should be distinguished from domicile, which the EU Core Person Vocabulary defines as the place the person treats as their permanent home and models with range Address; residency, by contrast, is linked to a Jurisdiction."
                    }
                ]
            },
            "term:orderedExample": {
                "@list": [
                    {
                        "@language": "en",
                        "@value": "A person identity attestation states that the person’s residency is Finland, represented as a jurisdiction rather than as a street address."
                    }
                ]
            },
            "suomi-meta:publicationStatus": {
                "@id": "http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT"
            },
            "@type": "skos:Concept",
            "dcterms:created": {
                "@value": "2026-04-28T14:51:03.792Z",
                "@type": "xsd:dateTime"
            },
            "dcterms:modified": {
                "@value": "2026-04-28T14:52:50.651Z",
                "@type": "xsd:dateTime"
            },
            "skos:altLabel": [
                {
                    "@id": "urn:uuid:8d5ed253-0eee-4e45-a7b5-699433c26e74"
                },
                {
                    "@id": "urn:uuid:94049a93-dad2-4171-ab1a-af40f3db90a8"
                },
                {
                    "@id": "urn:uuid:82673e05-b0ef-4ebb-806e-6176b899c171"
                },
                {
                    "@id": "urn:uuid:36edeff8-d162-4a0a-8041-507eadff3446"
                },
                {
                    "@id": "urn:uuid:049ffcfe-48d1-43be-930a-3af889bbb412"
                }
            ],
            "skos:definition": {
                "@language": "en",
                "@value": "a jurisdiction in which a person has their dwelling or is officially regarded as living or residing"
            },
            "skos:example": {
                "@language": "en",
                "@value": "A person identity attestation states that the person’s residency is Finland, represented as a jurisdiction rather than as a street address."
            },
            "skos:inScheme": {
                "@id": "https://iri.suomi.fi/terminology/webuild/"
            },
            "skos:note": {
                "@language": "en",
                "@value": "In the EBWV context, residency should be used for a person’s legally or administratively relevant jurisdiction of residence. It should not be modelled as a postal address or physical address field. It should be distinguished from domicile, which the EU Core Person Vocabulary defines as the place the person treats as their permanent home and models with range Address; residency, by contrast, is linked to a Jurisdiction."
            },
            "skos:prefLabel": {
                "@id": "urn:uuid:7c8172e4-c222-473b-b4c4-1318dd6386e8"
            },
            "skos:related": {
                "@id": "webuild:jurisdiction"
            },
            "suomi-meta:creator": "5dc030a4-740f-4dde-9548-4e6e797899d8",
            "suomi-meta:modifier": "5dc030a4-740f-4dde-9548-4e6e797899d8"
        },
        {
            "@id": "urn:uuid:f2bdb766-80ff-4054-9b87-62473b764aab",
            "suomi-meta:publicationStatus": {
                "@id": "http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT"
            },
            "skos-xl:literalForm": {
                "@language": "en",
                "@value": "payment service provider"
            },
            "@type": "skos-xl:Label"
        },
        {
            "@id": "urn:uuid:25b2a89d-d6bb-4699-a181-177427e791b8",
            "suomi-meta:publicationStatus": {
