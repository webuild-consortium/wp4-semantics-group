                "@type": "xsd:dateTime"
            },
            "suomi-meta:publicationStatus": {
                "@id": "http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT"
            },
            "suomi-meta:modifier": "5dc030a4-740f-4dde-9548-4e6e797899d8",
            "skos:note": {
                "@language": "en",
                "@value": "Post codes are common elements in many countries' postal address systems. One of the many post codes of Paris is for example \"75000\"."
            },
            "term:orderedNote": {
                "@list": [
                    {
                        "@language": "en",
                        "@value": "Post codes are common elements in many countries' postal address systems. One of the many post codes of Paris is for example \"75000\"."
                    }
                ]
            },
            "skos:definition": {
                "@language": "en",
                "@value": "The code created and maintained for postal purposes to identify a subdivision of addresses and postal delivery points."
            },
            "skos:prefLabel": {
