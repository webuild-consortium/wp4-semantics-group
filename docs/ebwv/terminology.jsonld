            "skos:definition": {
                "@language": "en",
                "@value": "See legal name"
            },
            "skos:inScheme": {
                "@id": "https://iri.suomi.fi/terminology/webuild/"
            },
            "term:orderedRelated": {
                "@list": [
                    {
                        "@id": "webuild:concept-105"
                    }
                ]
