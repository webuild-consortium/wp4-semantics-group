        {
            "@id": "webuild:employer",
            "suomi-meta:publicationStatus": {
                "@id": "http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT"
            },
            "suomi-meta:modifier": "5dc030a4-740f-4dde-9548-4e6e797899d8",
            "suomi-meta:creator": "5dc030a4-740f-4dde-9548-4e6e797899d8",
            "skos:prefLabel": {
                "@id": "urn:uuid:be37c5e6-09bb-4ca7-bf79-e9608a78aa5a"
            },
            "skos:inScheme": {
                "@id": "https://iri.suomi.fi/terminology/webuild/"
            },
            "skos:definition": {
                "@language": "en",
                "@value": "a party that engages a person to perform work under an employment relationship, with associated rights, duties, reporting obligations, or liabilities"
            },
            "dcterms:modified": {
                "@value": "2026-04-28T11:57:35.962Z",
                "@type": "xsd:dateTime"
            },
            "dcterms:created": {
                "@value": "2026-04-28T11:57:35.962Z",
                "@type": "xsd:dateTime"
            },
            "@type": "skos:Concept"
        },
        {
            "@id": "webuild:postedworker",
            "term:orderedSynonym": {
                "@list": [
                    {
                        "@id": "urn:uuid:a9171cc2-39cc-4310-a26f-b208893f4acf"
                    },
                    {
                        "@id": "urn:uuid:71913d2d-1455-4b11-9fdd-8a4e9c84977f"
                    },
                    {
                        "@id": "urn:uuid:cd779356-62e9-48f1-a572-35ad9b0af95a"
                    }
                ]
            },
            "@type": "skos:Concept",
            "dcterms:created": {
                "@value": "2026-04-28T14:47:17.976Z",
                "@type": "xsd:dateTime"
            },
            "dcterms:modified": {
                "@value": "2026-04-28T14:47:17.976Z",
                "@type": "xsd:dateTime"
            },
            "skos:altLabel": [
                {
                    "@id": "urn:uuid:cd779356-62e9-48f1-a572-35ad9b0af95a"
                },
                {
                    "@id": "urn:uuid:71913d2d-1455-4b11-9fdd-8a4e9c84977f"
                },
                {
                    "@id": "urn:uuid:a9171cc2-39cc-4310-a26f-b208893f4acf"
                }
            ],
            "skos:definition": {
                "@language": "en",
                "@value": "a worker who is sent by an employer to perform work temporarily in a country other than the country in which the worker normally works"
            },
            "skos:example": {
                "@language": "en",
                "@value": "A Finnish employer submits a Posted Worker Notification stating that a named employee is a posted worker assigned to a construction site in Belgium for three months."
            },
            "skos:inScheme": {
                "@id": "https://iri.suomi.fi/terminology/webuild/"
            },
            "skos:note": {
                "@language": "en",
                "@value": "In the EBWV context, and especially in a Posted Worker Notification, posted worker denotes the person whose cross-border posting is being notified to the competent authority of the host country. The concept should be used for the worker subject to the posting arrangement, not for the posting employer, host entity, local contact person, legal representative, or service recipient. A posted worker normally remains employed by, or otherwise contractually connected to, the sending employer during the posting period."
            },
            "skos:prefLabel": {
                "@id": "urn:uuid:1a54f59d-de99-4734-b22b-25592d936381"
            },
            "suomi-meta:creator": "5dc030a4-740f-4dde-9548-4e6e797899d8",
            "suomi-meta:modifier": "5dc030a4-740f-4dde-9548-4e6e797899d8",
            "suomi-meta:publicationStatus": {
                "@id": "http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT"
            },
            "term:orderedExample": {
                "@list": [
                    {
                        "@language": "en",
                        "@value": "A Finnish employer submits a Posted Worker Notification stating that a named employee is a posted worker assigned to a construction site in Belgium for three months."
                    }
                ]
            },
            "term:orderedNote": {
                "@list": [
                    {
                        "@language": "en",
                        "@value": "In the EBWV context, and especially in a Posted Worker Notification, posted worker denotes the person whose cross-border posting is being notified to the competent authority of the host country. The concept should be used for the worker subject to the posting arrangement, not for the posting employer, host entity, local contact person, legal representative, or service recipient. A posted worker normally remains employed by, or otherwise contractually connected to, the sending employer during the posting period."
                    }
                ]
            }
        },
        {
            "@id": "webuild:typeofemployment",
            "term:orderedSynonym": {
                "@list": [
                    {
                        "@id": "urn:uuid:edaa44ed-13c7-44ac-ba65-f86d21618e43"
                    },
                    {
                        "@id": "urn:uuid:0e2d5b67-58ce-4e12-b359-c6b3121b1b62"
                    },
                    {
                        "@id": "urn:uuid:45d9582e-10e8-40ef-b67d-53ce26ec2506"
                    },
                    {
                        "@id": "urn:uuid:782efa4d-40a8-4931-be9a-37b98f96ca4c"
                    }
                ]
            },
            "term:orderedRelated": {
                "@list": [
                    {
                        "@id": "webuild:postedworker"
                    },
                    {
                        "@id": "webuild:employer"
                    }
                ]
            },
            "term:orderedNote": {
                "@list": [
                    {
                        "@language": "en",
                        "@value": "In the EBWV context, type of employment should be used as a generic property of an employment relationship. It may describe whether the employment is permanent, fixed-term, temporary, seasonal, part-time, full-time, agency-based, apprenticeship-based, probationary or another recognised employment form.\n\nIn the Posted Worker Notification context, this concept helps describe the employment arrangement under which the posted worker is employed by the sending employer during the posting period. It should be distinguished from job title, which names the worker’s role or position; employment status, which may describe whether a person is employed, self-employed, unemployed or otherwise active; and working time, which describes the hours or pattern of work."
                    }
                ]
            },
            "term:orderedExample": {
                "@list": [
                    {
                        "@language": "en",
                        "@value": "A Posted Worker Notification states that the posted worker’s type of employment is “fixed-term employment”."
                    }
                ]
            },
            "suomi-meta:publicationStatus": {
                "@id": "http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT"
            },
            "@type": "skos:Concept",
            "dcterms:created": {
                "@value": "2026-04-28T15:04:07.672Z",
                "@type": "xsd:dateTime"
            },
            "dcterms:modified": {
                "@value": "2026-04-28T15:04:07.672Z",
                "@type": "xsd:dateTime"
            },
            "skos:altLabel": [
                {
                    "@id": "urn:uuid:782efa4d-40a8-4931-be9a-37b98f96ca4c"
                },
                {
                    "@id": "urn:uuid:45d9582e-10e8-40ef-b67d-53ce26ec2506"
                },
                {
                    "@id": "urn:uuid:0e2d5b67-58ce-4e12-b359-c6b3121b1b62"
                },
                {
                    "@id": "urn:uuid:edaa44ed-13c7-44ac-ba65-f86d21618e43"
                }
            ],
            "skos:definition": {
                "@language": "en",
                "@value": "the category or form of an employment relationship, indicating how a worker is employed or engaged by an employer"
            },
            "skos:example": {
                "@language": "en",
                "@value": "A Posted Worker Notification states that the posted worker’s type of employment is “fixed-term employment”."
            },
            "skos:inScheme": {
                "@id": "https://iri.suomi.fi/terminology/webuild/"
            },
            "skos:note": {
                "@language": "en",
                "@value": "In the EBWV context, type of employment should be used as a generic property of an employment relationship. It may describe whether the employment is permanent, fixed-term, temporary, seasonal, part-time, full-time, agency-based, apprenticeship-based, probationary or another recognised employment form.\n\nIn the Posted Worker Notification context, this concept helps describe the employment arrangement under which the posted worker is employed by the sending employer during the posting period. It should be distinguished from job title, which names the worker’s role or position; employment status, which may describe whether a person is employed, self-employed, unemployed or otherwise active; and working time, which describes the hours or pattern of work."
            },
            "skos:prefLabel": {
                "@id": "urn:uuid:90d215a5-19dc-49eb-80ee-9abd063d94c2"
            },
            "skos:related": [
                {
                    "@id": "webuild:employer"
                },
                {
                    "@id": "webuild:postedworker"
                }
            ],
