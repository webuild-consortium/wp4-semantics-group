                        "@id": "webuild:concept-26"
                    },
                    {
                        "@id": "webuild:birthname"
                    }
                ]
            },
            "term:orderedExample": {
                "@list": [
                    {
                        "@language": "en",
                        "@value": "A business identity attestation includes the registered legal name of the company, while a person identification attestation includes the person’s given name and family name."
                    }
                ]
            },
            "suomi-meta:publicationStatus": {
                "@id": "http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT"
