            "skos:note": {
                "@language": "en",
                "@value": "Legal entity is useb by ISA2 but we haven&#039;t defined it, should we do that?"
            },
            "skos:inScheme": {
                "@id": "https://iri.suomi.fi/terminology/webuild/"
            },
            "skos:definition": {
                "@language": "en",
                "@value": "an <a href='http://uri.suomi.fi/terminology/nbvoc/concept-41' data-type='internal'>agent </a>that <a href='http://uri.suomi.fi/terminology/nbvoc/concept-3022' data-type='internal'>owns </a><a href='http://uri.suomi.fi/terminology/nbvoc/concept-3021' data-type='internal'>shares </a>in a <a href='http://uri.suomi.fi/terminology/nbvoc/concept-3' data-type='internal'>legal entity</a>"
            },
            "http://purl.org/termed/properties/id": "37ac68f7-cd85-478d-977f-9b9cbd9e7bbd",
