            },
            "skos:definition": {
                "@language": "en",
                "@value": "a specific configuration of a European Business Wallet solution provided to a particular European Business Wallet owner, including the wallet front-end and back-end and the associated wallet secure cryptographic applications and devices"
            },
            "skos:broader": {
                "@id": "webuild:concept-106"
