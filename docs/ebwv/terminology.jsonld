                "@type": "xsd:dateTime"
            },
            "dcterms:created": "2022-02-14T09:01:34Z",
            "@type": "skos:Concept"
        },
        {
            "@id": "webuild:legalname",
            "term:orderedSynonym": {
                "@list": [
                    {
                        "@id": "urn:uuid:b09248cf-2495-426b-9423-4a72dab92ddf"
                    },
                    {
                        "@id": "urn:uuid:21bfc130-0b34-4049-a37a-10f8fabbfcd5"
                    }
                ]
            },
            "term:orderedSource": {
                "@list": [
                    "https://semiceu.github.io/Core-Business-Vocabulary/releases/2.2.0/#LegalEntity.legalname"
                ]
            },
            "term:orderedNote": {
                "@list": [
                    {
                        "@language": "en",
                        "@value": "The legal name is different from the alternative (trade) name which is a pseudonym used by companies that do not operate under their registered company name. A business might have more than one legal name, particularly in countries with more than one official language. In such cases, and where the encoding technology allows, the language of the string should be identified."
                    }
                ]
            },
            "suomi-meta:publicationStatus": {
                "@id": "http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT"
            },
            "suomi-meta:modifier": "5dc030a4-740f-4dde-9548-4e6e797899d8",
            "suomi-meta:creator": "5dc030a4-740f-4dde-9548-4e6e797899d8",
            "skos:prefLabel": {
                "@id": "urn:uuid:2515b85a-ef0e-4590-a7e6-76afab617224"
            },
            "skos:note": {
                "@language": "en",
                "@value": "The legal name is different from the alternative (trade) name which is a pseudonym used by companies that do not operate under their registered company name. A business might have more than one legal name, particularly in countries with more than one official language. In such cases, and where the encoding technology allows, the language of the string should be identified."
            },
            "skos:inScheme": {
                "@id": "https://iri.suomi.fi/terminology/webuild/"
            },
            "skos:definition": {
                "@language": "en",
                "@value": "the name under which the legal entity is legally registered"
            },
            "skos:altLabel": [
                {
                    "@id": "urn:uuid:21bfc130-0b34-4049-a37a-10f8fabbfcd5"
                },
                {
                    "@id": "urn:uuid:b09248cf-2495-426b-9423-4a72dab92ddf"
                }
            ],
            "dcterms:source": "https://semiceu.github.io/Core-Business-Vocabulary/releases/2.2.0/#LegalEntity.legalname",
            "dcterms:modified": {
                "@value": "2026-02-03T14:56:47.143Z",
                "@type": "xsd:dateTime"
            },
            "dcterms:created": {
                "@value": "2026-02-03T14:56:47.143Z",
                "@type": "xsd:dateTime"
            },
            "@type": "skos:Concept"
        },
        {
            "@id": "webuild:concept-24",
            "term:orderedBroader": {
                "@list": [
                    {
                        "@id": "webuild:concept-18"
                    }
                ]
            },
            "suomi-meta:publicationStatus": {
                "@id": "http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT"
            },
            "suomi-meta:modifier": "4c00fd3e-ad5d-4ad6-8782-de29597a5d57",
            "suomi-meta:creator": "5dc030a4-740f-4dde-9548-4e6e797899d8",
            "skos:prefLabel": {
                "@id": "urn:uuid:2d0c9be8-ef19-4df7-af9a-541aae17fbb4"
            },
            "skos:inScheme": {
                "@id": "https://iri.suomi.fi/terminology/webuild/"
            },
            "skos:definition": {
                "@language": "en",
                "@value": "Should be removed, we don't use it?"
            },
            "skos:broader": {
                "@id": "webuild:concept-18"
            },
            "http://purl.org/termed/properties/id": "2c0e412e-0ba1-4e91-8fad-ea4ff6b215c1",
            "dcterms:modified": {
                "@value": "2025-01-08T10:34:49.383Z",
                "@type": "xsd:dateTime"
            },
            "dcterms:created": "2022-02-07T08:05:45Z",
            "@type": "skos:Concept"
        },
        {
            "@id": "webuild:alternativename",
            "term:orderedNote": {
                "@list": [
                    {
                        "@language": "en",
                        "@value": "An alternative name may include, for example, a trade name, previous name, alias, pseudonym, commonly used name, or name expressed in another language or script.\nIt does not replace the primary or legal name but exists in parallel as an additional identifier used in specific contexts."
                    }
                ]
            },
            "term:orderedExample": {
                "@list": [
                    {
                        "@language": "en",
                        "@value": "A company’s registered legal name: Nordic Timber Export Oy\nAlternative name: NordTimber (trade name)\n\nA person’s legal name: Aleksandra Nowak\nAlternative name: Aleksandra Kowalska (former name)"
                    }
                ]
            },
            "term:orderedBroader": {
                "@list": [
                    {
                        "@id": "webuild:concept-18"
                    }
                ]
            },
            "suomi-meta:publicationStatus": {
                "@id": "http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT"
            },
            "suomi-meta:modifier": "5dc030a4-740f-4dde-9548-4e6e797899d8",
            "suomi-meta:creator": "5dc030a4-740f-4dde-9548-4e6e797899d8",
            "skos:prefLabel": {
                "@id": "urn:uuid:6c16487d-78cb-4803-92c4-93b8d35ed9c6"
            },
            "skos:note": {
                "@language": "en",
                "@value": "An alternative name may include, for example, a trade name, previous name, alias, pseudonym, commonly used name, or name expressed in another language or script.\nIt does not replace the primary or legal name but exists in parallel as an additional identifier used in specific contexts."
            },
            "skos:inScheme": {
                "@id": "https://iri.suomi.fi/terminology/webuild/"
            },
            "skos:example": {
                "@language": "en",
                "@value": "A company’s registered legal name: Nordic Timber Export Oy\nAlternative name: NordTimber (trade name)\n\nA person’s legal name: Aleksandra Nowak\nAlternative name: Aleksandra Kowalska (former name)"
            },
            "skos:definition": {
                "@language": "en",
                "@value": "a name by which a person, organisation, or other identified entity is known in addition to its primary or legally registered name"
            },
            "skos:broader": {
                "@id": "webuild:concept-18"
            },
            "dcterms:modified": {
                "@value": "2026-02-16T14:28:16.846Z",
                "@type": "xsd:dateTime"
            },
            "dcterms:created": {
                "@value": "2026-02-16T14:28:16.846Z",
                "@type": "xsd:dateTime"
            },
            "@type": "skos:Concept"
        },
        {
            "@id": "webuild:locatorname",
            "term:orderedNote": {
                "@list": [
                    {
                        "@language": "en",
                        "@value": "The locator name could be the name of the property or complex, of the building or part of the building, or it could be the name of a room inside a building.\n\nThe key difference between a locator designator and a locator name is that the latter is a proper name and is unlikely to include digits. For example, \"Shumann, Berlaymont\" is a meeting room within the European Commission headquarters for which locator name is more appropriate than locator."
                    }
                ]
            },
            "suomi-meta:publicationStatus": {
                "@id": "http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT"
            },
            "suomi-meta:modifier": "5dc030a4-740f-4dde-9548-4e6e797899d8",
            "suomi-meta:creator": "5dc030a4-740f-4dde-9548-4e6e797899d8",
            "skos:prefLabel": {
                "@id": "urn:uuid:4f64d4c4-0896-4276-a110-115f26e495ec"
            },
            "skos:note": {
                "@language": "en",
                "@value": "The locator name could be the name of the property or complex, of the building or part of the building, or it could be the name of a room inside a building.\n\nThe key difference between a locator designator and a locator name is that the latter is a proper name and is unlikely to include digits. For example, \"Shumann, Berlaymont\" is a meeting room within the European Commission headquarters for which locator name is more appropriate than locator."
            },
            "skos:inScheme": {
                "@id": "https://iri.suomi.fi/terminology/webuild/"
            },
            "skos:definition": {
                "@language": "en",
                "@value": "Proper noun(s) applied to the real world entity identified by the locator. The locator name could be the name of the property or complex, of the building or part of the building, or it could be the name of a room inside a building."
            },
            "dcterms:modified": {
                "@value": "2026-02-16T09:30:01.03Z",
                "@type": "xsd:dateTime"
            },
            "dcterms:created": {
                "@value": "2026-02-16T09:30:01.03Z",
                "@type": "xsd:dateTime"
            },
            "@type": "skos:Concept"
        },
        {
            "@id": "webuild:postname",
            "term:orderedSynonym": {
                "@list": [
                    {
                        "@id": "urn:uuid:986de4e3-0d97-44d7-975f-cfb591466d4a"
                    }
                ]
            },
            "term:orderedNote": {
                "@list": [
                    {
                        "@language": "en",
                        "@value": "Usually a city, for example \"Paris\"."
                    }
                ]
            },
            "suomi-meta:publicationStatus": {
                "@id": "http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT"
            },
            "suomi-meta:modifier": "5dc030a4-740f-4dde-9548-4e6e797899d8",
            "suomi-meta:creator": "5dc030a4-740f-4dde-9548-4e6e797899d8",
            "skos:prefLabel": {
                "@id": "urn:uuid:a691f4b8-179b-4409-ac62-af733d835bd3"
            },
            "skos:note": {
                "@language": "en",
                "@value": "Usually a city, for example \"Paris\"."
            },
            "skos:inScheme": {
                "@id": "https://iri.suomi.fi/terminology/webuild/"
            },
            "skos:definition": {
                "@language": "en",
                "@value": "a name created and maintained for postal purposes to identify a subdivision of addresses and postal delivery points"
            },
            "skos:altLabel": {
                "@id": "urn:uuid:986de4e3-0d97-44d7-975f-cfb591466d4a"
            },
            "dcterms:modified": {
                "@value": "2026-02-16T08:42:54.145Z",
