        {
            "@id": "webuild:temporaryaddress",
            "term:orderedSynonym": {
                "@list": [
                    {
                        "@id": "urn:uuid:4f3702d9-14a7-4036-a94f-f220320fcb5e"
                    },
                    {
                        "@id": "urn:uuid:904a6fad-c09c-4e21-b6c0-39b14564c791"
                    },
                    {
                        "@id": "urn:uuid:aa7bffd5-55f9-49d1-8ed6-303a0a5f747a"
                    },
                    {
                        "@id": "urn:uuid:d460c34c-abb0-4508-a7b5-ab134bd1d998"
                    }
                ]
            },
            "term:orderedNote": {
                "@list": [
                    {
                        "@language": "en",
                        "@value": "In the EBWV context, temporary address should be used for an address that is valid only for a specific period, stay, assignment, posting, visit or other temporary circumstance. It should be distinguished from domicile, which refers to the place a person treats as their permanent home, and from a general postal address, which may be used only for receiving correspondence. In a Posted Worker Notification, a temporary address may identify the worker’s accommodation or residence in the host country during the posting period."
                    }
                ]
            },
            "term:orderedExample": {
                "@list": [
                    {
                        "@language": "en",
                        "@value": "A Posted Worker Notification states that the worker’s domicile address is in Finland, while the worker’s temporary address during the posting period is an apartment in Belgium."
                    }
                ]
            },
            "term:orderedBroader": {
                "@list": [
                    {
                        "@id": "webuild:address"
                    }
                ]
            },
            "@type": "skos:Concept",
            "dcterms:created": {
                "@value": "2026-04-28T15:01:00.98Z",
                "@type": "xsd:dateTime"
            },
            "dcterms:modified": {
                "@value": "2026-04-28T15:01:00.98Z",
                "@type": "xsd:dateTime"
            },
            "skos:altLabel": [
                {
                    "@id": "urn:uuid:d460c34c-abb0-4508-a7b5-ab134bd1d998"
                },
                {
                    "@id": "urn:uuid:aa7bffd5-55f9-49d1-8ed6-303a0a5f747a"
                },
                {
                    "@id": "urn:uuid:904a6fad-c09c-4e21-b6c0-39b14564c791"
                },
                {
                    "@id": "urn:uuid:4f3702d9-14a7-4036-a94f-f220320fcb5e"
                }
            ],
            "skos:broader": {
                "@id": "webuild:address"
            },
            "skos:definition": {
                "@language": "en",
                "@value": "an address at which a person resides, stays or can be reached for a limited period, without it being the person’s permanent home or domicile address"
            },
            "skos:example": {
                "@language": "en",
                "@value": "A Posted Worker Notification states that the worker’s domicile address is in Finland, while the worker’s temporary address during the posting period is an apartment in Belgium."
            },
            "skos:inScheme": {
                "@id": "https://iri.suomi.fi/terminology/webuild/"
            },
            "skos:note": {
                "@language": "en",
                "@value": "In the EBWV context, temporary address should be used for an address that is valid only for a specific period, stay, assignment, posting, visit or other temporary circumstance. It should be distinguished from domicile, which refers to the place a person treats as their permanent home, and from a general postal address, which may be used only for receiving correspondence. In a Posted Worker Notification, a temporary address may identify the worker’s accommodation or residence in the host country during the posting period."
            },
            "skos:prefLabel": {
                "@id": "urn:uuid:83ec4bbf-a811-46d7-ab42-eaf887c2e0b0"
            },
            "suomi-meta:creator": "5dc030a4-740f-4dde-9548-4e6e797899d8",
            "suomi-meta:modifier": "5dc030a4-740f-4dde-9548-4e6e797899d8",
            "suomi-meta:publicationStatus": {
                "@id": "http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT"
            }
        },
        {
            "@id": "urn:uuid:83ec4bbf-a811-46d7-ab42-eaf887c2e0b0",
            "suomi-meta:publicationStatus": {
                "@id": "http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT"
            },
            "skos-xl:literalForm": {
                "@language": "en",
                "@value": "temporary address"
            },
            "@type": "skos-xl:Label"
        },
        {
            "@id": "webuild:socialrepresentative",
            "term:orderedNote": {
                "@list": [
                    {
                        "@language": "en",
                        "@value": "In the Posted Worker Notification context, social representative should denote the representative identified for social, employment or posting-related matters in the host country. The representative may act as a contact point for authorities, provide or receive information, support compliance with posting obligations, or assist with documentation relating to the posted worker’s social security or labour-law status. The concept should be distinguished from the employer, the host entity, the legal representative of the company, the posted worker, and a purely technical or administrative contact person."
                    }
                ]
            },
            "suomi-meta:publicationStatus": {
                "@id": "http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT"
            },
            "suomi-meta:modifier": "5dc030a4-740f-4dde-9548-4e6e797899d8",
            "suomi-meta:creator": "5dc030a4-740f-4dde-9548-4e6e797899d8",
            "skos:prefLabel": {
                "@id": "urn:uuid:1e19d696-b4d0-483d-84d7-7e83018ddda7"
            },
            "skos:note": {
                "@language": "en",
                "@value": "In the Posted Worker Notification context, social representative should denote the representative identified for social, employment or posting-related matters in the host country. The representative may act as a contact point for authorities, provide or receive information, support compliance with posting obligations, or assist with documentation relating to the posted worker’s social security or labour-law status. The concept should be distinguished from the employer, the host entity, the legal representative of the company, the posted worker, and a purely technical or administrative contact person."
            },
            "skos:inScheme": {
                "@id": "https://iri.suomi.fi/terminology/webuild/"
            },
            "skos:definition": {
                "@language": "en",
                "@value": "a person or entity designated to represent or assist an employer or posted worker in relation to social security, labour, employment or posting-related obligations during a posting period"
            },
            "dcterms:modified": {
                "@value": "2026-04-28T14:58:11.984Z",
                "@type": "xsd:dateTime"
            },
