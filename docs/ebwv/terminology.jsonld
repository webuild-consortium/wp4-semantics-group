        {
            "@id": "webuild:provenanceproof",
            "suomi-meta:publicationStatus": {
                "@id": "http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT"
            },
            "suomi-meta:modifier": "5dc030a4-740f-4dde-9548-4e6e797899d8",
            "suomi-meta:creator": "5dc030a4-740f-4dde-9548-4e6e797899d8",
            "skos:prefLabel": {
                "@id": "urn:uuid:f4d40301-b8ac-495c-90bd-7a64a89d0385"
            },
            "skos:inScheme": {
                "@id": "https://iri.suomi.fi/terminology/webuild/"
            },
            "skos:definition": {
                "@language": "en",
                "@value": "verifiable evidence establishing the origin, issuance context, and integrity of an electronic attestation of attributes, enabling a relying party to confirm who issued the attestation, on what basis, and that it has not been altered since issuance"
            },
            "dcterms:modified": {
                "@value": "2026-02-04T11:24:39.834Z",
                "@type": "xsd:dateTime"
            },
            "dcterms:created": {
                "@value": "2026-02-04T11:24:39.834Z",
                "@type": "xsd:dateTime"
            },
            "@type": "skos:Concept"
        },
        {
