        {
            "@id": "webuild:legalPersonIdentificationData",
            "suomi-meta:publicationStatus": {
                "@id": "http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT"
            },
            "suomi-meta:modifier": "f7193db9-3c93-4d56-9d57-d5c3f1132fe9",
            "suomi-meta:creator": "f7193db9-3c93-4d56-9d57-d5c3f1132fe9",
            "skos:prefLabel": {
                "@id": "urn:uuid:37e77d0d-ad8c-438a-8b3a-8683e2a4cd85"
            },
            "skos:inScheme": {
                "@id": "https://iri.suomi.fi/terminology/webuild/"
            },
            "skos:definition": {
                "@language": "en",
                "@value": "a set of data that enables the establishment of the identity of a legal person and that is issued by a LPID provider. The LPID is the credential subject of an LPID-Credential. A LPID credential allows a legal person to authenticate against a relying party."
            },
            "dcterms:modified": {
                "@value": "2026-01-12T16:28:32.455Z",
                "@type": "xsd:dateTime"
            },
            "dcterms:created": {
                "@value": "2026-01-12T16:28:32.455Z",
                "@type": "xsd:dateTime"
            },
            "@type": "skos:Concept"
        },
        {
            "@id": "urn:uuid:37e77d0d-ad8c-438a-8b3a-8683e2a4cd85",
            "suomi-meta:publicationStatus": {
                "@id": "http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT"
            },
            "skos-xl:literalForm": {
                "@language": "en",
                "@value": "Legal Person Identification Data"
            },
            "@type": "skos-xl:Label"
        },
        {
            "@id": "urn:uuid:d415b619-215c-44cc-b893-cab5df27b067",
            "suomi-meta:publicationStatus": {
                "@id": "http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT"
            },
            "skos-xl:literalForm": {
                "@language": "en",
                "@value": "natural person"
            },
            "@type": "skos-xl:Label"
        },
        {
            "@id": "webuild:legalidentifier",
            "suomi-meta:creator": "5dc030a4-740f-4dde-9548-4e6e797899d8",
            "skos:definition": {
                "@language": "en",
                "@value": "the unambiguous structured reference assigned to the legal entity by the legal authority that registered it"
            },
            "term:orderedSource": {
                "@list": [
                    "https://semiceu.github.io/Core-Business-Vocabulary/releases/2.2.0/#LegalEntity.legalidentifier"
                ]
            },
            "suomi-meta:publicationStatus": {
                "@id": "http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT"
            },
            "dcterms:modified": {
                "@value": "2026-02-03T15:04:12.908Z",
                "@type": "xsd:dateTime"
            },
            "dcterms:source": "https://semiceu.github.io/Core-Business-Vocabulary/releases/2.2.0/#LegalEntity.legalidentifier",
            "skos:prefLabel": {
                "@id": "urn:uuid:6338be59-797f-4b3c-a77c-c2e7ef473114"
            },
            "@type": "skos:Concept",
            "term:orderedNote": {
                "@list": [
                    {
                        "@language": "en",
                        "@value": "Legal Entity must have a unique identification number, allowing it to be clearly identified in communication across business registers. The Core vocabulary sets no restriction on the type of legal identifier. In many countries, the business register's identifier is the relevant data point.\n\nRemoved: \"The details of the registration are provided as properties of the Identifier class.\""
                    }
                ]
            },
            "suomi-meta:modifier": "5dc030a4-740f-4dde-9548-4e6e797899d8",
            "skos:note": {
                "@language": "en",
                "@value": "Legal Entity must have a unique identification number, allowing it to be clearly identified in communication across business registers. The Core vocabulary sets no restriction on the type of legal identifier. In many countries, the business register's identifier is the relevant data point.\n\nRemoved: \"The details of the registration are provided as properties of the Identifier class.\""
            },
            "dcterms:created": {
                "@value": "2026-02-03T15:04:12.908Z",
                "@type": "xsd:dateTime"
            },
            "skos:inScheme": {
                "@id": "https://iri.suomi.fi/terminology/webuild/"
            }
        },
