            },
            "skos:definition": {
                "@language": "en",
                "@value": "a Union entity, national, state, regional or local authority, a body governed by public law, an association formed by such entities or bodies, or a private entity mandated by at least one of them to provide public services, when acting under such a mandate"
            }
        },
