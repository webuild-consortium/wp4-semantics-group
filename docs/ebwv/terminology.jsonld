        {
            "@id": "webuild:powerofattorney",
            "dcterms:created": {
                "@value": "2026-02-04T11:00:17.579Z",
                "@type": "xsd:dateTime"
            },
            "term:orderedBroader": {
                "@list": [
                    {
                        "@id": "webuild:authorisation"
                    }
                ]
            },
            "skos:prefLabel": {
