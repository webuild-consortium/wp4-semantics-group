        {
            "@id": "webuild:placeofbirth",
            "term:orderedSynonym": {
                "@list": [
                    {
                        "@id": "urn:uuid:20283923-7f34-45f9-9c3c-4f3a6841cf79"
                    },
                    {
                        "@id": "urn:uuid:b26c663e-9861-4d63-ad24-cad6cc7802b1"
                    },
                    {
                        "@id": "urn:uuid:85bd8c78-7c60-4ec8-b460-f2677767225e"
                    },
                    {
                        "@id": "urn:uuid:53cfd7af-d6ad-4e90-97ef-bcec9052e0b3"
                    }
                ]
            },
            "term:orderedRelated": {
                "@list": [
                    {
                        "@id": "webuild:person"
                    }
                ]
            },
            "term:orderedNote": {
                "@list": [
                    {
                        "@language": "en",
                        "@value": "In the EBWV context, place of birth should be used for the officially recorded or attested location of a person’s birth. The value may be represented as a structured location, such as a municipality, city, region or other named place, and may be supported by a geographic identifier. It should be distinguished from country of birth, which identifies only the country, and from domicile, residence or address, which describe where the person lives or is treated as living."
                    }
                ]
            },
            "term:orderedExample": {
                "@list": [
                    {
                        "@language": "en",
                        "@value": "A person identification attestation states that the person’s place of birth is Helsinki, Finland."
                    }
                ]
            },
            "@type": "skos:Concept",
            "dcterms:created": {
                "@value": "2026-04-28T14:41:22.938Z",
                "@type": "xsd:dateTime"
            },
            "dcterms:modified": {
                "@value": "2026-04-28T14:41:42.981Z",
                "@type": "xsd:dateTime"
            },
            "skos:altLabel": [
