        },
        {
            "@id": "webuild:addressarea",
            "term:orderedNote": {
                "@list": [
                    {
                        "@language": "en",
                        "@value": "This would typically be part of a city, a neighbourhood or village, e.g. the area Stenstaden in the city of Sundsvall (SE) or Kreuzberg in the city of Berlin (DE). Address area is not an administrative unit."
                    }
                ]
            },
            "suomi-meta:publicationStatus": {
                "@id": "http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT"
            },
            "suomi-meta:modifier": "5dc030a4-740f-4dde-9548-4e6e797899d8",
            "suomi-meta:creator": "5dc030a4-740f-4dde-9548-4e6e797899d8",
            "skos:prefLabel": {
                "@id": "urn:uuid:9f364117-46ae-4e12-b887-ed617d30edfa"
            },
            "skos:note": {
                "@language": "en",
                "@value": "This would typically be part of a city, a neighbourhood or village, e.g. the area Stenstaden in the city of Sundsvall (SE) or Kreuzberg in the city of Berlin (DE). Address area is not an administrative unit."
            },
            "skos:inScheme": {
                "@id": "https://iri.suomi.fi/terminology/webuild/"
            },
            "skos:definition": {
                "@language": "en",
                "@value": "the name of a geographic area that groups addresses"
            },
            "dcterms:modified": {
                "@value": "2026-02-16T09:52:42.366Z",
                "@type": "xsd:dateTime"
            },
            "dcterms:created": {
                "@value": "2026-02-16T09:51:14.436Z",
                "@type": "xsd:dateTime"
            },
            "@type": "skos:Concept"
        },
        {
            "@id": "webuild:adminUnitL1",
            "term:orderedNote": {
                "@list": [
                    {
                        "@language": "en",
                        "@value": "Best practice is to use the ISO 3166-1 code but if this is inappropriate for the context, country names should be provided in a consistent manner to reduce ambiguity. For example, either write 'France' or 'FRA' consistently throughout the dataset and avoid mixing the two. The Country controlled vocabulary from the Publications Office can be reused for this."
                    }
                ]
            },
            "suomi-meta:publicationStatus": {
                "@id": "http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT"
            },
            "suomi-meta:modifier": "5dc030a4-740f-4dde-9548-4e6e797899d8",
            "suomi-meta:creator": "5dc030a4-740f-4dde-9548-4e6e797899d8",
            "skos:prefLabel": {
                "@id": "urn:uuid:019632ce-2305-44a9-882c-19e924ea43db"
            },
            "skos:note": {
                "@language": "en",
                "@value": "Best practice is to use the ISO 3166-1 code but if this is inappropriate for the context, country names should be provided in a consistent manner to reduce ambiguity. For example, either write 'France' or 'FRA' consistently throughout the dataset and avoid mixing the two. The Country controlled vocabulary from the Publications Office can be reused for this."
            },
            "skos:inScheme": {
                "@id": "https://iri.suomi.fi/terminology/webuild/"
            },
            "skos:definition": {
                "@language": "en",
                "@value": "the name of the uppermost level of the address, almost always a country"
            },
            "dcterms:modified": {
                "@value": "2026-02-16T09:45:53.956Z",
                "@type": "xsd:dateTime"
            },
            "dcterms:created": {
                "@value": "2026-02-16T09:45:53.956Z",
                "@type": "xsd:dateTime"
            },
            "@type": "skos:Concept"
        },
        {
            "@id": "urn:uuid:019632ce-2305-44a9-882c-19e924ea43db",
            "suomi-meta:publicationStatus": {
