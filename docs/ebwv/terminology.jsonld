        },
        {
            "@id": "webuild:economicactivity",
            "term:orderedSynonym": {
                "@list": [
                    {
                        "@id": "urn:uuid:538de649-c8ff-49d0-8ad6-7c80f0c76ad3"
                    },
                    {
                        "@id": "urn:uuid:9c8ac212-67a2-4fad-b6f2-df083426d020"
                    }
                ]
            },
            "term:orderedRelated": {
                "@list": [
                    {
                        "@id": "webuild:economicoperator"
                    }
                ]
            },
            "@type": "skos:Concept",
            "dcterms:created": {
                "@value": "2026-04-14T05:43:55.26Z",
                "@type": "xsd:dateTime"
            },
            "dcterms:modified": {
                "@value": "2026-04-14T05:46:26.677Z",
                "@type": "xsd:dateTime"
            },
            "skos:altLabel": [
                {
                    "@id": "urn:uuid:538de649-c8ff-49d0-8ad6-7c80f0c76ad3"
                },
                {
                    "@id": "urn:uuid:9c8ac212-67a2-4fad-b6f2-df083426d020"
                }
            ],
            "skos:broader": {
                "@id": "webuild:activity"
            },
            "skos:definition": {
                "@language": "en",
                "@value": "activity in which resources are combined in a production process to produce goods or services; in EU law and policy, the concept also covers the offering of goods or services on a market"
            },
            "skos:inScheme": {
                "@id": "https://iri.suomi.fi/terminology/webuild/"
            },
            "skos:note": {
                "@language": "en",
                "@value": "Use for activities relevant to NACE classification, business statistics, market participation, trade, procurement, compliance and EU Business Wallet attestations. An economic activity may be associated with an economic operator in the regulatory sense."
            },
            "skos:prefLabel": {
                "@id": "urn:uuid:8860fb3a-4231-47a8-8031-6ac8ea25d3db"
            },
            "skos:related": {
                "@id": "webuild:economicoperator"
            },
            "suomi-meta:creator": "5dc030a4-740f-4dde-9548-4e6e797899d8",
            "suomi-meta:modifier": "5dc030a4-740f-4dde-9548-4e6e797899d8",
            "suomi-meta:publicationStatus": {
                "@id": "http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT"
            },
            "term:orderedBroader": {
                "@list": [
                    {
                        "@id": "webuild:activity"
                    }
                ]
            },
            "term:orderedNote": {
                "@list": [
                    {
                        "@language": "en",
                        "@value": "Use for activities relevant to NACE classification, business statistics, market participation, trade, procurement, compliance and EU Business Wallet attestations. An economic activity may be associated with an economic operator in the regulatory sense."
                    }
                ]
            }
        },
        {
            "@id": "webuild:economicoperator",
            "term:orderedRelated": {
                "@list": [
                    {
                        "@id": "webuild:economicactivity"
                    }
                ]
            },
            "suomi-meta:publicationStatus": {
                "@id": "http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT"
            },
            "suomi-meta:modifier": "5dc030a4-740f-4dde-9548-4e6e797899d8",
            "suomi-meta:creator": "5dc030a4-740f-4dde-9548-4e6e797899d8",
            "skos:related": {
                "@id": "webuild:economicactivity"
            },
            "skos:prefLabel": {
                "@id": "urn:uuid:9dd6aa36-d9d6-41c2-81d8-3f268dbf5789"
            },
            "skos:inScheme": {
                "@id": "https://iri.suomi.fi/terminology/webuild/"
            },
            "skos:definition": {
                "@language": "en",
                "@value": "any natural or legal person, including but not limited to companies, partnerships, foundations, associations as well as sole-traders and self-employed persons or a group of such persons, acting in a commercial or professional capacity (EBW regulation definition; 3rd Presidency compromise)\n\nOR\n\nactor concept used in EU regulatory contexts for a natural or legal person, and in some instruments also a public entity or grouping, engaged in legally relevant economic operations"
            },
            "dcterms:modified": {
                "@value": "2026-04-14T05:47:34.269Z",
                "@type": "xsd:dateTime"
            },
            "dcterms:created": {
                "@value": "2026-04-14T05:45:50.887Z",
                "@type": "xsd:dateTime"
            },
            "@type": "skos:Concept"
        },
        {
            "@id": "webuild:activity",
            "term:orderedSynonym": {
                "@list": [
                    {
                        "@id": "urn:uuid:8425ef72-a782-4413-86e7-19c41413e5c1"
                    },
                    {
                        "@id": "urn:uuid:64abbb6a-818b-48d7-a70d-d9acc42aa6c2"
                    }
                ]
            },
            "term:orderedNote": {
                "@list": [
                    {
                        "@language": "en",
                        "@value": "Broad neutral concept. Use when the activity does not specifically need to be classified as economic, regulatory, administrative or other specialised activity.\n\nOR \n\nA more narrower concept that is anchored clearly in business, economic operators, and contextual purpose, rather than generic human action."
                    }
                ]
            },
            "term:orderedNarrower": {
                "@list": [
                    {
                        "@id": "webuild:economicactivity"
                    }
                ]
            },
            "suomi-meta:publicationStatus": {
                "@id": "http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT"
            },
            "suomi-meta:modifier": "5dc030a4-740f-4dde-9548-4e6e797899d8",
            "suomi-meta:creator": "5dc030a4-740f-4dde-9548-4e6e797899d8",
            "skos:prefLabel": {
                "@id": "urn:uuid:760b4be2-8c0d-46e2-be0e-30d77cb2a146"
            },
            "skos:note": {
                "@language": "en",
                "@value": "Broad neutral concept. Use when the activity does not specifically need to be classified as economic, regulatory, administrative or other specialised activity.\n\nOR \n\nA more narrower concept that is anchored clearly in business, economic operators, and contextual purpose, rather than generic human action."
            },
            "skos:narrower": {
                "@id": "webuild:economicactivity"
            },
            "skos:inScheme": {
                "@id": "https://iri.suomi.fi/terminology/webuild/"
            },
            "skos:definition": {
                "@language": "en",
                "@value": "organised doing, operation or process carried out for a purpose or result\n\nOR\n\na business-related undertaking, operation, or process carried out by a party or economic operator for a defined purpose within an economic, administrative, or regulatory context"
            },
            "skos:altLabel": [
                {
                    "@id": "urn:uuid:8425ef72-a782-4413-86e7-19c41413e5c1"
                },
                {
                    "@id": "urn:uuid:64abbb6a-818b-48d7-a70d-d9acc42aa6c2"
                }
            ],
