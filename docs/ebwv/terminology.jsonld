        {
            "@id": "webuild:powerofattorney",
            "term:orderedBroader": {
                "@list": [
                    {
                        "@id": "webuild:authorisation"
                    }
                ]
            },
            "suomi-meta:publicationStatus": {
                "@id": "http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT"
            },
            "suomi-meta:modifier": "5dc030a4-740f-4dde-9548-4e6e797899d8",
            "suomi-meta:creator": "5dc030a4-740f-4dde-9548-4e6e797899d8",
            "skos:prefLabel": {
                "@id": "urn:uuid:5750efcd-f4ef-44bd-b31d-ea8976fb19f0"
            },
            "skos:inScheme": {
                "@id": "https://iri.suomi.fi/terminology/webuild/"
            },
            "skos:definition": {
                "@language": "en",
                "@value": "a legally effective authorization by which a natural person or legal person (the mandator) grants another agent (the mandatee) the right to act on the mandator’s behalf in one or more specified legal, administrative, or business matters, with defined scope, constraints, and validity, and which can be presented and verified in the EU Business Wallet as evidence of representation towards relying parties"
            },
            "skos:broader": {
                "@id": "webuild:authorisation"
            },
