        },
        {
            "@id": "webuild:subscribedcapital",
            "skos:example": {
                "@language": "en",
                "@value": "A private limited company with registered subscribed capital of 25,000 EUR.\nA public limited company with subscribed capital of 100,000 EUR, partially paid."
            },
            "@type": "skos:Concept",
            "suomi-meta:creator": "5dc030a4-740f-4dde-9548-4e6e797899d8",
            "term:orderedExample": {
                "@list": [
                    {
                        "@language": "en",
                        "@value": "A private limited company with registered subscribed capital of 25,000 EUR.\nA public limited company with subscribed capital of 100,000 EUR, partially paid."
                    }
                ]
            },
            "suomi-meta:publicationStatus": {
                "@id": "http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT"
            },
            "skos:prefLabel": {
                "@id": "urn:uuid:847a0421-d786-4fa4-b5e5-59a139eac626"
            },
            "skos:note": {
                "@language": "en",
                "@value": "Subscribed capital represents a legally binding commitment of capital participation in a company.\nIt may be fully or partially paid and is recorded in official company registration or statutory documents.\nIt applies primarily to capital-based legal entities."
            },
            "dcterms:created": {
                "@value": "2026-02-03T15:31:29.16Z",
                "@type": "xsd:dateTime"
            },
            "dcterms:modified": {
                "@value": "2026-02-17T14:06:02.308Z",
                "@type": "xsd:dateTime"
            },
            "term:orderedNote": {
                "@list": [
                    {
                        "@language": "en",
                        "@value": "Subscribed capital represents a legally binding commitment of capital participation in a company.\nIt may be fully or partially paid and is recorded in official company registration or statutory documents.\nIt applies primarily to capital-based legal entities."
                    }
                ]
            },
            "skos:definition": {
                "@language": "en",
                "@value": "the total monetary amount of capital that shareholders or members have formally committed to contribute to a company under its constitutive documents"
            },
            "skos:inScheme": {
                "@id": "https://iri.suomi.fi/terminology/webuild/"
            },
            "suomi-meta:modifier": "5dc030a4-740f-4dde-9548-4e6e797899d8"
        },
