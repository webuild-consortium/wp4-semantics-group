                        "@id": "webuild:concept-6006"
                    }
                ]
            },
            "@type": "skos:Concept",
            "dcterms:created": "2022-10-24T09:42:20Z",
            "dcterms:modified": {
                "@value": "2026-04-14T05:32:08.323Z",
                "@type": "xsd:dateTime"
            },
            "http://purl.org/termed/properties/id": "be7d71a9-3a74-4f51-9e65-0c4635616c66",
            "skos:definition": {
                "@language": "en",
                "@value": "an active deed or action carried out by a legal entity"
            },
            "skos:inScheme": {
                "@id": "https://iri.suomi.fi/terminology/webuild/"
            },
            "skos:narrower": [
                {
                    "@id": "webuild:concept-30"
                },
                {
                    "@id": "webuild:concept-2000"
                }
            ],
            "skos:note": {
                "@language": "en",
                "@value": "EU Core Business Vocabulary definition for \"Legal entity activity\" =  The area of work in which the Legal Entity is engaged."
            },
            "skos:prefLabel": {
                "@id": "urn:uuid:f2f78481-7cc2-4237-ace4-eb47cedace0a"
            },
            "skos:related": {
                "@id": "webuild:concept-6006"
            },
            "suomi-meta:creator": "5dc030a4-740f-4dde-9548-4e6e797899d8",
            "suomi-meta:modifier": "5dc030a4-740f-4dde-9548-4e6e797899d8",
            "suomi-meta:publicationStatus": {
                "@id": "http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT"
            },
            "term:orderedNarrower": {
                "@list": [
                    {
                        "@id": "webuild:concept-2000"
                    },
                    {
                        "@id": "webuild:concept-30"
                    }
                ]
            },
            "term:orderedNote": {
                "@list": [
                    {
                        "@language": "en",
                        "@value": "EU Core Business Vocabulary definition for \"Legal entity activity\" =  The area of work in which the Legal Entity is engaged."
                    }
                ]
            }
        },
        {
            "@id": "webuild:concept-2000",
            "term:orderedRelated": {
                "@list": [
                    {
                        "@id": "webuild:concept-94"
                    }
                ]
            },
            "term:orderedNote": {
                "@list": [
                    {
                        "@language": "en",
                        "@value": "An economic activity is characterised by an input of resources (such as capital goods, labour, manufacturing techniques or intermediary products), a production process and an output of products (goods or services).  <br />Economic activity does not have to be carried out for profit or even regularly. When economic activities are carried out by agents in order to generate profit, the economic activity can be described as business activity. <br />Economic activity values should be expressed as values from a common codelist. In the NSG&amp;B context the values should be taken from NACE."
                    }
                ]
            },
            "term:orderedBroader": {
                "@list": [
                    {
                        "@id": "webuild:concept-2001"
                    }
                ]
            },
            "suomi-meta:publicationStatus": {
                "@id": "http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT"
            },
            "suomi-meta:modifier": "5dc030a4-740f-4dde-9548-4e6e797899d8",
            "suomi-meta:creator": "5dc030a4-740f-4dde-9548-4e6e797899d8",
            "skos:related": {
                "@id": "webuild:concept-94"
            },
            "skos:prefLabel": {
                "@id": "urn:uuid:bc1436c2-d988-47a4-a14d-594086ea71c9"
            },
            "skos:note": {
                "@language": "en",
                "@value": "An economic activity is characterised by an input of resources (such as capital goods, labour, manufacturing techniques or intermediary products), a production process and an output of products (goods or services).  <br />Economic activity does not have to be carried out for profit or even regularly. When economic activities are carried out by agents in order to generate profit, the economic activity can be described as business activity. <br />Economic activity values should be expressed as values from a common codelist. In the NSG&amp;B context the values should be taken from NACE."
            },
            "skos:inScheme": {
                "@id": "https://iri.suomi.fi/terminology/webuild/"
            },
            "skos:definition": {
                "@language": "en",
                "@value": "an activity where resources are combined to produce specific goods or services"
            },
            "skos:broader": {
                "@id": "webuild:concept-2001"
            },
            "http://purl.org/termed/properties/id": "d0c8878f-1c7f-4573-a913-aa1a9d32c0e1",
