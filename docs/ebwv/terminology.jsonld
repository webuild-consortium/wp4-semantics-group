        {
            "@id": "webuild:concept-100",
            "term:orderedSynonym": {
                "@list": [
                    {
                        "@id": "urn:uuid:38d50945-6756-45eb-966b-e8668571d25d"
                    }
                ]
            },
            "term:orderedRelated": {
                "@list": [
                    {
                        "@id": "webuild:concept-7"
                    },
                    {
                        "@id": "webuild:concept-14"
                    },
                    {
                        "@id": "webuild:concept-98"
                    }
                ]
            },
            "term:orderedNote": {
                "@list": [
                    {
                        "@language": "en",
                        "@value": "At minimum, the \"EBWOID\" includes legal name + one or more legal identifiers (e.g., EUID or national identifier), and may include additional matching attributes under policy."
                    }
                ]
            },
            "@type": "skos:Concept",
            "dcterms:created": {
                "@value": "2025-12-04T13:05:46.444Z",
                "@type": "xsd:dateTime"
            },
            "dcterms:modified": {
                "@value": "2026-01-23T14:58:21.848Z",
                "@type": "xsd:dateTime"
            },
            "skos:altLabel": {
                "@id": "urn:uuid:38d50945-6756-45eb-966b-e8668571d25d"
            },
            "skos:broader": {
                "@id": "webuild:concept-93"
            },
            "skos:definition": {
                "@language": "en",
                "@value": "a set of data that enables the establishment of the identity of a European Business Wallet owner and that is issued by a provider of European Business Wallet owner identification data"
            },
            "skos:inScheme": {
                "@id": "https://iri.suomi.fi/terminology/webuild/"
            },
            "skos:note": {
                "@language": "en",
                "@value": "At minimum, the \"EBWOID\" includes legal name + one or more legal identifiers (e.g., EUID or national identifier), and may include additional matching attributes under policy."
            },
            "skos:prefLabel": {
                "@id": "urn:uuid:346cac64-695d-436e-a8b4-daba8723e44d"
            },
            "skos:related": [
                {
                    "@id": "webuild:concept-98"
                },
                {
                    "@id": "webuild:concept-7"
                },
