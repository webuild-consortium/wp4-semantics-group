        {
            "@id": "webuild:concept-94",
            "term:orderedSource": {
                "@list": [
                    "COM(2025) 838 - Proposal for a Regulation on the establishment of European Business Wallets"
                ]
            },
            "term:orderedRelated": {
                "@list": [
                    {
                        "@id": "webuild:concept-6006"
                    },
                    {
                        "@id": "webuild:concept-109"
                    },
                    {
                        "@id": "webuild:concept-6005"
                    }
                ]
            },
            "term:orderedNote": {
                "@list": [
                    {
                        "@language": "en",
                        "@value": "“Economic operator” is a capacity/role. \n\nThe same underlying entity may or may not be an economic operator depending on context. \n\nEconomic operators frequently correspond to \"legal entities\" for regulated processes, but the precise coverage depends on the applicable legal instrument."
                    },
                    {
                        "@language": "en",
                        "@value": "Natural persons can be economic operators; whether they are treated as “legal entities” depends on whether they have a legally recognised registered business identity in the relevant legal context."
                    },
                    {
                        "@language": "en",
                        "@value": "NB: the exact scope of the \"economic operator\" concept depends on the legal instrument (procurement vs market surveillance vs sector laws)."
                    }
                ]
            },
            "term:orderedBroader": {
                "@list": [
                    {
                        "@id": "webuild:concept-41"
                    }
                ]
            },
            "suomi-meta:publicationStatus": {
                "@id": "http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT"
            },
            "suomi-meta:modifier": "5dc030a4-740f-4dde-9548-4e6e797899d8",
            "suomi-meta:creator": "5dc030a4-740f-4dde-9548-4e6e797899d8",
            "skos:related": [
                {
                    "@id": "webuild:concept-109"
                },
                {
                    "@id": "webuild:concept-6006"
                },
                {
                    "@id": "webuild:concept-6005"
                }
            ],
            "@type": "skos:Concept",
            "dcterms:created": {
                "@value": "2025-12-04T12:47:24.424Z",
                "@type": "xsd:dateTime"
            },
            "dcterms:modified": {
                "@value": "2026-03-03T06:05:42.321Z",
                "@type": "xsd:dateTime"
            },
            "dcterms:source": "COM(2025) 838 - Proposal for a Regulation on the establishment of European Business Wallets",
            "skos:broader": {
                "@id": "webuild:concept-41"
            },
            "skos:changeNote": "alternative definitions:\n\"a natural person, legal person or group of such persons, including temporary associations of undertakings, when acting in a commercial or professional capacity for purposes related to their trade, business, craft or profession\"\n\"any natural or legal person or public entity or group of such persons and/or entities, including any temporary association of undertakings, which offers the execution of works and/or a work, the supply of products or the provision of services on the market\"",
            "skos:definition": {
                "@language": "en",
                "@value": "an agent acting in a commercial or professional capacity for purposes related to its trade, business, craft, or profession"
            },
            "skos:inScheme": {
                "@id": "https://iri.suomi.fi/terminology/webuild/"
            },
            "skos:note": [
                {
                    "@language": "en",
                    "@value": "Natural persons can be economic operators; whether they are treated as “legal entities” depends on whether they have a legally recognised registered business identity in the relevant legal context."
                },
                {
                    "@language": "en",
                    "@value": "“Economic operator” is a capacity/role. \n\nThe same underlying entity may or may not be an economic operator depending on context. \n\nEconomic operators frequently correspond to \"legal entities\" for regulated processes, but the precise coverage depends on the applicable legal instrument."
                },
                {
                    "@language": "en",
                    "@value": "NB: the exact scope of the \"economic operator\" concept depends on the legal instrument (procurement vs market surveillance vs sector laws)."
                }
            ],
            "skos:prefLabel": [
                {
                    "@id": "urn:uuid:a53404ff-d71b-40bc-999e-01588fddb37f"
                },
                {
                    "@id": "urn:uuid:b369f9d8-b167-44bd-a5a5-8c72b4b3363b"
                },
                {
                    "@id": "urn:uuid:0fd08ec7-8001-446d-a3a3-aab584f573bf"
                }
            ]
        },
        {
            "@id": "webuild:concept-7",
            "term:orderedRelated": {
                "@list": [
                    {
                        "@id": "webuild:concept-100"
                    },
                    {
                        "@id": "webuild:concept-30"
                    }
                ]
            },
            "term:orderedNote": {
                "@list": [
                    {
                        "@language": "en",
                        "@value": "In the context of business related information, the main identifier for a business entity is usually the \"legal identifier\", which is the identifier given to the business entity when it is registered by a competent authority in a specific jurisdiction."
                    }
                ]
            },
            "term:orderedNarrower": {
                "@list": [
                    {
                        "@id": "webuild:concept-14"
                    }
                ]
            },
            "@type": "skos:Concept",
            "dcterms:created": "2021-12-13T14:42:43Z",
            "dcterms:modified": {
                "@value": "2026-04-14T05:49:04.049Z",
                "@type": "xsd:dateTime"
            },
            "http://purl.org/termed/properties/id": "34a93245-36f6-4b98-a1cc-60fcf66fac99",
            "skos:definition": {
                "@language": "en",
                "@value": "a structured reference that identifies an entity"
            },
            "skos:inScheme": {
                "@id": "https://iri.suomi.fi/terminology/webuild/"
            },
            "skos:narrower": {
                "@id": "webuild:concept-14"
            },
            "skos:note": {
                "@language": "en",
                "@value": "In the context of business related information, the main identifier for a business entity is usually the \"legal identifier\", which is the identifier given to the business entity when it is registered by a competent authority in a specific jurisdiction."
            },
            "skos:prefLabel": [
                {
                    "@id": "urn:uuid:8b376364-58c7-4435-ba1e-bafdcbc4d0fd"
                },
                {
                    "@id": "urn:uuid:4b4b9460-6371-40b3-b360-ed7f5bc67773"
                },
                {
                    "@id": "urn:uuid:34fda745-a8e5-4a35-bb3a-ab297cc30a1f"
                }
            ],
            "skos:related": [
                {
                    "@id": "webuild:concept-100"
                },
                {
                    "@id": "webuild:concept-30"
                }
            ],
            "suomi-meta:creator": "5dc030a4-740f-4dde-9548-4e6e797899d8",
            "suomi-meta:modifier": "5dc030a4-740f-4dde-9548-4e6e797899d8",
            "suomi-meta:publicationStatus": {
                "@id": "http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT"
            }
        },
        {
            "@id": "webuild:concept-110",
            "term:orderedRelated": {
                "@list": [
                    {
                        "@id": "webuild:concept-94"
                    }
                ]
            },
            "term:orderedNote": {
                "@list": [
                    {
                        "@language": "en",
                        "@value": "The EUID consists of the country code, a register identifier and a national registration number. At the moment it is undefined how an EUID would look like for economic operators that are natural persons and other types of economic operators that are not certain types of legal entities mentioned in the BRIS regulation.\n\nThe future EU Business Wallet regulation will designate the European unique identifier (EUID), as established and governed by Directive (EU) 2017/1132, as the unique identifier for European Business Wallet owners, and establishes a similar unique identifier for European Business Wallets owners to whom the European Unique Identifier is not available."
                    }
                ]
            },
            "term:orderedBroader": {
                "@list": [
                    {
                        "@id": "webuild:concept-7"
                    }
                ]
            },
            "suomi-meta:publicationStatus": {
                "@id": "http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT"
            },
            "suomi-meta:modifier": "5dc030a4-740f-4dde-9548-4e6e797899d8",
            "suomi-meta:creator": "5dc030a4-740f-4dde-9548-4e6e797899d8",
            "skos:related": {
                "@id": "webuild:concept-94"
            },
            "skos:prefLabel": {
                "@id": "urn:uuid:391f5ee1-a1b9-4278-8e64-e98b65fd55bd"
            },
            "skos:note": {
                "@language": "en",
                "@value": "The EUID consists of the country code, a register identifier and a national registration number. At the moment it is undefined how an EUID would look like for economic operators that are natural persons and other types of economic operators that are not certain types of legal entities mentioned in the BRIS regulation.\n\nThe future EU Business Wallet regulation will designate the European unique identifier (EUID), as established and governed by Directive (EU) 2017/1132, as the unique identifier for European Business Wallet owners, and establishes a similar unique identifier for European Business Wallets owners to whom the European Unique Identifier is not available."
            },
            "skos:inScheme": {
                "@id": "https://iri.suomi.fi/terminology/webuild/"
            },
            "skos:definition": {
                "@language": "en",
                "@value": "a unique identifier to identify economic operators"
            },
            "skos:broader": {
                "@id": "webuild:concept-7"
            },
            "dcterms:modified": {
                "@value": "2026-01-23T12:41:06.613Z",
                "@type": "xsd:dateTime"
            },
            "dcterms:created": {
                "@value": "2026-01-23T12:19:25.358Z",
                "@type": "xsd:dateTime"
