            },
            "skos-xl:literalForm": {
                "@language": "en",
                "@value": "legal entity status"
            },
            "@type": "skos-xl:Label"
        },
        {
            "@id": "urn:uuid:a3c69f99-3c1b-466e-b3ba-2ac7eb99984d",
            "suomi-meta:publicationStatus": {
                "@id": "http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT"
            },
            "skos-xl:literalForm": {
                "@language": "en",
                "@value": "status"
            },
            "@type": "skos-xl:Label"
        },
        {
            "@id": "urn:uuid:071db069-50b3-4054-a5e4-57bd9b3055c1",
            "suomi-meta:publicationStatus": {
                "@id": "http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT"
            },
            "skos-xl:literalForm": {
                "@language": "en",
                "@value": "company status"
            },
            "@type": "skos-xl:Label"
        },
        {
            "@id": "webuild:companystatus",
            "term:orderedSynonym": {
                "@list": [
                    {
                        "@id": "urn:uuid:a3c69f99-3c1b-466e-b3ba-2ac7eb99984d"
                    },
                    {
                        "@id": "urn:uuid:d4895be1-944d-47a2-a2f3-3f2ded35be95"
                    },
                    {
                        "@id": "urn:uuid:6e96ab9c-2b81-4471-a912-5e5b1a39254b"
                    }
                ]
            },
            "@type": "skos:Concept",
            "dcterms:created": {
                "@value": "2026-02-03T16:01:27.274Z",
                "@type": "xsd:dateTime"
            },
            "dcterms:modified": {
                "@value": "2026-02-03T16:01:52.249Z",
                "@type": "xsd:dateTime"
            },
            "dcterms:source": "https://semiceu.github.io/Core-Business-Vocabulary/releases/2.2.0/#LegalEntity.legalentitystatus",
            "skos:altLabel": [
                {
                    "@id": "urn:uuid:a3c69f99-3c1b-466e-b3ba-2ac7eb99984d"
                },
                {
                    "@id": "urn:uuid:6e96ab9c-2b81-4471-a912-5e5b1a39254b"
                },
                {
                    "@id": "urn:uuid:d4895be1-944d-47a2-a2f3-3f2ded35be95"
                }
            ],
            "skos:definition": {
                "@language": "en",
                "@value": "information about the viability of the current position of the legal entity"
            },
            "skos:inScheme": {
                "@id": "https://iri.suomi.fi/terminology/webuild/"
            },
            "skos:note": {
                "@language": "en",
                "@value": "Recording the status of a company presents the same issues as its type. The terms 'insolvent', 'bankrupt' and 'in receivership,' for example, are likely to mean slightly different things with different legal implications in different jurisdictions. Best practice for recording various other status levels is to use the relevant jurisdiction's terms and to identify the controlled vocabulary used."
            },
            "skos:prefLabel": {
                "@id": "urn:uuid:071db069-50b3-4054-a5e4-57bd9b3055c1"
            },
            "suomi-meta:creator": "5dc030a4-740f-4dde-9548-4e6e797899d8",
            "suomi-meta:modifier": "5dc030a4-740f-4dde-9548-4e6e797899d8",
            "suomi-meta:publicationStatus": {
                "@id": "http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT"
            },
            "term:orderedNote": {
                "@list": [
                    {
                        "@language": "en",
                        "@value": "Recording the status of a company presents the same issues as its type. The terms 'insolvent', 'bankrupt' and 'in receivership,' for example, are likely to mean slightly different things with different legal implications in different jurisdictions. Best practice for recording various other status levels is to use the relevant jurisdiction's terms and to identify the controlled vocabulary used."
                    }
                ]
            },
            "term:orderedSource": {
                "@list": [
                    "https://semiceu.github.io/Core-Business-Vocabulary/releases/2.2.0/#LegalEntity.legalentitystatus"
                ]
            }
        },
        {
            "@id": "urn:uuid:847a0421-d786-4fa4-b5e5-59a139eac626",
            "suomi-meta:publicationStatus": {
                "@id": "http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT"
            },
            "skos-xl:literalForm": {
                "@language": "en",
                "@value": "subscribed capital"
            },
            "@type": "skos-xl:Label"
        },
        {
            "@id": "webuild:subscribedcapital",
            "term:orderedNote": {
                "@list": [
                    {
                        "@language": "en",
                        "@value": "Subscribed capital represents a legally binding commitment of capital participation in a company.\nIt may be fully or partially paid and is recorded in official company registration or statutory documents.\nIt applies primarily to capital-based legal entities."
                    }
                ]
            },
            "term:orderedExample": {
                "@list": [
                    {
                        "@language": "en",
                        "@value": "A private limited company with registered subscribed capital of 25,000 EUR.\nA public limited company with subscribed capital of 100,000 EUR, partially paid."
                    }
                ]
            },
            "suomi-meta:publicationStatus": {
                "@id": "http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT"
            },
            "suomi-meta:modifier": "5dc030a4-740f-4dde-9548-4e6e797899d8",
            "suomi-meta:creator": "5dc030a4-740f-4dde-9548-4e6e797899d8",
            "skos:prefLabel": {
                "@id": "urn:uuid:847a0421-d786-4fa4-b5e5-59a139eac626"
            },
            "skos:note": {
                "@language": "en",
                "@value": "Subscribed capital represents a legally binding commitment of capital participation in a company.\nIt may be fully or partially paid and is recorded in official company registration or statutory documents.\nIt applies primarily to capital-based legal entities."
            },
            "skos:inScheme": {
                "@id": "https://iri.suomi.fi/terminology/webuild/"
            },
            "skos:example": {
                "@language": "en",
                "@value": "A private limited company with registered subscribed capital of 25,000 EUR.\nA public limited company with subscribed capital of 100,000 EUR, partially paid."
            },
            "skos:definition": {
                "@language": "en",
                "@value": "the total monetary amount of capital that shareholders or members have formally committed to contribute to a company under its constitutive documents"
            },
            "dcterms:modified": {
                "@value": "2026-02-17T14:06:02.308Z",
                "@type": "xsd:dateTime"
            },
            "dcterms:created": {
                "@value": "2026-02-03T15:31:29.16Z",
                "@type": "xsd:dateTime"
            },
            "@type": "skos:Concept"
        },
        {
            "@id": "urn:uuid:563f235a-d44a-4fa4-a40e-f5b4c47d8204",
            "suomi-meta:publicationStatus": {
                "@id": "http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT"
            },
            "skos-xl:literalForm": {
                "@language": "en",
                "@value": "registration date"
            },
            "@type": "skos-xl:Label"
        },
        {
            "@id": "urn:uuid:53165e5a-041f-4cf3-bf69-da9e55321c5a",
            "suomi-meta:publicationStatus": {
                "@id": "http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT"
            },
            "skos-xl:literalForm": {
                "@language": "en",
                "@value": "date of registration"
            },
            "@type": "skos-xl:Label"
        },
        {
            "@id": "webuild:dateofregistration",
            "term:orderedSynonym": {
                "@list": [
                    {
                        "@id": "urn:uuid:563f235a-d44a-4fa4-a40e-f5b4c47d8204"
                    }
                ]
            },
            "term:orderedSource": {
                "@list": [
                    "https://semiceu.github.io/Core-Business-Vocabulary/releases/2.2.0/#LegalEntity.registrationdate"
                ]
            },
            "suomi-meta:publicationStatus": {
                "@id": "http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT"
            },
            "suomi-meta:modifier": "5dc030a4-740f-4dde-9548-4e6e797899d8",
            "suomi-meta:creator": "5dc030a4-740f-4dde-9548-4e6e797899d8",
            "skos:prefLabel": {
                "@id": "urn:uuid:53165e5a-041f-4cf3-bf69-da9e55321c5a"
            },
            "skos:inScheme": {
                "@id": "https://iri.suomi.fi/terminology/webuild/"
            },
            "skos:definition": {
                "@language": "en",
                "@value": "the date on which the legal entity has registered in some jurisdiction for regulatory and / or for tax purposes"
            },
            "skos:altLabel": {
                "@id": "urn:uuid:563f235a-d44a-4fa4-a40e-f5b4c47d8204"
            },
            "dcterms:source": "https://semiceu.github.io/Core-Business-Vocabulary/releases/2.2.0/#LegalEntity.registrationdate",
            "dcterms:modified": {
                "@value": "2026-02-03T15:23:40.395Z",
                "@type": "xsd:dateTime"
            },
            "dcterms:created": {
                "@value": "2026-02-03T15:23:40.395Z",
                "@type": "xsd:dateTime"
            },
            "@type": "skos:Concept"
        },
        {
            "@id": "urn:uuid:b75e2235-2097-472c-9122-c426c8a3306f",
            "suomi-meta:publicationStatus": {
                "@id": "http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT"
            },
            "skos-xl:literalForm": {
                "@language": "en",
                "@value": "registered address"
            },
            "@type": "skos-xl:Label"
        },
        {
            "@id": "urn:uuid:6d74117a-7060-4a98-9acb-9274b59cdb8c",
            "suomi-meta:publicationStatus": {
                "@id": "http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT"
            },
            "skos-xl:literalForm": {
                "@language": "en",
                "@value": "legal address"
            },
            "@type": "skos-xl:Label"
        },
        {
            "@id": "webuild:registeredaddress",
            "term:orderedSynonym": {
                "@list": [
                    {
                        "@id": "urn:uuid:6d74117a-7060-4a98-9acb-9274b59cdb8c"
                    }
                ]
            },
            "term:orderedSource": {
                "@list": [
                    "https://semiceu.github.io/Core-Business-Vocabulary/releases/2.2.0/#LegalEntity.registeredaddress"
                ]
            },
            "term:orderedNote": {
                "@list": [
                    {
                        "@language": "en",
                        "@value": "In almost all jurisdictions, Legal Entities must register a public address. This may or may not be the actual address at which the Legal Entity does its business, it is commonly the address of their lawyer or accountant, but it is the address to which formal communications can be sent. The registered address property points to the Address of the Registered Site. This property can be seen as a shorthand for this property path."
                    }
                ]
            },
            "suomi-meta:publicationStatus": {
                "@id": "http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT"
            },
            "suomi-meta:modifier": "5dc030a4-740f-4dde-9548-4e6e797899d8",
            "suomi-meta:creator": "5dc030a4-740f-4dde-9548-4e6e797899d8",
            "skos:prefLabel": {
                "@id": "urn:uuid:b75e2235-2097-472c-9122-c426c8a3306f"
            },
            "skos:note": {
                "@language": "en",
                "@value": "In almost all jurisdictions, Legal Entities must register a public address. This may or may not be the actual address at which the Legal Entity does its business, it is commonly the address of their lawyer or accountant, but it is the address to which formal communications can be sent. The registered address property points to the Address of the Registered Site. This property can be seen as a shorthand for this property path."
            },
            "skos:inScheme": {
                "@id": "https://iri.suomi.fi/terminology/webuild/"
            },
            "skos:definition": {
                "@language": "en",
                "@value": "the address at which the legal entity is legally registered"
            },
            "skos:altLabel": {
                "@id": "urn:uuid:6d74117a-7060-4a98-9acb-9274b59cdb8c"
            },
            "dcterms:source": "https://semiceu.github.io/Core-Business-Vocabulary/releases/2.2.0/#LegalEntity.registeredaddress",
            "dcterms:modified": {
                "@value": "2026-02-03T15:18:48.614Z",
