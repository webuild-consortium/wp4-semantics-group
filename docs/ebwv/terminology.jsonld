                }
            ],
            "http://purl.org/termed/properties/id": "34a93245-36f6-4b98-a1cc-60fcf66fac99",
            "suomi-meta:creator": "5dc030a4-740f-4dde-9548-4e6e797899d8",
            "dcterms:modified": {
                "@value": "2025-12-04T13:44:56.377Z",
                "@type": "xsd:dateTime"
            },
            "skos:narrower": {
                "@id": "webuild:concept-14"
            },
            "skos:inScheme": {
                "@id": "https://iri.suomi.fi/terminology/webuild/"
            },
            "term:orderedNote": {
                "@list": [
                    {
                        "@language": "en",
                        "@value": "In the context of business related information, the main identifier for a business entity is usually the \"legal identifier\", which is the identifier given to the business entity when it is registered by a competent authority in a specific jurisdiction."
                    }
                ]
            },
            "dcterms:created": "2021-12-13T14:42:43Z",
            "term:orderedNarrower": {
