        {
            "@id": "webuild:birthname",
            "term:orderedNote": {
                "@list": [
                    {
                        "@language": "en",
                        "@value": "A birth name is the legally recognised name entered in the civil register at the time of birth.\nIt may later change due to marriage, adoption, gender recognition, legal name change, or other lawful modification."
                    },
                    {
                        "@language": "en",
                        "@value": "A birth name may consist of one or more given names and one or more family names, depending on national naming systems."
                    }
                ]
            },
            "term:orderedBroader": {
                "@list": [
                    {
                        "@id": "webuild:concept-18"
                    }
                ]
            },
            "suomi-meta:publicationStatus": {
                "@id": "http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT"
            },
            "suomi-meta:modifier": "5dc030a4-740f-4dde-9548-4e6e797899d8",
            "suomi-meta:creator": "5dc030a4-740f-4dde-9548-4e6e797899d8",
            "skos:prefLabel": {
                "@id": "urn:uuid:6f7bd3f5-0226-46f2-a7cb-7c18c22d5afc"
            },
            "skos:note": [
                {
                    "@language": "en",
                    "@value": "A birth name may consist of one or more given names and one or more family names, depending on national naming systems."
                },
                {
                    "@language": "en",
                    "@value": "A birth name is the legally recognised name entered in the civil register at the time of birth.\nIt may later change due to marriage, adoption, gender recognition, legal name change, or other lawful modification."
                }
            ],
            "skos:inScheme": {
                "@id": "https://iri.suomi.fi/terminology/webuild/"
            },
            "skos:definition": {
                "@language": "en",
                "@value": "the name assigned to a person at birth and recorded in the official birth registration"
            },
            "skos:broader": {
                "@id": "webuild:concept-18"
            },
            "dcterms:modified": {
                "@value": "2026-02-16T14:30:14.763Z",
                "@type": "xsd:dateTime"
            },
            "dcterms:created": {
                "@value": "2026-02-16T14:30:14.763Z",
                "@type": "xsd:dateTime"
            },
            "@type": "skos:Concept"
        },
        {
            "@id": "urn:uuid:6f7bd3f5-0226-46f2-a7cb-7c18c22d5afc",
            "suomi-meta:publicationStatus": {
                "@id": "http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT"
            },
            "skos-xl:literalForm": {
                "@language": "en",
                "@value": "birth name"
            },
            "@type": "skos-xl:Label"
        },
        {
            "@id": "urn:uuid:6c16487d-78cb-4803-92c4-93b8d35ed9c6",
            "suomi-meta:publicationStatus": {
                "@id": "http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT"
            },
            "skos-xl:literalForm": {
                "@language": "en",
                "@value": "alternative name"
            },
            "@type": "skos-xl:Label"
        },
        {
            "@id": "webuild:alternativename",
            "term:orderedNote": {
                "@list": [
                    {
                        "@language": "en",
                        "@value": "An alternative name may include, for example, a trade name, previous name, alias, pseudonym, commonly used name, or name expressed in another language or script.\nIt does not replace the primary or legal name but exists in parallel as an additional identifier used in specific contexts."
                    }
                ]
            },
            "term:orderedExample": {
                "@list": [
                    {
                        "@language": "en",
                        "@value": "A company’s registered legal name: Nordic Timber Export Oy\nAlternative name: NordTimber (trade name)\n\nA person’s legal name: Aleksandra Nowak\nAlternative name: Aleksandra Kowalska (former name)"
                    }
                ]
            },
            "term:orderedBroader": {
                "@list": [
                    {
                        "@id": "webuild:concept-18"
                    }
                ]
            },
            "suomi-meta:publicationStatus": {
                "@id": "http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT"
            },
            "suomi-meta:modifier": "5dc030a4-740f-4dde-9548-4e6e797899d8",
            "suomi-meta:creator": "5dc030a4-740f-4dde-9548-4e6e797899d8",
            "skos:prefLabel": {
                "@id": "urn:uuid:6c16487d-78cb-4803-92c4-93b8d35ed9c6"
            },
            "skos:note": {
                "@language": "en",
                "@value": "An alternative name may include, for example, a trade name, previous name, alias, pseudonym, commonly used name, or name expressed in another language or script.\nIt does not replace the primary or legal name but exists in parallel as an additional identifier used in specific contexts."
            },
            "skos:inScheme": {
                "@id": "https://iri.suomi.fi/terminology/webuild/"
            },
            "skos:example": {
                "@language": "en",
                "@value": "A company’s registered legal name: Nordic Timber Export Oy\nAlternative name: NordTimber (trade name)\n\nA person’s legal name: Aleksandra Nowak\nAlternative name: Aleksandra Kowalska (former name)"
            },
            "skos:definition": {
                "@language": "en",
                "@value": "a name by which a person, organisation, or other identified entity is known in addition to its primary or legally registered name"
            },
            "skos:broader": {
                "@id": "webuild:concept-18"
            },
            "dcterms:modified": {
                "@value": "2026-02-16T14:28:16.846Z",
                "@type": "xsd:dateTime"
            },
            "dcterms:created": {
                "@value": "2026-02-16T14:28:16.846Z",
                "@type": "xsd:dateTime"
            },
            "@type": "skos:Concept"
        },
        {
            "@id": "urn:uuid:9f364117-46ae-4e12-b887-ed617d30edfa",
            "suomi-meta:publicationStatus": {
                "@id": "http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT"
            },
            "skos-xl:literalForm": {
                "@language": "en",
                "@value": "address area"
            },
            "@type": "skos-xl:Label"
        },
        {
            "@id": "webuild:addressarea",
            "term:orderedNote": {
                "@list": [
                    {
                        "@language": "en",
                        "@value": "This would typically be part of a city, a neighbourhood or village, e.g. the area Stenstaden in the city of Sundsvall (SE) or Kreuzberg in the city of Berlin (DE). Address area is not an administrative unit."
                    }
                ]
            },
            "suomi-meta:publicationStatus": {
                "@id": "http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT"
            },
            "suomi-meta:modifier": "5dc030a4-740f-4dde-9548-4e6e797899d8",
            "suomi-meta:creator": "5dc030a4-740f-4dde-9548-4e6e797899d8",
            "skos:prefLabel": {
                "@id": "urn:uuid:9f364117-46ae-4e12-b887-ed617d30edfa"
            },
            "skos:note": {
                "@language": "en",
                "@value": "This would typically be part of a city, a neighbourhood or village, e.g. the area Stenstaden in the city of Sundsvall (SE) or Kreuzberg in the city of Berlin (DE). Address area is not an administrative unit."
            },
            "skos:inScheme": {
                "@id": "https://iri.suomi.fi/terminology/webuild/"
            },
            "skos:definition": {
                "@language": "en",
                "@value": "the name of a geographic area that groups addresses"
            },
            "dcterms:modified": {
                "@value": "2026-02-16T09:52:42.366Z",
                "@type": "xsd:dateTime"
            },
            "dcterms:created": {
                "@value": "2026-02-16T09:51:14.436Z",
                "@type": "xsd:dateTime"
            },
            "@type": "skos:Concept"
        },
        {
            "@id": "webuild:adminUnitL1",
            "term:orderedNote": {
                "@list": [
                    {
                        "@language": "en",
                        "@value": "Best practice is to use the ISO 3166-1 code but if this is inappropriate for the context, country names should be provided in a consistent manner to reduce ambiguity. For example, either write 'France' or 'FRA' consistently throughout the dataset and avoid mixing the two. The Country controlled vocabulary from the Publications Office can be reused for this."
                    }
                ]
            },
            "suomi-meta:publicationStatus": {
                "@id": "http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT"
            },
            "suomi-meta:modifier": "5dc030a4-740f-4dde-9548-4e6e797899d8",
            "suomi-meta:creator": "5dc030a4-740f-4dde-9548-4e6e797899d8",
            "skos:prefLabel": {
                "@id": "urn:uuid:019632ce-2305-44a9-882c-19e924ea43db"
            },
            "skos:note": {
                "@language": "en",
                "@value": "Best practice is to use the ISO 3166-1 code but if this is inappropriate for the context, country names should be provided in a consistent manner to reduce ambiguity. For example, either write 'France' or 'FRA' consistently throughout the dataset and avoid mixing the two. The Country controlled vocabulary from the Publications Office can be reused for this."
            },
            "skos:inScheme": {
                "@id": "https://iri.suomi.fi/terminology/webuild/"
            },
            "skos:definition": {
                "@language": "en",
                "@value": "the name of the uppermost level of the address, almost always a country"
            },
            "dcterms:modified": {
                "@value": "2026-02-16T09:45:53.956Z",
                "@type": "xsd:dateTime"
            },
            "dcterms:created": {
                "@value": "2026-02-16T09:45:53.956Z",
                "@type": "xsd:dateTime"
            },
            "@type": "skos:Concept"
        },
        {
            "@id": "urn:uuid:019632ce-2305-44a9-882c-19e924ea43db",
            "suomi-meta:publicationStatus": {
                "@id": "http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT"
            },
            "skos-xl:literalForm": {
                "@language": "en",
                "@value": "administrative unit level 1"
            },
            "@type": "skos-xl:Label"
        },
        {
            "@id": "urn:uuid:bbcad48c-8f22-47e2-a7d1-fda424b1120b",
            "suomi-meta:publicationStatus": {
                "@id": "http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT"
            },
            "skos-xl:literalForm": {
                "@language": "en",
                "@value": "administrative unit level 2"
            },
            "@type": "skos-xl:Label"
        },
        {
            "@id": "webuild:adminUnitL2",
            "suomi-meta:publicationStatus": {
                "@id": "http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT"
            },
            "suomi-meta:modifier": "5dc030a4-740f-4dde-9548-4e6e797899d8",
            "suomi-meta:creator": "5dc030a4-740f-4dde-9548-4e6e797899d8",
            "skos:prefLabel": {
                "@id": "urn:uuid:bbcad48c-8f22-47e2-a7d1-fda424b1120b"
            },
            "skos:inScheme": {
                "@id": "https://iri.suomi.fi/terminology/webuild/"
            },
            "skos:definition": {
                "@language": "en",
                "@value": "The name of a secondary level/region of the address, usually a county, state or other such area that typically encompasses several localities."
            },
            "dcterms:modified": {
                "@value": "2026-02-16T09:43:22.551Z",
