            },
            "term:orderedNote": {
                "@list": [
                    {
                        "@language": "en",
                        "@value": "EU Core Business Vocabulary definition for \"legal identifier\" = The unambiguous structured reference assigned to the Legal Entity by the legal authority that registered it."
                    }
                ]
            },
            "term:orderedBroader": {
                "@list": [
                    {
                        "@id": "webuild:concept-7"
                    }
                ]
            },
            "@type": "skos:Concept",
