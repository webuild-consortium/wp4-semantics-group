            "skos:definition": {
                "@language": "en",
                "@value": "a rule that defines which agent(s) can act on behalf of another agent"
            },
            "skos:inScheme": {
                "@id": "https://iri.suomi.fi/terminology/webuild/"
            },
            "skos:narrower": [
                {
                    "@id": "webuild:concept-83"
                },
                {
                    "@id": "webuild:concept-84"
                },
                {
                    "@id": "webuild:concept-82"
                },
                {
                    "@id": "webuild:concept-81"
                },
                {
                    "@id": "webuild:concept-80"
                }
            ],
            "skos:note": {
                "@language": "en",
                "@value": "A representation rule can express that a person in a certain position in a company (agent) can represent the company alone or jointly together with others or simply state that a specific person has been granted this right without being previously affiliated to the company (agent)."
            },
            "skos:prefLabel": {
                "@id": "urn:uuid:d58d7394-236a-486c-922a-a085f59c4bf5"
            },
