            "@type": "skos:Concept"
        },
        {
            "@id": "urn:uuid:37e77d0d-ad8c-438a-8b3a-8683e2a4cd85",
            "suomi-meta:publicationStatus": {
                "@id": "http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT"
            },
            "skos-xl:literalForm": {
                "@language": "en",
                "@value": "Legal Person Identification Data"
            },
            "@type": "skos-xl:Label"
        },
        {
            "@id": "webuild:legalPersonIdentificationData",
            "suomi-meta:publicationStatus": {
                "@id": "http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT"
            },
            "suomi-meta:modifier": "f7193db9-3c93-4d56-9d57-d5c3f1132fe9",
            "suomi-meta:creator": "f7193db9-3c93-4d56-9d57-d5c3f1132fe9",
            "skos:prefLabel": {
                "@id": "urn:uuid:37e77d0d-ad8c-438a-8b3a-8683e2a4cd85"
            },
            "skos:inScheme": {
                "@id": "https://iri.suomi.fi/terminology/webuild/"
            },
            "skos:definition": {
                "@language": "en",
                "@value": "a set of data that enables the establishment of the identity of a legal person and that is issued by a LPID provider. The LPID is the credential subject of an LPID-Credential. A LPID credential allows a legal person to authenticate against a relying party."
            },
            "dcterms:modified": {
                "@value": "2026-01-12T16:28:32.455Z",
                "@type": "xsd:dateTime"
            },
            "dcterms:created": {
                "@value": "2026-01-12T16:28:32.455Z",
                "@type": "xsd:dateTime"
            },
            "@type": "skos:Concept"
        },
        {
            "@id": "webuild:concept-41",
            "term:orderedNote": {
                "@list": [
                    {
                        "@language": "en",
                        "@value": "The term agent represents an upper class / broader concept that would encompass both natural persons, sole traders, organizations, registered organizations, legal entities and others that are capable of actions like \"doing business."
                    },
                    {
                        "@language": "en",
                        "@value": "Umbrella concept for actors that can act/decide/commit in processes.\nIncludes natural persons and organisations (and therefore legal persons).\nIf you later want “software agent,” introduce it explicitly; do not imply it here unless your use cases require it."
                    },
                    {
                        "@language": "en",
                        "@value": "“Agent” is the broad umbrella concept covering actors that can participate in business/legal processes (e.g., natural persons, organisations, legal persons, legal entities). If you intend “agent” to include software agents, state that explicitly; otherwise keep it socio-legal and process-oriented."
                    }
                ]
            },
            "term:orderedNarrower": {
                "@list": [
                    {
                        "@id": "webuild:concept-1"
                    },
                    {
                        "@id": "webuild:concept-6005"
                    },
                    {
                        "@id": "webuild:concept-94"
                    },
                    {
                        "@id": "webuild:concept-6006"
                    }
                ]
            },
            "term:orderedBroader": {
                "@list": [
                    {
                        "@id": "webuild:concept-95"
                    }
                ]
            },
            "suomi-meta:publicationStatus": {
                "@id": "http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT"
            },
            "suomi-meta:modifier": "5dc030a4-740f-4dde-9548-4e6e797899d8",
            "suomi-meta:creator": "5dc030a4-740f-4dde-9548-4e6e797899d8",
            "@type": "skos:Concept",
            "dcterms:created": "2022-02-07T08:20:41Z",
            "dcterms:modified": {
                "@value": "2026-01-23T14:30:39.71Z",
                "@type": "xsd:dateTime"
            },
            "http://purl.org/termed/properties/id": "6364b7df-d2c8-4f56-ac4d-f53141e3d0df",
            "skos:broader": {
                "@id": "webuild:concept-95"
            },
            "skos:changeNote": "alternative definitions:\n\"an entity that can perform actions and participate in interactions (including legal, organisational, or business processes)\"\n\"an entity that is able to carry out actions\"",
            "skos:definition": {
                "@language": "en",
                "@value": "an entity that can perform actions or be treated as acting within a process"
            },
            "skos:inScheme": {
                "@id": "https://iri.suomi.fi/terminology/webuild/"
            },
            "skos:narrower": [
                {
                    "@id": "webuild:concept-6006"
                },
                {
                    "@id": "webuild:concept-94"
                },
                {
                    "@id": "webuild:concept-1"
                },
                {
                    "@id": "webuild:concept-6005"
                }
            ],
            "skos:note": [
                {
                    "@language": "en",
                    "@value": "The term agent represents an upper class / broader concept that would encompass both natural persons, sole traders, organizations, registered organizations, legal entities and others that are capable of actions like \"doing business."
                },
                {
                    "@language": "en",
                    "@value": "Umbrella concept for actors that can act/decide/commit in processes.\nIncludes natural persons and organisations (and therefore legal persons).\nIf you later want “software agent,” introduce it explicitly; do not imply it here unless your use cases require it."
                },
                {
                    "@language": "en",
                    "@value": "“Agent” is the broad umbrella concept covering actors that can participate in business/legal processes (e.g., natural persons, organisations, legal persons, legal entities). If you intend “agent” to include software agents, state that explicitly; otherwise keep it socio-legal and process-oriented."
                }
            ],
            "skos:prefLabel": {
                "@id": "urn:uuid:14b229de-4ba0-48eb-9f7e-ff15a33d4ef4"
            }
