        {
            "@id": "webuild:concept-7",
            "skos:prefLabel": [
                {
                    "@id": "urn:uuid:8d77b5c9-52d0-42ce-accb-41a3f5927499"
                },
                {
                    "@id": "urn:uuid:683e386f-12d9-4013-b935-7d0365a9515b"
                },
                {
