        {
            "@id": "webuild:concept-79",
            "term:orderedNote": {
                "@list": [
                    {
                        "@language": "en",
                        "@value": "Delegable means that something is able to be assigned or transferred to another agent, typically referring to duties, powers, or responsibilities."
                    }
                ]
            },
            "suomi-meta:publicationStatus": {
                "@id": "http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT"
            },
            "suomi-meta:modifier": "5dc030a4-740f-4dde-9548-4e6e797899d8",
            "suomi-meta:creator": "5dc030a4-740f-4dde-9548-4e6e797899d8",
            "skos:prefLabel": {
                "@id": "urn:uuid:94a05e3a-97dd-432e-8e00-2716b69ef045"
            },
            "skos:note": {
                "@language": "en",
