            },
            "skos-xl:literalForm": {
                "@language": "en",
                "@value": "account provider"
            },
            "@type": "skos-xl:Label"
        },
        {
            "@id": "urn:uuid:2958dd8a-5ed7-4da4-adf0-4420dcba1438",
            "suomi-meta:publicationStatus": {
                "@id": "http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT"
            },
            "skos-xl:literalForm": {
                "@language": "en",
                "@value": "service provider"
            },
            "@type": "skos-xl:Label"
        },
        {
            "@id": "webuild:provider",
            "term:orderedSynonym": {
                "@list": [
                    {
                        "@id": "urn:uuid:2958dd8a-5ed7-4da4-adf0-4420dcba1438"
                    },
                    {
                        "@id": "urn:uuid:25b2a89d-d6bb-4699-a181-177427e791b8"
                    },
                    {
                        "@id": "urn:uuid:f2bdb766-80ff-4054-9b87-62473b764aab"
                    }
                ]
            },
            "term:orderedNote": {
                "@list": [
                    {
                        "@language": "en",
                        "@value": "In the EBWV context, and especially in relation to bank accounts or similar services, provider denotes the organisation or other agent that makes the service available to a customer, account holder, user or beneficiary. For a bank account, the provider is typically the bank, payment institution, electronic money institution or other regulated financial service provider that maintains or offers the account. The concept should be distinguished from the account holder, owner, user, beneficiary, intermediary and issuer of a credential. In regulated contexts, a more precise subtype such as payment service provider, account servicing payment service provider, credit institution or electronic money institution should be used where available."
                    }
                ]
            },
            "suomi-meta:publicationStatus": {
                "@id": "http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT"
            },
            "suomi-meta:modifier": "5dc030a4-740f-4dde-9548-4e6e797899d8",
            "suomi-meta:creator": "5dc030a4-740f-4dde-9548-4e6e797899d8",
            "skos:prefLabel": {
                "@id": "urn:uuid:62080bc2-4e07-4bb0-980e-385371867e61"
            },
            "skos:note": {
                "@language": "en",
                "@value": "In the EBWV context, and especially in relation to bank accounts or similar services, provider denotes the organisation or other agent that makes the service available to a customer, account holder, user or beneficiary. For a bank account, the provider is typically the bank, payment institution, electronic money institution or other regulated financial service provider that maintains or offers the account. The concept should be distinguished from the account holder, owner, user, beneficiary, intermediary and issuer of a credential. In regulated contexts, a more precise subtype such as payment service provider, account servicing payment service provider, credit institution or electronic money institution should be used where available."
            },
            "skos:inScheme": {
                "@id": "https://iri.suomi.fi/terminology/webuild/"
            },
            "skos:definition": {
                "@language": "en",
                "@value": "an agent that offers, supplies or makes available a service, account, facility or other capability to another party"
            },
            "skos:altLabel": [
                {
                    "@id": "urn:uuid:2958dd8a-5ed7-4da4-adf0-4420dcba1438"
