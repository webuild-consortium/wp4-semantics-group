            "skos:inScheme": {
                "@id": "https://iri.suomi.fi/terminology/webuild/"
            },
            "skos:definition": {
                "@language": "en",
                "@value": "one of the equal parts into which a legal entity's capital is divided, entitling the holder to a proportion of the profits and a right to vote in shareholder meetings"
            },
            "http://purl.org/termed/properties/id": "83946e4c-cb5f-4572-b14a-d82da5ddf923",
