            "@id": "urn:uuid:ab4596a9-c0b1-4217-96b8-84a37c80c6de",
            "suomi-meta:publicationStatus": {
                "@id": "http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT"
            },
            "skos-xl:literalForm": {
                "@language": "en",
                "@value": "workplace"
            },
            "@type": "skos-xl:Label"
        },
        {
            "@id": "webuild:placeofwork",
            "term:orderedSynonym": {
                "@list": [
                    {
                        "@id": "urn:uuid:ab4596a9-c0b1-4217-96b8-84a37c80c6de"
                    },
                    {
                        "@id": "urn:uuid:974c0a4a-840a-458f-971b-8ff4c98eb2d7"
                    },
                    {
                        "@id": "urn:uuid:6e3c6430-a1df-4998-8eff-4c20826bc035"
                    },
                    {
                        "@id": "urn:uuid:d936318b-ae72-4c8b-8486-270260979c68"
                    }
                ]
            },
            "term:orderedNote": {
                "@list": [
                    {
                        "@language": "en",
                        "@value": "In the Posted Worker Notification context, place of work denotes the location in the host country where the posted worker will carry out the posted work. It may be a construction site, office, factory, vessel, service location, client premises, branch, establishment or another identifiable work site. The concept should be distinguished from the worker’s domicile or residence, the employer’s registered address, the host entity’s registered address, and the administrative address used for correspondence. Where the work is performed at several locations, the notification may need to list multiple places of work or describe the area or route of work."
                    }
                ]
            },
            "@type": "skos:Concept",
            "dcterms:created": {
                "@value": "2026-04-28T14:44:57.898Z",
                "@type": "xsd:dateTime"
            },
            "dcterms:modified": {
                "@value": "2026-04-28T14:44:57.898Z",
                "@type": "xsd:dateTime"
            },
            "skos:altLabel": [
                {
                    "@id": "urn:uuid:d936318b-ae72-4c8b-8486-270260979c68"
                },
                {
                    "@id": "urn:uuid:6e3c6430-a1df-4998-8eff-4c20826bc035"
                },
                {
                    "@id": "urn:uuid:974c0a4a-840a-458f-971b-8ff4c98eb2d7"
                },
                {
                    "@id": "urn:uuid:ab4596a9-c0b1-4217-96b8-84a37c80c6de"
                }
            ],
            "skos:definition": {
                "@language": "en",
                "@value": "the location where a worker performs, is expected to perform, or is assigned to perform work during an employment, posting or work assignment"
            },
            "skos:example": {
                "@language": "en",
                "@value": "A Posted Worker Notification states that the worker’s place of work is a construction site operated by the host entity in Antwerp, Belgium."
            },
            "skos:inScheme": {
                "@id": "https://iri.suomi.fi/terminology/webuild/"
            },
            "skos:note": {
                "@language": "en",
                "@value": "In the Posted Worker Notification context, place of work denotes the location in the host country where the posted worker will carry out the posted work. It may be a construction site, office, factory, vessel, service location, client premises, branch, establishment or another identifiable work site. The concept should be distinguished from the worker’s domicile or residence, the employer’s registered address, the host entity’s registered address, and the administrative address used for correspondence. Where the work is performed at several locations, the notification may need to list multiple places of work or describe the area or route of work."
            },
            "skos:prefLabel": {
                "@id": "urn:uuid:a22da038-f911-47fc-95b7-79be7d7ef8ea"
            },
            "suomi-meta:creator": "5dc030a4-740f-4dde-9548-4e6e797899d8",
            "suomi-meta:modifier": "5dc030a4-740f-4dde-9548-4e6e797899d8",
            "suomi-meta:publicationStatus": {
                "@id": "http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT"
            },
            "term:orderedExample": {
                "@list": [
                    {
                        "@language": "en",
                        "@value": "A Posted Worker Notification states that the worker’s place of work is a construction site operated by the host entity in Antwerp, Belgium."
                    }
                ]
            }
        },
        {
            "@id": "urn:uuid:a22da038-f911-47fc-95b7-79be7d7ef8ea",
            "suomi-meta:publicationStatus": {
