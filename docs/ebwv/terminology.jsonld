                "@value": "proprietor"
            },
            "@type": "skos-xl:Label"
        },
        {
            "@id": "webuild:owner",
            "term:orderedSynonym": {
                "@list": [
                    {
                        "@id": "urn:uuid:546286f2-b1bb-4171-8c5b-e63e5e34194b"
                    },
                    {
                        "@id": "urn:uuid:16dd4abb-94eb-49ee-a6d0-12d2212cb748"
                    },
                    {
                        "@id": "urn:uuid:435db1fa-57ee-4415-9024-3330288dc35e"
                    },
                    {
                        "@id": "urn:uuid:7099ac3e-8950-41b9-88b8-5e6733d26d39"
                    }
                ]
            },
            "term:orderedNote": {
                "@list": [
                    {
                        "@language": "en",
                        "@value": "In the EBWV context, owner should be used for the party that is legally or administratively recognised as owning something. The owned object may be tangible, intangible, digital, financial or organisational, such as a business, vehicle, bank account, real estate asset, wallet, credential, product or intellectual property right. The concept should be distinguished from holder, controller, user, possessor, custodian, operator, beneficial owner and legal representative. In particular, an owner may not be the same party as the person using, controlling, representing or holding the object."
                    }
                ]
            },
            "suomi-meta:publicationStatus": {
                "@id": "http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT"
            },
            "suomi-meta:modifier": "5dc030a4-740f-4dde-9548-4e6e797899d8",
            "suomi-meta:creator": "5dc030a4-740f-4dde-9548-4e6e797899d8",
            "skos:prefLabel": {
                "@id": "urn:uuid:c0fc6aa7-31b6-44c7-afab-b23e746820b1"
            },
            "skos:note": {
                "@language": "en",
                "@value": "In the EBWV context, owner should be used for the party that is legally or administratively recognised as owning something. The owned object may be tangible, intangible, digital, financial or organisational, such as a business, vehicle, bank account, real estate asset, wallet, credential, product or intellectual property right. The concept should be distinguished from holder, controller, user, possessor, custodian, operator, beneficial owner and legal representative. In particular, an owner may not be the same party as the person using, controlling, representing or holding the object."
            },
            "skos:inScheme": {
                "@id": "https://iri.suomi.fi/terminology/webuild/"
            },
            "skos:definition": {
                "@language": "en",
                "@value": "an agent that holds an ownership right, title or legally recognised control over an asset, resource, business entity, credential, account, property or other object"
            },
            "skos:altLabel": [
                {
                    "@id": "urn:uuid:546286f2-b1bb-4171-8c5b-e63e5e34194b"
                },
                {
                    "@id": "urn:uuid:16dd4abb-94eb-49ee-a6d0-12d2212cb748"
                },
                {
                    "@id": "urn:uuid:435db1fa-57ee-4415-9024-3330288dc35e"
                },
                {
                    "@id": "urn:uuid:7099ac3e-8950-41b9-88b8-5e6733d26d39"
                }
            ],
            "dcterms:modified": {
                "@value": "2026-04-28T14:33:54.697Z",
                "@type": "xsd:dateTime"
            },
            "dcterms:created": {
                "@value": "2026-04-28T14:33:54.697Z",
                "@type": "xsd:dateTime"
            },
            "@type": "skos:Concept"
        },
        {
            "@id": "urn:uuid:c0fc6aa7-31b6-44c7-afab-b23e746820b1",
            "suomi-meta:publicationStatus": {
                "@id": "http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT"
            },
            "skos-xl:literalForm": {
                "@language": "en",
                "@value": "owner"
            },
            "@type": "skos-xl:Label"
        },
        {
