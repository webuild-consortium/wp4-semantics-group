            },
            "dcterms:modified": {
                "@value": "2026-01-13T09:17:16.113Z",
                "@type": "xsd:dateTime"
            },
            "skos:altLabel": [
                {
                    "@id": "urn:uuid:1f6a0439-2aaf-401c-acce-82d80cd4a869"
                },
                {
                    "@id": "urn:uuid:b72cb510-c556-4dbc-9af8-17e47defc04b"
                },
                {
                    "@id": "urn:uuid:3c6fdbcc-2a60-47e4-a155-ed62be2df256"
                },
                {
                    "@id": "urn:uuid:844ee5cb-d693-40d7-a4db-ecef6f1502f3"
                },
                {
                    "@id": "urn:uuid:e7478fac-443d-4cd2-8bd6-5674f1308dcb"
                }
            ],
            "skos:definition": {
                "@language": "en",
                "@value": "the terms under which a mandator grants or delegates authority or power to a mandatee"
            },
            "skos:inScheme": {
                "@id": "https://iri.suomi.fi/terminology/webuild/"
            },
            "skos:prefLabel": {
                "@id": "urn:uuid:37235745-c587-4090-87b2-e554329f87a1"
            },
            "skos:related": [
                {
                    "@id": "webuild:concept-77"
                },
                {
                    "@id": "webuild:concept-76"
                }
            ],
