                    }
                ]
            }
        },
        {
            "@id": "webuild:concept-98",
            "term:orderedRelated": {
                "@list": [
                    {
                        "@id": "webuild:concept-94"
                    },
                    {
                        "@id": "webuild:concept-96"
                    },
                    {
                        "@id": "webuild:concept-100"
                    },
                    {
                        "@id": "webuild:concept-6006"
                    }
                ]
            },
            "term:orderedNote": {
                "@list": [
                    {
                        "@language": "en",
                        "@value": "It is important to notice that this concept does not refer to the ultimate beneficial owner of the economic operator but only to the economic operator entity that controls the instance of the wallet."
                    }
                ]
            },
            "@type": "skos:Concept",
            "dcterms:created": {
                "@value": "2025-12-04T12:57:50.496Z",
                "@type": "xsd:dateTime"
            },
            "dcterms:modified": {
                "@value": "2026-01-23T15:10:44.566Z",
                "@type": "xsd:dateTime"
            },
            "skos:broader": {
                "@id": "webuild:concept-6006"
            },
            "skos:definition": {
                "@language": "en",
                "@value": "an economic operator or public sector body that owns, or has a right of use of, a European Business Wallet under the regulation"
            },
            "skos:inScheme": {
                "@id": "https://iri.suomi.fi/terminology/webuild/"
            },
            "skos:note": {
                "@language": "en",
                "@value": "It is important to notice that this concept does not refer to the ultimate beneficial owner of the economic operator but only to the economic operator entity that controls the instance of the wallet."
            },
            "skos:prefLabel": {
                "@id": "urn:uuid:e734dc6d-3e88-41e8-8b77-620971460acc"
            },
