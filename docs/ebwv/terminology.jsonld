                    {
                        "@id": "urn:uuid:0464a7f5-01b9-45ca-b074-fa40935ac4e5"
                    },
                    {
                        "@id": "urn:uuid:d5069316-92ca-4ae0-a479-6ad48ae2db1c"
                    }
                ]
            },
            "term:orderedNote": {
                "@list": [
                    {
                        "@language": "en",
                        "@value": "In the EU Company Certificate context, legal representative should denote a person or entity whose authority to represent the company is recorded or otherwise recognised for company-law purposes. The concept is especially relevant because the EU Company Certificate is intended to provide reliable cross-border evidence of company information, including details on persons representing the company. The concept should be distinguished from a general contact person, beneficial owner, employee, agent, or proxy. A proxy or authorised agent may represent the company for a specific transaction or procedure, but a legal representative normally has a representation role grounded in company law, the company register, articles of association, or another formal legal source. The EU digital company-law reform describes the EU Company Certificate as evidence of incorporation and company information, including details on persons representing the company."
                    }
                ]
            },
            "suomi-meta:publicationStatus": {
                "@id": "http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT"
            },
            "suomi-meta:modifier": "5dc030a4-740f-4dde-9548-4e6e797899d8",
            "suomi-meta:creator": "5dc030a4-740f-4dde-9548-4e6e797899d8",
            "skos:prefLabel": {
                "@id": "urn:uuid:bdb35d97-37bb-40b9-983a-df1b2f8e3d0c"
            },
            "skos:note": {
                "@language": "en",
                "@value": "In the EU Company Certificate context, legal representative should denote a person or entity whose authority to represent the company is recorded or otherwise recognised for company-law purposes. The concept is especially relevant because the EU Company Certificate is intended to provide reliable cross-border evidence of company information, including details on persons representing the company. The concept should be distinguished from a general contact person, beneficial owner, employee, agent, or proxy. A proxy or authorised agent may represent the company for a specific transaction or procedure, but a legal representative normally has a representation role grounded in company law, the company register, articles of association, or another formal legal source. The EU digital company-law reform describes the EU Company Certificate as evidence of incorporation and company information, including details on persons representing the company."
            },
            "skos:inScheme": {
                "@id": "https://iri.suomi.fi/terminology/webuild/"
            },
            "skos:definition": {
                "@language": "en",
                "@value": "a natural person or [economic operator] that has authority, under law, the company’s statutes, a register entry or another recognised legal basis, to represent a [company] in dealings with third parties, authorities or courts"
            },
