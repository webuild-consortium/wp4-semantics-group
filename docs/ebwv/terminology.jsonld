            },
            "skos-xl:literalForm": {
                "@language": "en",
                "@value": "asset owner"
            },
            "@type": "skos-xl:Label"
        },
        {
            "@id": "urn:uuid:435db1fa-57ee-4415-9024-3330288dc35e",
            "suomi-meta:publicationStatus": {
                "@id": "http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT"
            },
            "skos-xl:literalForm": {
                "@language": "en",
                "@value": "entity with ownership"
            },
            "@type": "skos-xl:Label"
        },
        {
            "@id": "urn:uuid:16dd4abb-94eb-49ee-a6d0-12d2212cb748",
            "suomi-meta:publicationStatus": {
                "@id": "http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT"
            },
            "skos-xl:literalForm": {
                "@language": "en",
                "@value": "holder"
            },
            "@type": "skos-xl:Label"
        },
        {
            "@id": "urn:uuid:546286f2-b1bb-4171-8c5b-e63e5e34194b",
            "suomi-meta:publicationStatus": {
                "@id": "http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT"
            },
            "skos-xl:literalForm": {
