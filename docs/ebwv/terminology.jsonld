        {
            "@id": "urn:uuid:f1412668-6642-4b34-9a8f-dc7e358522a0",
            "suomi-meta:publicationStatus": {
                "@id": "http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT"
            },
            "skos-xl:literalForm": {
                "@language": "en",
                "@value": "local unit"
            },
            "@type": "skos-xl:Label"
        },
        {
            "@id": "webuild:localunit",
            "term:orderedSynonym": {
                "@list": [
                    {
                        "@id": "urn:uuid:f24baf81-de6c-4b42-b8be-39899b601321"
                    },
                    {
                        "@id": "urn:uuid:61c6c603-f0d3-465c-b98b-7de9f47ea6e4"
                    }
                ]
            },
            "term:orderedRelated": {
                "@list": [
                    {
                        "@id": "webuild:site"
                    }
                ]
            },
            "term:orderedNote": {
                "@list": [
                    {
                        "@language": "en",
                        "@value": "Use as the general EU-wide concept for a geographically delimited operating unit of an enterprise (economic operator). This is the preferred broad concept in a Eurostat-oriented model."
                    },
                    {
                        "@language": "en",
                        "@value": "Alternatively:\nUse as the broad EU statistical concept for a geographically delimited operating unit of an enterprise. A local unit may contain more than one activity, may consist only of ancillary activities, and may in some cases be the registered office even if nobody works there."
                    }
                ]
            },
            "@type": "skos:Concept",
            "dcterms:created": {
                "@value": "2026-04-13T08:57:42.11Z",
                "@type": "xsd:dateTime"
            },
            "dcterms:modified": {
                "@value": "2026-04-14T05:30:57.466Z",
                "@type": "xsd:dateTime"
            },
            "skos:altLabel": [
                {
                    "@id": "urn:uuid:61c6c603-f0d3-465c-b98b-7de9f47ea6e4"
                },
                {
                    "@id": "urn:uuid:f24baf81-de6c-4b42-b8be-39899b601321"
                }
            ],
            "skos:definition": {
                "@language": "en",
                "@value": "an enterprise or part of an enterprise situated in a geographically identified place, from or at which economic activity is carried out and for which one or more persons work\n\nOR\n\nan enterprise or part thereof situated in a geographically identified place, from or at which economic activity is carried out"
            },
            "skos:inScheme": {
                "@id": "https://iri.suomi.fi/terminology/webuild/"
            },
            "skos:narrower": {
                "@id": "webuild:establishment"
            },
            "skos:note": [
                {
                    "@language": "en",
                    "@value": "Use as the general EU-wide concept for a geographically delimited operating unit of an enterprise (economic operator). This is the preferred broad concept in a Eurostat-oriented model."
                },
                {
                    "@language": "en",
                    "@value": "Alternatively:\nUse as the broad EU statistical concept for a geographically delimited operating unit of an enterprise. A local unit may contain more than one activity, may consist only of ancillary activities, and may in some cases be the registered office even if nobody works there."
                }
            ],
            "skos:prefLabel": {
                "@id": "urn:uuid:f1412668-6642-4b34-9a8f-dc7e358522a0"
            },
            "skos:related": {
                "@id": "webuild:site"
            },
            "suomi-meta:creator": "5dc030a4-740f-4dde-9548-4e6e797899d8",
            "suomi-meta:modifier": "5dc030a4-740f-4dde-9548-4e6e797899d8",
            "suomi-meta:publicationStatus": {
                "@id": "http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT"
            },
            "term:orderedNarrower": {
                "@list": [
                    {
                        "@id": "webuild:establishment"
                    }
                ]
            }
        },
        {
            "@id": "webuild:establishment",
            "term:orderedSynonym": {
                "@list": [
                    {
                        "@id": "urn:uuid:c4ecbb22-137e-47e3-a563-41e376461896"
                    },
                    {
                        "@id": "urn:uuid:2c2e6807-7dc1-4f71-8c41-75f65180e8b2"
                    },
                    {
                        "@id": "urn:uuid:2d417a04-4f47-48ba-87bd-5f8ec691cb2a"
                    }
                ]
            },
            "term:orderedRelated": {
                "@list": [
                    {
                        "@id": "webuild:site"
                    }
                ]
            },
            "term:orderedNote": {
                "@list": [
                    {
                        "@language": "en",
                        "@value": "Use when the concept is not merely a local operating presence but a production-oriented local unit characterised by a principal activity. In Eurostat and related statistical contexts this corresponds to the local kind-of-activity unit."
                    },
                    {
                        "@language": "en",
                        "@value": "Alternatively:\nUse when the intended concept is the more specific production-oriented unit used for industry and national accounts purposes, rather than the broader local unit."
                    }
                ]
            },
            "term:orderedBroader": {
                "@list": [
                    {
                        "@id": "webuild:localunit"
                    }
                ]
            },
            "@type": "skos:Concept",
            "dcterms:created": {
                "@value": "2026-04-13T09:00:06.166Z",
                "@type": "xsd:dateTime"
            },
            "dcterms:modified": {
                "@value": "2026-04-14T05:34:09.427Z",
                "@type": "xsd:dateTime"
            },
            "skos:altLabel": [
                {
                    "@id": "urn:uuid:2d417a04-4f47-48ba-87bd-5f8ec691cb2a"
                },
                {
                    "@id": "urn:uuid:c4ecbb22-137e-47e3-a563-41e376461896"
                },
                {
                    "@id": "urn:uuid:2c2e6807-7dc1-4f71-8c41-75f65180e8b2"
                }
            ],
            "skos:broader": {
                "@id": "webuild:localunit"
            },
            "skos:definition": {
                "@language": "en",
                "@value": "a local unit that constitutes a production unit mainly engaged in one kind of economic activity, corresponding to the local part of a kind-of-activity unit\n\nOR\n\na local unit viewed through both the activity dimension and the locality dimension; in the European statistical context this corresponds to the local kind-of-activity unit"
            },
            "skos:inScheme": {
                "@id": "https://iri.suomi.fi/terminology/webuild/"
            },
            "skos:note": [
                {
                    "@language": "en",
                    "@value": "Use when the concept is not merely a local operating presence but a production-oriented local unit characterised by a principal activity. In Eurostat and related statistical contexts this corresponds to the local kind-of-activity unit."
                },
                {
                    "@language": "en",
                    "@value": "Alternatively:\nUse when the intended concept is the more specific production-oriented unit used for industry and national accounts purposes, rather than the broader local unit."
                }
            ],
            "skos:prefLabel": {
                "@id": "urn:uuid:56d0149c-0df4-4f8d-97e2-2a6a14e0d089"
            },
            "skos:related": {
                "@id": "webuild:site"
            },
            "suomi-meta:creator": "5dc030a4-740f-4dde-9548-4e6e797899d8",
            "suomi-meta:modifier": "5dc030a4-740f-4dde-9548-4e6e797899d8",
            "suomi-meta:publicationStatus": {
                "@id": "http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT"
            }
        },
        {
            "@id": "webuild:site",
            "term:orderedSynonym": {
                "@list": [
                    {
                        "@id": "urn:uuid:7052e039-5382-49dd-a2c1-5447f8765b3c"
                    },
                    {
                        "@id": "urn:uuid:9a70f8e9-d8ad-4730-a551-51ef1af4b318"
                    },
                    {
                        "@id": "urn:uuid:45cbcb6a-1d8a-4bc3-a819-94e242819a38"
                    }
                ]
            },
            "term:orderedRelated": {
                "@list": [
                    {
                        "@id": "webuild:establishment"
                    },
                    {
                        "@id": "webuild:localunit"
                    }
                ]
            },
            "term:orderedNote": {
                "@list": [
                    {
                        "@language": "en",
                        "@value": "Use only for the location or premises layer. Do not use for the enterprise (economic operator) sub-unit itself when the intended meaning is a local operating or statistical unit."
                    },
                    {
                        "@language": "en",
                        "@value": "Alternatively:\nUse only for the physical-location layer. Do not use as the main concept for the statistical unit of an enterprise."
                    }
                ]
            },
            "@type": "skos:Concept",
            "dcterms:created": {
                "@value": "2026-04-13T09:03:04.359Z",
                "@type": "xsd:dateTime"
            },
            "dcterms:modified": {
                "@value": "2026-04-14T05:35:41.952Z",
                "@type": "xsd:dateTime"
            },
            "skos:altLabel": [
                {
                    "@id": "urn:uuid:45cbcb6a-1d8a-4bc3-a819-94e242819a38"
                },
                {
                    "@id": "urn:uuid:9a70f8e9-d8ad-4730-a551-51ef1af4b318"
                },
                {
                    "@id": "urn:uuid:7052e039-5382-49dd-a2c1-5447f8765b3c"
                }
            ],
            "skos:definition": {
                "@language": "en",
                "@value": "a place, premises or location at which an organisation is present or located\n\nOR\n\na physical place, premises or location whose boundaries help determine the spatial extent of a local unit"
            },
            "skos:inScheme": {
                "@id": "https://iri.suomi.fi/terminology/webuild/"
            },
            "skos:note": [
                {
                    "@language": "en",
                    "@value": "Use only for the location or premises layer. Do not use for the enterprise (economic operator) sub-unit itself when the intended meaning is a local operating or statistical unit."
                },
                {
                    "@language": "en",
                    "@value": "Alternatively:\nUse only for the physical-location layer. Do not use as the main concept for the statistical unit of an enterprise."
                }
            ],
            "skos:prefLabel": {
                "@id": "urn:uuid:31764b48-c0eb-43d0-9be0-0132a7f971f0"
            },
            "skos:related": [
                {
                    "@id": "webuild:localunit"
                },
                {
                    "@id": "webuild:establishment"
                }
            ],
            "suomi-meta:creator": "5dc030a4-740f-4dde-9548-4e6e797899d8",
            "suomi-meta:modifier": "5dc030a4-740f-4dde-9548-4e6e797899d8",
            "suomi-meta:publicationStatus": {
                "@id": "http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT"
            }
        },
        {
            "@id": "webuild:legalform",
            "term:orderedNote": {
                "@list": [
                    {
                        "@language": "en",
                        "@value": "Legal form is typically expressed using nationally defined classifications, such as company types or partnership forms, which may be represented as codes or controlled concepts in business registers."
                    },
                    {
                        "@language": "en",
                        "@value": "The reference in the definition to \"legal entity\" reflects the existing EU Core Business Vocabulary structure, but the label of the key actor type might change during WE BUILD LSP (discussions about introducing the more generic \"economic operator\" instead)."
                    }
                ]
            },
            "suomi-meta:publicationStatus": {
                "@id": "http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT"
            },
            "suomi-meta:modifier": "5dc030a4-740f-4dde-9548-4e6e797899d8",
            "suomi-meta:creator": "5dc030a4-740f-4dde-9548-4e6e797899d8",
            "skos:prefLabel": {
                "@id": "urn:uuid:ec6a9ff0-b2c3-4411-aabd-c295d0c23de3"
            },
            "skos:note": [
                {
                    "@language": "en",
                    "@value": "Legal form is typically expressed using nationally defined classifications, such as company types or partnership forms, which may be represented as codes or controlled concepts in business registers."
                },
                {
                    "@language": "en",
                    "@value": "The reference in the definition to \"legal entity\" reflects the existing EU Core Business Vocabulary structure, but the label of the key actor type might change during WE BUILD LSP (discussions about introducing the more generic \"economic operator\" instead)."
                }
            ],
            "skos:inScheme": {
                "@id": "https://iri.suomi.fi/terminology/webuild/"
            },
            "skos:definition": {
                "@language": "en",
                "@value": "the juridical classification of a [legal entity] according to the law under which it is constituted, determining its legal personality, governance structure, and liability regime"
            },
            "dcterms:modified": {
                "@value": "2026-03-24T09:00:17.295Z",
                "@type": "xsd:dateTime"
            },
            "dcterms:created": {
                "@value": "2026-03-24T09:00:17.295Z",
                "@type": "xsd:dateTime"
            },
            "@type": "skos:Concept"
        },
        {
            "@id": "urn:uuid:ec6a9ff0-b2c3-4411-aabd-c295d0c23de3",
            "suomi-meta:publicationStatus": {
                "@id": "http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT"
            },
            "skos-xl:literalForm": {
                "@language": "en",
                "@value": "legal form"
            },
            "@type": "skos-xl:Label"
        },
        {
            "@id": "urn:uuid:e1b64573-537b-440b-bdcd-78a3980d4e1d",
            "suomi-meta:publicationStatus": {
                "@id": "http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT"
            },
            "skos-xl:literalForm": {
                "@language": "en",
                "@value": "locator designator"
            },
            "@type": "skos-xl:Label"
        },
        {
            "@id": "webuild:locatordesignator",
            "term:orderedNote": {
                "@list": [
                    {
                        "@language": "en",
                        "@value": "A locator designator uniquely identifies a physical entry point or unit within a structured address system.\n\nIt commonly corresponds to:\nBuilding number; House number; Entrance identifier; Staircase identifier; Apartment or unit number\n\nThe locator designator is distinct from the thoroughfare name and from the post code.\nIt forms part of a structured postal or geographical address."
                    }
                ]
            },
            "suomi-meta:publicationStatus": {
                "@id": "http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT"
            },
            "suomi-meta:modifier": "5dc030a4-740f-4dde-9548-4e6e797899d8",
            "suomi-meta:creator": "5dc030a4-740f-4dde-9548-4e6e797899d8",
            "skos:prefLabel": {
                "@id": "urn:uuid:e1b64573-537b-440b-bdcd-78a3980d4e1d"
            },
            "skos:note": {
                "@language": "en",
                "@value": "A locator designator uniquely identifies a physical entry point or unit within a structured address system.\n\nIt commonly corresponds to:\nBuilding number; House number; Entrance identifier; Staircase identifier; Apartment or unit number\n\nThe locator designator is distinct from the thoroughfare name and from the post code.\nIt forms part of a structured postal or geographical address."
            },
            "skos:inScheme": {
                "@id": "https://iri.suomi.fi/terminology/webuild/"
            },
            "skos:definition": {
                "@language": "en",
                "@value": "an alphanumeric identifier assigned within a thoroughfare or property context to designate a specific access point, building, unit, or sub-unit"
            },
            "dcterms:modified": {
                "@value": "2026-02-17T14:00:13.214Z",
                "@type": "xsd:dateTime"
            },
            "dcterms:created": {
                "@value": "2026-02-17T14:00:13.214Z",
                "@type": "xsd:dateTime"
            },
            "@type": "skos:Concept"
        },
        {
            "@id": "webuild:countryofdeath",
            "term:orderedNote": {
                "@list": [
                    {
                        "@language": "en",
                        "@value": "Country of death refers to the state associated with the place where the death occurred and was legally recorded."
                    },
                    {
                        "@language": "en",
                        "@value": "It reflects territorial jurisdiction at the time of death registration and does not imply:\nCitizenship; Residence; Nationality; Place of burial\n\nWhere geopolitical changes have occurred, the country of death shall correspond to the state recognised in the official death record."
                    }
                ]
            },
            "suomi-meta:publicationStatus": {
                "@id": "http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT"
            },
            "suomi-meta:modifier": "5dc030a4-740f-4dde-9548-4e6e797899d8",
            "suomi-meta:creator": "5dc030a4-740f-4dde-9548-4e6e797899d8",
            "skos:prefLabel": {
                "@id": "urn:uuid:e45b390b-ef56-493a-a925-585c8b8a2ac4"
            },
            "skos:note": [
                {
                    "@language": "en",
                    "@value": "Country of death refers to the state associated with the place where the death occurred and was legally recorded."
                },
                {
                    "@language": "en",
                    "@value": "It reflects territorial jurisdiction at the time of death registration and does not imply:\nCitizenship; Residence; Nationality; Place of burial\n\nWhere geopolitical changes have occurred, the country of death shall correspond to the state recognised in the official death record."
                }
            ],
            "skos:inScheme": {
                "@id": "https://iri.suomi.fi/terminology/webuild/"
            },
            "skos:definition": {
                "@language": "en",
                "@value": "the sovereign state within whose territory a person’s death was officially registered"
            },
            "dcterms:modified": {
                "@value": "2026-02-16T14:38:58.599Z",
                "@type": "xsd:dateTime"
            },
            "dcterms:created": {
                "@value": "2026-02-16T14:38:58.599Z",
                "@type": "xsd:dateTime"
            },
            "@type": "skos:Concept"
        },
        {
            "@id": "urn:uuid:e45b390b-ef56-493a-a925-585c8b8a2ac4",
            "suomi-meta:publicationStatus": {
                "@id": "http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT"
            },
            "skos-xl:literalForm": {
                "@language": "en",
                "@value": "country of death"
            },
            "@type": "skos-xl:Label"
        },
        {
            "@id": "urn:uuid:84772a6e-0544-4831-8109-6ab322108783",
            "suomi-meta:publicationStatus": {
                "@id": "http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT"
            },
            "skos-xl:literalForm": {
                "@language": "en",
                "@value": "country of birth"
            },
            "@type": "skos-xl:Label"
        },
        {
            "@id": "webuild:countryofbirth",
            "term:orderedNote": {
                "@list": [
                    {
                        "@language": "en",
                        "@value": "Country of birth refers to the state associated with the place of birth at the time of birth registration.\nIt reflects territorial jurisdiction and does not imply citizenship, nationality, ethnicity, or residence."
                    },
                    {
                        "@language": "en",
                        "@value": "Where historical territorial changes have occurred, the country of birth shall correspond to the state recognised in the official birth record."
                    }
                ]
            },
            "suomi-meta:publicationStatus": {
                "@id": "http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT"
            },
            "suomi-meta:modifier": "5dc030a4-740f-4dde-9548-4e6e797899d8",
            "suomi-meta:creator": "5dc030a4-740f-4dde-9548-4e6e797899d8",
            "skos:prefLabel": {
                "@id": "urn:uuid:84772a6e-0544-4831-8109-6ab322108783"
            },
            "skos:note": [
                {
                    "@language": "en",
                    "@value": "Country of birth refers to the state associated with the place of birth at the time of birth registration.\nIt reflects territorial jurisdiction and does not imply citizenship, nationality, ethnicity, or residence."
                },
                {
                    "@language": "en",
                    "@value": "Where historical territorial changes have occurred, the country of birth shall correspond to the state recognised in the official birth record."
                }
            ],
            "skos:inScheme": {
                "@id": "https://iri.suomi.fi/terminology/webuild/"
            },
            "skos:definition": {
                "@language": "en",
                "@value": "the sovereign state within whose territory a person’s birth was officially registered"
            },
            "dcterms:modified": {
                "@value": "2026-02-16T14:37:17.229Z",
                "@type": "xsd:dateTime"
            },
            "dcterms:created": {
                "@value": "2026-02-16T14:37:17.229Z",
                "@type": "xsd:dateTime"
            },
            "@type": "skos:Concept"
        },
        {
            "@id": "webuild:contactpoint",
            "term:orderedNote": {
                "@list": [
                    {
                        "@language": "en",
                        "@value": "A contact point represents the means or role by which communication is established with a person, organisation, or public authority."
                    },
                    {
                        "@language": "en",
                        "@value": "A contact point may also represent a functional role (e.g. “Customer Support”, “Procurement Office”) rather than an individual person."
                    }
                ]
            },
            "suomi-meta:publicationStatus": {
                "@id": "http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT"
            },
            "suomi-meta:modifier": "5dc030a4-740f-4dde-9548-4e6e797899d8",
            "suomi-meta:creator": "5dc030a4-740f-4dde-9548-4e6e797899d8",
            "skos:prefLabel": {
                "@id": "urn:uuid:4e663008-7541-4488-8982-d8914121f66c"
            },
            "skos:note": [
                {
                    "@language": "en",
                    "@value": "A contact point may also represent a functional role (e.g. “Customer Support”, “Procurement Office”) rather than an individual person."
                },
                {
                    "@language": "en",
                    "@value": "A contact point represents the means or role by which communication is established with a person, organisation, or public authority."
                }
            ],
            "skos:inScheme": {
                "@id": "https://iri.suomi.fi/terminology/webuild/"
            },
            "skos:definition": {
                "@language": "en",
                "@value": "a designated communication channel or organisational function through which an entity can be contacted for a specific purpose"
            },
            "dcterms:modified": {
                "@value": "2026-02-16T14:35:36.043Z",
                "@type": "xsd:dateTime"
            },
            "dcterms:created": {
                "@value": "2026-02-16T14:35:36.043Z",
                "@type": "xsd:dateTime"
            },
            "@type": "skos:Concept"
        },
        {
            "@id": "urn:uuid:4e663008-7541-4488-8982-d8914121f66c",
            "suomi-meta:publicationStatus": {
