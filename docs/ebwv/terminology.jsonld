        {
            "@id": "webuild:legalrepresentative",
            "term:orderedSynonym": {
                "@list": [
                    {
                        "@id": "urn:uuid:a2129fd5-3ca2-4a28-9380-09864b95a2a6"
                    },
                    {
                        "@id": "urn:uuid:1aca6026-f44c-4f11-b404-0af11ba68cfd"
