        {
            "@id": "webuild:concept-98",
            "skos:note": {
                "@language": "en",
                "@value": "It is important to notice that this concept does not refer to the ultimate beneficial owner of the economic operator but only to the economic operator entity that controls the instance of the wallet."
            },
