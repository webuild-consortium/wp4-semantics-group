                "@language": "en",
                "@value": "mandator"
            },
            "@type": "skos-xl:Label"
        },
        {
            "@id": "webuild:mandator",
            "suomi-meta:publicationStatus": {
                "@id": "http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT"
            },
            "suomi-meta:modifier": "5dc030a4-740f-4dde-9548-4e6e797899d8",
            "suomi-meta:creator": "5dc030a4-740f-4dde-9548-4e6e797899d8",
            "skos:prefLabel": {
                "@id": "urn:uuid:015a86dc-c75e-479a-97e4-3b306de1c74e"
            },
            "skos:inScheme": {
                "@id": "https://iri.suomi.fi/terminology/webuild/"
            },
            "skos:definition": {
                "@language": "en",
                "@value": "a natural person or legal person that grants a mandate (power of attorney) to a mandatee, thereby authorizing the mandatee to act on the mandator’s behalf within a defined scope, constraints, and validity"
            },
            "dcterms:modified": {
                "@value": "2026-02-04T11:19:51.989Z",
                "@type": "xsd:dateTime"
            },
            "dcterms:created": {
                "@value": "2026-02-04T11:19:51.989Z",
                "@type": "xsd:dateTime"
            },
            "@type": "skos:Concept"
        },
        {
            "@id": "urn:uuid:fb45c8e1-c3f2-4dbd-a7c8-2920df2b2cb6",
            "suomi-meta:publicationStatus": {
                "@id": "http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT"
            },
            "skos-xl:literalForm": {
                "@language": "en",
                "@value": "mandate"
            },
            "@type": "skos-xl:Label"
        },
        {
            "@id": "webuild:mandate",
            "suomi-meta:publicationStatus": {
                "@id": "http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT"
            },
            "suomi-meta:modifier": "5dc030a4-740f-4dde-9548-4e6e797899d8",
            "suomi-meta:creator": "5dc030a4-740f-4dde-9548-4e6e797899d8",
            "skos:prefLabel": {
                "@id": "urn:uuid:fb45c8e1-c3f2-4dbd-a7c8-2920df2b2cb6"
            },
            "skos:inScheme": {
                "@id": "https://iri.suomi.fi/terminology/webuild/"
            },
            "skos:definition": {
                "@language": "en",
                "@value": "a legally effective authorization by which a natural person or legal person (the mandator) empowers another agent (the mandatee) to act on the mandator’s behalf for one or more specified legal, administrative, or business matters, with a defined scope, constraints, and validity, and which can be presented and verified in the EU Business Wallet as evidence of representation towards relying parties"
            },
            "dcterms:modified": {
                "@value": "2026-02-04T11:18:03.431Z",
                "@type": "xsd:dateTime"
            },
            "dcterms:created": {
                "@value": "2026-02-04T11:18:03.431Z",
                "@type": "xsd:dateTime"
            },
            "@type": "skos:Concept"
        },
        {
            "@id": "urn:uuid:846f3541-0f10-4020-b2c3-3a1decc4bbc2",
            "suomi-meta:publicationStatus": {
                "@id": "http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT"
            },
            "skos-xl:literalForm": {
                "@language": "en",
                "@value": "authorisation"
            },
            "@type": "skos-xl:Label"
        },
        {
            "@id": "urn:uuid:96cbd269-b0bb-45f0-8e68-fb3db51bf229",
            "suomi-meta:publicationStatus": {
                "@id": "http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT"
            },
            "skos-xl:literalForm": {
                "@language": "en",
                "@value": "scope"
            },
            "@type": "skos-xl:Label"
        },
        {
            "@id": "webuild:scope",
            "suomi-meta:publicationStatus": {
                "@id": "http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT"
            },
            "suomi-meta:modifier": "5dc030a4-740f-4dde-9548-4e6e797899d8",
            "suomi-meta:creator": "5dc030a4-740f-4dde-9548-4e6e797899d8",
            "skos:prefLabel": {
                "@id": "urn:uuid:96cbd269-b0bb-45f0-8e68-fb3db51bf229"
            },
            "skos:inScheme": {
                "@id": "https://iri.suomi.fi/terminology/webuild/"
            },
            "skos:definition": {
                "@language": "en",
                "@value": "the set of actions, powers, and subject matters for which a power of attorney (mandate) authorizes the mandatee to act on behalf of the mandator, including any functional, domain, or process limitations (and, where applicable, exclusions) that determine what the mandatee is permitted to do and what falls outside the authorization"
            },
            "dcterms:modified": {
                "@value": "2026-02-04T11:06:10.028Z",
                "@type": "xsd:dateTime"
            },
            "dcterms:created": {
                "@value": "2026-02-04T11:06:10.028Z",
                "@type": "xsd:dateTime"
            },
            "@type": "skos:Concept"
        },
        {
            "@id": "urn:uuid:10f9266e-1ea9-402c-b8d1-5160132cfd99",
            "suomi-meta:publicationStatus": {
                "@id": "http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT"
            },
            "skos-xl:literalForm": {
                "@language": "en",
                "@value": "mandatee"
            },
            "@type": "skos-xl:Label"
        },
        {
            "@id": "webuild:mandatee",
            "suomi-meta:publicationStatus": {
                "@id": "http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT"
            },
            "suomi-meta:modifier": "5dc030a4-740f-4dde-9548-4e6e797899d8",
            "suomi-meta:creator": "5dc030a4-740f-4dde-9548-4e6e797899d8",
            "skos:prefLabel": {
                "@id": "urn:uuid:10f9266e-1ea9-402c-b8d1-5160132cfd99"
            },
            "skos:inScheme": {
                "@id": "https://iri.suomi.fi/terminology/webuild/"
            },
            "skos:definition": {
                "@language": "en",
                "@value": "an agent — a natural person or legal person — that is granted a mandate (power of attorney) by a mandator to act on the mandator’s behalf in one or more specified legal, administrative, or business matters, within the defined scope, constraints, and validity of that authorization, and whose authority can be presented and verified towards relying parties in the EU Business Wallet"
            },
            "dcterms:modified": {
                "@value": "2026-02-04T11:04:13.713Z",
                "@type": "xsd:dateTime"
            },
            "dcterms:created": {
                "@value": "2026-02-04T11:04:13.713Z",
                "@type": "xsd:dateTime"
            },
            "@type": "skos:Concept"
        },
