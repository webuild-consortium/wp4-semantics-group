        {
            "@id": "webuild:concept-51",
            "term:orderedRelated": {
                "@list": [
                    {
                        "@id": "webuild:concept-6006"
                    }
                ]
            },
            "term:orderedNote": {
                "@list": [
                    {
                        "@language": "en",
                        "@value": "Need to decide whether to devite from EU core for translated versions of legal name or to create a seperate category"
                    }
                ]
            },
            "term:orderedBroader": {
                "@list": [
                    {
                        "@id": "webuild:concept-18"
                    }
                ]
            },
            "suomi-meta:publicationStatus": {
                "@id": "http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT"
            },
            "suomi-meta:modifier": "4c00fd3e-ad5d-4ad6-8782-de29597a5d57",
            "suomi-meta:creator": "5dc030a4-740f-4dde-9548-4e6e797899d8",
            "skos:related": {
                "@id": "webuild:concept-6006"
            },
            "skos:prefLabel": {
                "@id": "urn:uuid:04844908-e92b-4910-ac70-dbcf38345fae"
            },
            "skos:note": {
                "@language": "en",
                "@value": "Need to decide whether to devite from EU core for translated versions of legal name or to create a seperate category"
            },
            "skos:inScheme": {
                "@id": "https://iri.suomi.fi/terminology/webuild/"
            },
            "skos:definition": {
                "@language": "en",
                "@value": "any other registered name by which a legal entity is known"
            },
            "skos:broader": {
                "@id": "webuild:concept-18"
            },
            "http://purl.org/termed/properties/id": "3690c87e-fc60-4a26-9e48-fad56d2f5025",
            "dcterms:modified": {
