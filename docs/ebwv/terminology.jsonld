        {
            "@id": "webuild:locationdesignator",
            "suomi-meta:publicationStatus": {
                "@id": "http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT"
            },
            "suomi-meta:creator": "5dc030a4-740f-4dde-9548-4e6e797899d8",
            "skos:inScheme": {
                "@id": "https://iri.suomi.fi/terminology/webuild/"
            },
            "dcterms:created": {
                "@value": "2026-02-16T09:36:36.703Z",
                "@type": "xsd:dateTime"
            },
            "skos:note": {
                "@language": "en",
                "@value": "In simpler terms, this is the building number, apartment number, etc. For an address such as \"Flat 3, 17 Bridge Street\", the locator is \"flat 3, 17\". A German example: \"Hauptstrasse 6 A\", the locator is \"6 A\"."
            },
            "skos:definition": {
                "@language": "en",
                "@value": "A number or sequence of characters that uniquely identifies the locator within the relevant scope."
            },
            "skos:prefLabel": {
                "@id": "urn:uuid:cd69f4e6-4db1-4042-a611-59e438c87de8"
            },
            "dcterms:modified": {
                "@value": "2026-02-16T09:36:36.703Z",
                "@type": "xsd:dateTime"
            },
            "term:orderedNote": {
                "@list": [
                    {
                        "@language": "en",
                        "@value": "In simpler terms, this is the building number, apartment number, etc. For an address such as \"Flat 3, 17 Bridge Street\", the locator is \"flat 3, 17\". A German example: \"Hauptstrasse 6 A\", the locator is \"6 A\"."
                    }
                ]
            },
            "@type": "skos:Concept",
            "suomi-meta:modifier": "5dc030a4-740f-4dde-9548-4e6e797899d8"
        },
        {
            "@id": "webuild:thoroughfare",
            "skos:note": [
                {
                    "@language": "en",
                    "@value": "The concept thoroughfare is just a part of \"streetAddress\" in Schema.org; example:\nstreetAddress: \"38 avenue de l'Opéra\"\nthoroughfare: \"avenue de l'Opéra\""
                },
                {
                    "@language": "en",
                    "@value": "A thoroughfare is usually a street, but it might be a waterway or some other feature. For example, \"Avenue des Champs-Élysées\".\n\nThe concept definition is based on the EU Core Location Vocabulary."
                }
            ],
            "dcterms:created": {
                "@value": "2026-02-16T08:34:40.728Z",
                "@type": "xsd:dateTime"
            },
            "@type": "skos:Concept",
            "term:orderedNote": {
                "@list": [
                    {
                        "@language": "en",
                        "@value": "A thoroughfare is usually a street, but it might be a waterway or some other feature. For example, \"Avenue des Champs-Élysées\".\n\nThe concept definition is based on the EU Core Location Vocabulary."
                    },
                    {
                        "@language": "en",
                        "@value": "The concept thoroughfare is just a part of \"streetAddress\" in Schema.org; example:\nstreetAddress: \"38 avenue de l'Opéra\"\nthoroughfare: \"avenue de l'Opéra\""
                    }
                ]
            },
            "skos:definition": {
                "@language": "en",
                "@value": "the name of a passage or way through from one location to another"
            },
            "skos:altLabel": {
                "@id": "urn:uuid:cdc31107-5f91-4442-beeb-af09460bfc36"
            },
            "suomi-meta:publicationStatus": {
                "@id": "http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT"
            },
            "skos:prefLabel": {
                "@id": "urn:uuid:95ed35c9-93af-471a-a4e1-63666ceebf92"
            },
            "dcterms:modified": {
                "@value": "2026-02-16T09:05:35.455Z",
                "@type": "xsd:dateTime"
            },
            "skos:inScheme": {
                "@id": "https://iri.suomi.fi/terminology/webuild/"
            },
            "suomi-meta:modifier": "5dc030a4-740f-4dde-9548-4e6e797899d8",
