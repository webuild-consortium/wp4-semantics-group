                "@type": "xsd:dateTime"
            },
            "@type": "skos:Concept"
        },
        {
            "@id": "webuild:contactpoint",
            "term:orderedNote": {
                "@list": [
                    {
                        "@language": "en",
                        "@value": "A contact point represents the means or role by which communication is established with a person, organisation, or public authority."
                    },
                    {
                        "@language": "en",
                        "@value": "A contact point may also represent a functional role (e.g. “Customer Support”, “Procurement Office”) rather than an individual person."
                    }
                ]
            },
            "suomi-meta:publicationStatus": {
                "@id": "http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT"
            },
            "suomi-meta:modifier": "5dc030a4-740f-4dde-9548-4e6e797899d8",
            "suomi-meta:creator": "5dc030a4-740f-4dde-9548-4e6e797899d8",
            "skos:prefLabel": {
                "@id": "urn:uuid:4e663008-7541-4488-8982-d8914121f66c"
            },
            "skos:note": [
                {
                    "@language": "en",
                    "@value": "A contact point may also represent a functional role (e.g. “Customer Support”, “Procurement Office”) rather than an individual person."
                },
                {
                    "@language": "en",
                    "@value": "A contact point represents the means or role by which communication is established with a person, organisation, or public authority."
                }
            ],
            "skos:inScheme": {
                "@id": "https://iri.suomi.fi/terminology/webuild/"
            },
            "skos:definition": {
                "@language": "en",
                "@value": "a designated communication channel or organisational function through which an entity can be contacted for a specific purpose"
            },
            "dcterms:modified": {
                "@value": "2026-02-16T14:35:36.043Z",
                "@type": "xsd:dateTime"
            },
            "dcterms:created": {
                "@value": "2026-02-16T14:35:36.043Z",
                "@type": "xsd:dateTime"
            },
            "@type": "skos:Concept"
        },
        {
            "@id": "urn:uuid:4e663008-7541-4488-8982-d8914121f66c",
            "suomi-meta:publicationStatus": {
                "@id": "http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT"
            },
            "skos-xl:literalForm": {
                "@language": "en",
                "@value": "contact point"
            },
            "@type": "skos-xl:Label"
        },
        {
            "@id": "urn:uuid:604c0d24-4524-4905-8d8a-6e01e8925b4b",
            "suomi-meta:publicationStatus": {
                "@id": "http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT"
