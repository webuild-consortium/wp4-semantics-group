        {
            "@id": "webuild:contactpoint",
            "term:orderedNote": {
                "@list": [
                    {
                        "@language": "en",
                        "@value": "A contact point represents the means or role by which communication is established with a person, organisation, or public authority."
                    },
                    {
                        "@language": "en",
                        "@value": "A contact point may also represent a functional role (e.g. “Customer Support”, “Procurement Office”) rather than an individual person."
                    }
                ]
            },
            "@type": "skos:Concept",
            "suomi-meta:publicationStatus": {
                "@id": "http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT"
            },
            "suomi-meta:modifier": "5dc030a4-740f-4dde-9548-4e6e797899d8",
            "suomi-meta:creator": "5dc030a4-740f-4dde-9548-4e6e797899d8",
            "skos:note": [
                {
                    "@language": "en",
                    "@value": "A contact point represents the means or role by which communication is established with a person, organisation, or public authority."
                },
                {
                    "@language": "en",
                    "@value": "A contact point may also represent a functional role (e.g. “Customer Support”, “Procurement Office”) rather than an individual person."
                }
            ],
            "skos:definition": {
                "@language": "en",
                "@value": "a designated communication channel or organisational function through which an entity can be contacted for a specific purpose"
            },
            "dcterms:created": {
                "@value": "2026-02-16T14:35:36.043Z",
                "@type": "xsd:dateTime"
            },
            "dcterms:modified": {
                "@value": "2026-02-16T14:35:36.043Z",
                "@type": "xsd:dateTime"
            },
            "skos:inScheme": {
                "@id": "https://iri.suomi.fi/terminology/webuild/"
            },
            "skos:prefLabel": {
                "@id": "urn:uuid:4e663008-7541-4488-8982-d8914121f66c"
            }
        },
        {
            "@id": "webuild:concept-110",
            "skos:prefLabel": {
                "@id": "urn:uuid:391f5ee1-a1b9-4278-8e64-e98b65fd55bd"
            },
            "skos:note": {
                "@language": "en",
                "@value": "The EUID consists of the country code, a register identifier and a national registration number. At the moment it is undefined how an EUID would look like for economic operators that are natural persons and other types of economic operators that are not certain types of legal entities mentioned in the BRIS regulation.\n\nThe future EU Business Wallet regulation will designate the European unique identifier (EUID), as established and governed by Directive (EU) 2017/1132, as the unique identifier for European Business Wallet owners, and establishes a similar unique identifier for European Business Wallets owners to whom the European Unique Identifier is not available."
            },
            "skos:related": {
                "@id": "webuild:concept-94"
            },
            "suomi-meta:modifier": "5dc030a4-740f-4dde-9548-4e6e797899d8",
            "skos:broader": {
                "@id": "webuild:concept-7"
            },
            "@type": "skos:Concept",
            "dcterms:created": {
                "@value": "2026-01-23T12:19:25.358Z",
                "@type": "xsd:dateTime"
            },
            "suomi-meta:creator": "5dc030a4-740f-4dde-9548-4e6e797899d8",
            "term:orderedNote": {
                "@list": [
                    {
                        "@language": "en",
                        "@value": "The EUID consists of the country code, a register identifier and a national registration number. At the moment it is undefined how an EUID would look like for economic operators that are natural persons and other types of economic operators that are not certain types of legal entities mentioned in the BRIS regulation.\n\nThe future EU Business Wallet regulation will designate the European unique identifier (EUID), as established and governed by Directive (EU) 2017/1132, as the unique identifier for European Business Wallet owners, and establishes a similar unique identifier for European Business Wallets owners to whom the European Unique Identifier is not available."
                    }
                ]
            },
            "dcterms:modified": {
                "@value": "2026-01-23T12:41:06.613Z",
                "@type": "xsd:dateTime"
            },
            "term:orderedBroader": {
                "@list": [
                    {
                        "@id": "webuild:concept-7"
                    }
                ]
            },
            "term:orderedRelated": {
                "@list": [
                    {
                        "@id": "webuild:concept-94"
                    }
                ]
            },
            "skos:definition": {
                "@language": "en",
                "@value": "a unique identifier to identify economic operators"
            },
            "skos:inScheme": {
                "@id": "https://iri.suomi.fi/terminology/webuild/"
            },
            "suomi-meta:publicationStatus": {
                "@id": "http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT"
            }
        },
        {
            "@id": "webuild:mandator",
            "suomi-meta:publicationStatus": {
                "@id": "http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT"
