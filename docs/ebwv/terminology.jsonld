        },
        {
            "@id": "webuild:lei",
            "term:orderedSynonym": {
                "@list": [
                    {
                        "@id": "urn:uuid:427d3424-d925-4b76-b6ef-47af9b8eb768"
                    }
                ]
            },
            "term:orderedNote": {
                "@list": [
                    {
                        "@language": "en",
                        "@value": "In the EBWV context, LEI denotes the identifier issued through the Global LEI System and maintained under the governance of GLEIF-accredited Local Operating Units. It identifies a legal entity, not a natural person acting in a private capacity, and should be used as an identifier value for an LEI-eligible entity. The LEI is especially relevant for cross-border business identification, financial reporting, procurement, trade, sanctions screening and regulatory verification."
                    }
                ]
            },
            "suomi-meta:publicationStatus": {
                "@id": "http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT"
            },
            "suomi-meta:modifier": "5dc030a4-740f-4dde-9548-4e6e797899d8",
            "suomi-meta:creator": "5dc030a4-740f-4dde-9548-4e6e797899d8",
            "skos:prefLabel": {
                "@id": "urn:uuid:643b36a8-4c6b-4682-af25-9f2f4568de6b"
            },
            "skos:note": {
                "@language": "en",
                "@value": "In the EBWV context, LEI denotes the identifier issued through the Global LEI System and maintained under the governance of GLEIF-accredited Local Operating Units. It identifies a legal entity, not a natural person acting in a private capacity, and should be used as an identifier value for an LEI-eligible entity. The LEI is especially relevant for cross-border business identification, financial reporting, procurement, trade, sanctions screening and regulatory verification."
            },
            "skos:inScheme": {
                "@id": "https://iri.suomi.fi/terminology/webuild/"
            },
            "skos:definition": {
                "@language": "en",
                "@value": "a globally unique reference code assigned under the Global LEI System to identify a legal entity participating in financial, business or regulatory transactions"
            },
            "skos:altLabel": {
                "@id": "urn:uuid:427d3424-d925-4b76-b6ef-47af9b8eb768"
            },
            "dcterms:modified": {
                "@value": "2026-04-28T14:25:13.054Z",
                "@type": "xsd:dateTime"
            },
            "dcterms:created": {
                "@value": "2026-04-28T14:25:13.054Z",
                "@type": "xsd:dateTime"
            },
            "@type": "skos:Concept"
        },
        {
            "@id": "urn:uuid:643b36a8-4c6b-4682-af25-9f2f4568de6b",
