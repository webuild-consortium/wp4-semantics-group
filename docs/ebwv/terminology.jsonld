                "@language": "en",
                "@value": "scope of authority"
            },
            "@type": "skos-xl:Label"
        },
        {
            "@id": "urn:uuid:2c715e4f-6c4b-420e-ba14-aca2f41ed64c",
            "suomi-meta:publicationStatus": {
                "@id": "http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT"
            },
            "skos-xl:literalForm": {
                "@language": "en",
                "@value": "extent of authorization"
            },
            "@type": "skos-xl:Label"
        },
        {
            "@id": "urn:uuid:4d47342e-7130-42a5-b99e-84ae01af651c",
            "suomi-meta:publicationStatus": {
                "@id": "http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT"
            },
            "skos-xl:literalForm": {
                "@language": "en",
                "@value": "mandate scope"
            },
            "@type": "skos-xl:Label"
        },
        {
            "@id": "urn:uuid:6c756406-dc7f-4227-b9b8-d61c223b744e",
            "suomi-meta:publicationStatus": {
                "@id": "http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT"
            },
            "skos-xl:literalForm": {
                "@language": "en",
                "@value": "representation scope"
            },
            "@type": "skos-xl:Label"
        },
        {
            "@id": "webuild:scopeofauthorization",
            "term:orderedSynonym": {
                "@list": [
                    {
                        "@id": "urn:uuid:81e79908-5f43-4514-86e6-a57c87cba339"
                    },
                    {
                        "@id": "urn:uuid:bd63d2bd-5e7f-465f-a199-d43e829665a8"
                    },
                    {
                        "@id": "urn:uuid:2c715e4f-6c4b-420e-ba14-aca2f41ed64c"
                    },
                    {
                        "@id": "urn:uuid:4d47342e-7130-42a5-b99e-84ae01af651c"
                    },
                    {
                        "@id": "urn:uuid:6c756406-dc7f-4227-b9b8-d61c223b744e"
                    }
                ]
            },
            "term:orderedNote": {
                "@list": [
                    {
                        "@language": "en",
                        "@value": "In the EBWV context, scope of authorization should be used to describe the limits of an authorisation, mandate, power of attorney, representation right, access right or consent. It may specify what the authorised party may do, for whom, in which role, in relation to which subject matter, and under what conditions. The scope may be general or limited, and may be restricted by time, jurisdiction, transaction type, service, value threshold, document type, credential type or required joint action with another representative.\n\nIt should be distinguished from the authorised person or representative, who is the agent receiving the authority; the authorising party, who grants or is represented by the authority; and the legal basis, which explains why the authority exists."
                    }
                ]
            },
            "term:orderedExample": {
                "@list": [
                    {
                        "@language": "en",
                        "@value": "A power of attorney attestation states that the representative’s scope of authorization is limited to submitting VAT returns and receiving tax-related notifications on behalf of the company."
                    }
                ]
            },
            "@type": "skos:Concept",
            "dcterms:created": {
                "@value": "2026-04-28T14:54:50.304Z",
                "@type": "xsd:dateTime"
            },
            "dcterms:modified": {
                "@value": "2026-04-28T14:55:57.693Z",
                "@type": "xsd:dateTime"
            },
            "skos:altLabel": [
                {
                    "@id": "urn:uuid:6c756406-dc7f-4227-b9b8-d61c223b744e"
                },
                {
                    "@id": "urn:uuid:4d47342e-7130-42a5-b99e-84ae01af651c"
                },
                {
                    "@id": "urn:uuid:2c715e4f-6c4b-420e-ba14-aca2f41ed64c"
                },
                {
                    "@id": "urn:uuid:bd63d2bd-5e7f-465f-a199-d43e829665a8"
                },
                {
                    "@id": "urn:uuid:81e79908-5f43-4514-86e6-a57c87cba339"
                }
            ],
            "skos:definition": {
                "@language": "en",
                "@value": "the actions, matters, transactions, roles or circumstances for which an agent is authorised to act on behalf of another person or entity"
            },
            "skos:example": {
                "@language": "en",
                "@value": "A power of attorney attestation states that the representative’s scope of authorization is limited to submitting VAT returns and receiving tax-related notifications on behalf of the company."
            },
            "skos:inScheme": {
                "@id": "https://iri.suomi.fi/terminology/webuild/"
            },
            "skos:note": {
                "@language": "en",
                "@value": "In the EBWV context, scope of authorization should be used to describe the limits of an authorisation, mandate, power of attorney, representation right, access right or consent. It may specify what the authorised party may do, for whom, in which role, in relation to which subject matter, and under what conditions. The scope may be general or limited, and may be restricted by time, jurisdiction, transaction type, service, value threshold, document type, credential type or required joint action with another representative.\n\nIt should be distinguished from the authorised person or representative, who is the agent receiving the authority; the authorising party, who grants or is represented by the authority; and the legal basis, which explains why the authority exists."
            },
            "skos:prefLabel": {
                "@id": "urn:uuid:7b893c19-8b10-498a-a402-3d1bce8c3be2"
            },
            "suomi-meta:creator": "5dc030a4-740f-4dde-9548-4e6e797899d8",
            "suomi-meta:modifier": "5dc030a4-740f-4dde-9548-4e6e797899d8",
            "suomi-meta:publicationStatus": {
                "@id": "http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT"
            }
        },
