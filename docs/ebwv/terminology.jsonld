        {
            "@id": "webuild:birthname",
            "skos:note": [
                {
                    "@language": "en",
                    "@value": "A birth name may consist of one or more given names and one or more family names, depending on national naming systems."
                },
                {
                    "@language": "en",
                    "@value": "A birth name is the legally recognised name entered in the civil register at the time of birth.\nIt may later change due to marriage, adoption, gender recognition, legal name change, or other lawful modification."
                }
            ],
            "skos:inScheme": {
                "@id": "https://iri.suomi.fi/terminology/webuild/"
            },
            "suomi-meta:creator": "5dc030a4-740f-4dde-9548-4e6e797899d8",
            "skos:prefLabel": {
                "@id": "urn:uuid:6f7bd3f5-0226-46f2-a7cb-7c18c22d5afc"
            },
            "dcterms:modified": {
                "@value": "2026-02-16T14:30:14.763Z",
                "@type": "xsd:dateTime"
            },
            "skos:definition": {
                "@language": "en",
                "@value": "the name assigned to a person at birth and recorded in the official birth registration"
            },
            "skos:broader": {
                "@id": "webuild:concept-18"
            },
            "suomi-meta:publicationStatus": {
                "@id": "http://uri.suomi.fi/codelist/interoperabilityplatform/interoperabilityplatform_status/code/DRAFT"
            },
            "term:orderedBroader": {
                "@list": [
                    {
                        "@id": "webuild:concept-18"
                    }
                ]
            },
            "@type": "skos:Concept",
            "dcterms:created": {
                "@value": "2026-02-16T14:30:14.763Z",
                "@type": "xsd:dateTime"
            },
            "term:orderedNote": {
                "@list": [
                    {
                        "@language": "en",
                        "@value": "A birth name is the legally recognised name entered in the civil register at the time of birth.\nIt may later change due to marriage, adoption, gender recognition, legal name change, or other lawful modification."
                    },
                    {
                        "@language": "en",
                        "@value": "A birth name may consist of one or more given names and one or more family names, depending on national naming systems."
                    }
                ]
            },
            "suomi-meta:modifier": "5dc030a4-740f-4dde-9548-4e6e797899d8"
        },
        {
            "@id": "urn:uuid:6f7bd3f5-0226-46f2-a7cb-7c18c22d5afc",
