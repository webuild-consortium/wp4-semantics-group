    vs:term_status "stable" ;
.

ebwv:partner a rdf:Property, owl:ObjectProperty ;
    rdfs:domain ebwv:EuccPartnership ;
    rdfs:range ebwv:GeneralPartner, ebwv:LimitedPartner, ebwv:StatutoryPartner ;
