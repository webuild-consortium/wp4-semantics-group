    vs:term_status "stable" ;
.

ebwv:scopeOfAuthorization a rdf:Property, owl:ObjectProperty ;
    rdfs:domain [ a owl:Class; owl:unionOf (ebwv:LegalRepresentative ebwv:StatutoryPartner) ] ;
    rdfs:range ebwv:ScopeOfAuthorization, [ a owl:Class; owl:oneOf (ebwv:Alone ebwv:Jointly) ] ;
    rdfs:label "scope of authorization (alone or jointly)" ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/role>, <https://webuild-consortium.github.io/wp4-semantics-group/ebwv/vocabulary.html#> ;
    vs:term_status "stable" ;
.

ebwv:subscribedCapital a rdf:Property, owl:ObjectProperty ;
    rdfs:domain ebwv:EuccLimitLiabilityCompany ;
    rdfs:range ebwv:Capital ;
    rdfs:label "subscribed capital" ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/subscribedcapital>, <https://webuild-consortium.github.io/wp4-semantics-group/ebwv/vocabulary.html#> ;
    vs:term_status "stable" ;
.

ebwv:thoroughfare a rdf:Property, owl:DatatypeProperty ;
    rdfs:domain ebwv:Address ;
    rdfs:range xsd:string ;
    rdfs:label "thoroughfare" ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/thoroughfare>, <https://webuild-consortium.github.io/wp4-semantics-group/ebwv/vocabulary.html#> ;
    vs:term_status "stable" ;
.

ebwv:tin a rdf:Property, owl:DatatypeProperty ;
    rdfs:domain ebwv:LegalPersonIdentificationData ;
    rdfs:range xsd:string ;
    rdfs:label "tax reference number" ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/tin>, <https://webuild-consortium.github.io/wp4-semantics-group/ebwv/vocabulary.html#> ;
    vs:term_status "stable" ;
.

ebwv:vat a rdf:Property, owl:DatatypeProperty ;
    rdfs:domain ebwv:LegalPersonIdentificationData ;
    rdfs:range xsd:string ;
    rdfs:label "value added tax id" ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/vat>, <https://webuild-consortium.github.io/wp4-semantics-group/ebwv/vocabulary.html#> ;
    vs:term_status "stable" ;
.

