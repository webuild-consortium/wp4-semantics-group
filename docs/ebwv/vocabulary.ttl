    rdfs:domain ebwv:Platform ;
    rdfs:range ebwv:EconomicOperator ;
    rdfs:label "operator" ;
    rdfs:comment """<div>The organisation that hosts the platform and onboards new members.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/operator>, <https://w3id.org/ebwv#> ;
    vs:term_status "stable" ;
.

