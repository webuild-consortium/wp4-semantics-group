.

ebwv:dateOfRegistration a rdf:Property, owl:DatatypeProperty ;
    rdfs:domain [ a owl:Class; owl:unionOf (ebwv:EuccLimitLiabilityCompany ebwv:EuccPartnership) ] ;
    rdfs:range xsd:date ;
    rdfs:label "date of registration" ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/dateofregistration>, <https://webuild-consortium.github.io/wp4-semantics-group/ebwv/vocabulary.html#> ;
    vs:term_status "stable" ;
.

ebwv:domicile a rdf:Property, owl:ObjectProperty ;
    rdfs:domain ebwv:Person ;
