    rdfs:label "domicile" ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/domicile>, <https://webuild-consortium.github.io/wp4-semantics-group/ebwv/vocabulary.html#> ;
