@prefix ebwv: <https://w3id.org/ebwv#> .
@prefix cred: <https://www.w3.org/2018/credentials#> .
@prefix jsonld: <http://www.w3.org/ns/json-ld#> .
@prefix schema: <https://schema.org/> .
@prefix time: <http://www.w3.org/2006/time#> .
@prefix dc: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix vs: <http://www.w3.org/2003/06/sw-vocab-status/ns#> .

# Ontology definition
ebwv: a owl:Ontology ;
    dc:title """European Business Wallet Vocabulary v0.1"""@en ;
    dc:description """Vocabulary used by the Verifiable Credentials of the European Business Wallet Framework"""^^rdf:HTML ;
    rdfs:seeAlso <https://webuild-consortium.github.io/wp4-semantics-group/ebwv> ;
    dc:date "2026-07-13"^^xsd:date ;
.

# Property definitions
ebwv:a1 a rdf:Property, owl:DatatypeProperty ;
    rdfs:domain ebwv:PostedWorkerNotification ;
    rdfs:range xsd:anyURI ;
    rdfs:label "a1 certificate" ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/a1>, <https://w3id.org/ebwv#> ;
    vs:term_status "stable" ;
.

ebwv:acceptedAt a rdf:Property, owl:DatatypeProperty ;
    rdfs:domain ebwv:GovernanceRulebook ;
    rdfs:range xsd:dateTime ;
    rdfs:label "accepted at" ;
    rdfs:comment """<div>Datetime when the rulebook was accepted. May differ from issuance time in an outbound flow where a credential is issued to an existing member based on a previously completed onboarding flow.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/acceptedat>, <https://w3id.org/ebwv#> ;
    vs:term_status "stable" ;
.

ebwv:accountName a rdf:Property, owl:DatatypeProperty ;
    rdfs:domain ebwv:BankAccount ;
    rdfs:range xsd:string ;
    rdfs:label "account name" ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/accountname>, <https://w3id.org/ebwv#> ;
    vs:term_status "stable" ;
.

ebwv:accountType a rdf:Property, owl:DatatypeProperty ;
    rdfs:domain ebwv:BankAccount ;
    rdfs:range ebwv:AccountType ;
    rdfs:label "account type" ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/banktype>, <https://w3id.org/ebwv#> ;
    vs:term_status "stable" ;
.

ebwv:activity a rdf:Property, owl:DatatypeProperty ;
    rdfs:domain ebwv:Company ;
    rdfs:range ebwv:Nace21 ;
    rdfs:label "main activity of company" ;
    rdfs:comment """<div>organised doing, operation or process carried out for a purpose or result</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/activity>, <https://w3id.org/ebwv#> ;
    vs:term_status "stable" ;
.

ebwv:addressArea a rdf:Property, owl:DatatypeProperty ;
    rdfs:domain ebwv:Address ;
    rdfs:range xsd:string ;
    rdfs:label "address area" ;
    rdfs:comment """<div>the name of a geographic area that groups addresses</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/addressarea>, <https://w3id.org/ebwv#> ;
    vs:term_status "stable" ;
.

ebwv:administrativeRepresentative a rdf:Property, owl:ObjectProperty ;
    rdfs:domain ebwv:EconomicOperator ;
    rdfs:range ebwv:Person ;
    rdfs:label "administrative representative" ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/administrativerepresentative>, <https://w3id.org/ebwv#> ;
    vs:term_status "stable" ;
.

ebwv:adminUnitL1 a rdf:Property, owl:DatatypeProperty ;
    rdfs:domain ebwv:Address ;
    rdfs:range ebwv:CountryCode ;
    rdfs:label "administrative unit level 1" ;
    rdfs:comment """<div>the name of the uppermost level of the address, almost always a country</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/adminUnitL1>, <https://w3id.org/ebwv#> ;
    vs:term_status "stable" ;
.

ebwv:adminUnitL2 a rdf:Property, owl:DatatypeProperty ;
    rdfs:domain ebwv:Address ;
    rdfs:range xsd:string ;
    rdfs:label "administrative unit level 2" ;
    rdfs:comment """<div>The name of a secondary level/region of the address, usually a county, state or other such area that typically encompasses several localities.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/adminUnitL2>, <https://w3id.org/ebwv#> ;
    vs:term_status "stable" ;
.

ebwv:alternativeName a rdf:Property, owl:DatatypeProperty ;
    rdfs:domain ebwv:Person ;
    rdfs:range xsd:string ;
    rdfs:label "alternative name" ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/alternativename>, <https://w3id.org/ebwv#> ;
    vs:term_status "stable" ;
.

ebwv:amount a rdf:Property, owl:DatatypeProperty ;
    rdfs:domain ebwv:MonetaryAmount ;
    rdfs:range xsd:float ;
    rdfs:label "amount" ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/amount>, <https://w3id.org/ebwv#> ;
    vs:term_status "stable" ;
.

ebwv:assignment a rdf:Property, owl:ObjectProperty ;
    rdfs:domain ebwv:PostedWorkerNotification ;
    rdfs:range ebwv:WorkAssignment ;
    rdfs:label "assignment" ;
    rdfs:comment """<div>a formal allocation of a role, mandate, responsibility, task, right, or duty to an identified party or agent within a defined context</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/assignment>, <https://w3id.org/ebwv#> ;
    vs:term_status "stable" ;
.

ebwv:attestationLegalCategory a rdf:Property, owl:ObjectProperty ;
    rdfs:domain ebwv:ElectronicAttestationOfAttributes ;
    rdfs:range ebwv:AttestationLegalCategory, [ a owl:Class; owl:oneOf (ebwv:QEAA ebwv:Pub-EAA ebwv:EAA) ] ;
    rdfs:label "attestation legal category" ;
    rdfs:comment """<div>a categorization of electronic attestations of attributes into three primary types, each associated with a distinct level of assurance and legal effect</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/attestationlegalcategory>, <https://w3id.org/ebwv#> ;
    vs:term_status "stable" ;
.

ebwv:birthName a rdf:Property, owl:DatatypeProperty ;
    rdfs:domain ebwv:Person ;
    rdfs:range xsd:string ;
    rdfs:label "birth name" ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/birthname>, <https://w3id.org/ebwv#> ;
    vs:term_status "stable" ;
.

ebwv:buyer a rdf:Property, owl:DatatypeProperty ;
    rdfs:domain ebwv:PaymentTerms ;
    rdfs:range xsd:anyURI ;
    rdfs:label "buyer" ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/buyer>, <https://w3id.org/ebwv#> ;
    vs:term_status "stable" ;
.

ebwv:citizenship a rdf:Property, owl:DatatypeProperty ;
    rdfs:domain ebwv:Person ;
    rdfs:range ebwv:CountryCode ;
    rdfs:label "citizenship" ;
    rdfs:comment """<div>the legal bond between a natural person and a state, recognised under national law, which establishes membership in that state and entails associated rights and obligations</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/citizenship>, <https://w3id.org/ebwv#> ;
    vs:term_status "stable" ;
.

ebwv:constructionSector a rdf:Property, owl:DatatypeProperty ;
    rdfs:domain ebwv:EconomicOperator ;
    rdfs:range xsd:boolean ;
    rdfs:label "construction sector" ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/constructionsector>, <https://w3id.org/ebwv#> ;
    vs:term_status "stable" ;
.

ebwv:contactPoint a rdf:Property, owl:ObjectProperty ;
    rdfs:domain [ a owl:Class; owl:unionOf (ebwv:Person ebwv:EconomicOperator) ] ;
    rdfs:range ebwv:ContactPoint ;
    rdfs:label "contact point" ;
    rdfs:comment """<div>a designated communication channel or organisational function through which an entity can be contacted for a specific purpose</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/contactpoint>, <https://w3id.org/ebwv#> ;
    vs:term_status "stable" ;
.

ebwv:contributor a rdf:Property, owl:ObjectProperty ;
    rdfs:domain ebwv:SocialSecurityContribution ;
    rdfs:range ebwv:EconomicOperator ;
    rdfs:label "contributor" ;
    rdfs:comment """<div>The economic operator that is the employer subject of a social security contribution attestation.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/contributor>, <https://w3id.org/ebwv#> ;
    vs:term_status "stable" ;
.

ebwv:correspondenceAddress a rdf:Property, owl:ObjectProperty ;
    rdfs:domain [ a owl:Class; owl:unionOf (ebwv:Company ebwv:LegalPerson) ] ;
    rdfs:range ebwv:Address ;
    rdfs:label "correspondence Address" ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/correspondenceaddress>, <https://w3id.org/ebwv#> ;
    vs:term_status "stable" ;
.

ebwv:countryOfBirth a rdf:Property, owl:ObjectProperty ;
    rdfs:domain ebwv:Person ;
    rdfs:range ebwv:Location ;
    rdfs:label "country of birth" ;
    rdfs:comment """<div>the sovereign state within whose territory a person's birth was officially registered</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/countryofbirth>, <https://w3id.org/ebwv#> ;
    vs:term_status "stable" ;
.

ebwv:countryOfDeath a rdf:Property, owl:ObjectProperty ;
    rdfs:domain ebwv:Person ;
    rdfs:range ebwv:Location ;
    rdfs:label "country of death" ;
    rdfs:comment """<div>the sovereign state within whose territory a person's death was officially registered</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/countryofdeath>, <https://w3id.org/ebwv#> ;
    vs:term_status "stable" ;
.

ebwv:currency a rdf:Property, owl:DatatypeProperty ;
    rdfs:domain [ a owl:Class; owl:unionOf (ebwv:MonetaryAmount ebwv:PaymentTerms) ] ;
    rdfs:range ebwv:Currency ;
    rdfs:label "currency" ;
    rdfs:comment """<div>a recognised monetary unit used to express prices, payments, liabilities, values, or other monetary amounts in a business, financial, administrative, or regulatory context</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/currency>, <https://w3id.org/ebwv#> ;
    vs:term_status "stable" ;
.

ebwv:dateOfBirth a rdf:Property, owl:DatatypeProperty ;
    rdfs:domain [ a owl:Class; owl:unionOf (ebwv:Person ebwv:NaturalPerson) ] ;
    rdfs:range xsd:date ;
    rdfs:label "date of birth" ;
    rdfs:comment """<div>the point in time on which the person was born</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/dateofbirth>, <https://w3id.org/ebwv#> ;
    vs:term_status "stable" ;
.

ebwv:dateOfDeath a rdf:Property, owl:DatatypeProperty ;
    rdfs:domain ebwv:Person ;
    rdfs:range xsd:date ;
    rdfs:label "date of death" ;
    rdfs:comment """<div>the calendar date on which a person is recorded or attested as having died</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/dateofdeath>, <https://w3id.org/ebwv#> ;
    vs:term_status "stable" ;
.

ebwv:dateOfRegistration a rdf:Property, owl:DatatypeProperty ;
    rdfs:domain [ a owl:Class; owl:unionOf (ebwv:Company ebwv:LegalPerson) ] ;
    rdfs:range xsd:date ;
    rdfs:label "date of registration" ;
    rdfs:comment """<div>the date on which the legal entity has registered in some jurisdiction for regulatory and / or for tax purposes</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/dateofregistration>, <https://w3id.org/ebwv#> ;
    vs:term_status "stable" ;
.

ebwv:deliveryLocation a rdf:Property, owl:ObjectProperty ;
    rdfs:domain ebwv:PaymentTerms ;
    rdfs:range ebwv:Location, ebwv:Address ;
    rdfs:label "delivery location" ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/deliverylocation>, <https://w3id.org/ebwv#> ;
    vs:term_status "stable" ;
.

ebwv:domicile a rdf:Property, owl:ObjectProperty ;
    rdfs:domain ebwv:Person ;
    rdfs:range ebwv:Address ;
    rdfs:label "domicile" ;
    rdfs:comment """<div>the address representing the place that a person treats as their permanent home, as recorded, declared, or attested in a given context</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/domicile>, <https://w3id.org/ebwv#> ;
    vs:term_status "stable" ;
.

ebwv:duration a rdf:Property, owl:ObjectProperty ;
    rdfs:domain ebwv:WorkAssignment ;
    rdfs:range ebwv:PeriodOfTime ;
    rdfs:label "duration" ;
    rdfs:comment """<div>a temporal length representing how long an activity, status, validity period, assignment, mandate, process, event, or other time-bound condition lasts</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/duration>, <https://w3id.org/ebwv#> ;
    vs:term_status "stable" ;
.

ebwv:employee a rdf:Property, owl:ObjectProperty ;
    rdfs:domain ebwv:EconomicOperator ;
    rdfs:range ebwv:Person ;
    rdfs:label "employee" ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/employee>, <https://w3id.org/ebwv#> ;
    vs:term_status "stable" ;
.

ebwv:employer a rdf:Property, owl:ObjectProperty ;
    rdfs:domain [ a owl:Class; owl:unionOf (ebwv:A1Certificate ebwv:PostedWorkerNotification) ] ;
    rdfs:range ebwv:EconomicOperator ;
    rdfs:label "employer" ;
    rdfs:comment """<div>a party that engages a person to perform work under an employment relationship, with associated rights, duties, reporting obligations, or liabilities</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/employer>, <https://w3id.org/ebwv#> ;
    vs:term_status "stable" ;
.

ebwv:endDate a rdf:Property, owl:DatatypeProperty ;
    rdfs:domain [ a owl:Class; owl:unionOf (ebwv:PeriodOfTime ebwv:Company) ] ;
    rdfs:range xsd:date ;
    rdfs:label "end date of period of time" ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/endDate>, <https://w3id.org/ebwv#> ;
    vs:term_status "stable" ;
.

ebwv:familyName a rdf:Property, owl:DatatypeProperty ;
    rdfs:domain [ a owl:Class; owl:unionOf (ebwv:NaturalPerson ebwv:Person) ] ;
    rdfs:range xsd:string ;
    rdfs:label "family name" ;
    rdfs:comment """<div>the hereditary surname of a family</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/familyname>, <https://w3id.org/ebwv#> ;
    vs:term_status "stable" ;
.

ebwv:flagState a rdf:Property, owl:DatatypeProperty ;
    rdfs:domain ebwv:Vessel ;
    rdfs:range ebwv:CountryCode ;
    rdfs:label "flag state" ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/flagstate>, <https://w3id.org/ebwv#> ;
    vs:term_status "stable" ;
.

ebwv:fullAddress a rdf:Property, owl:DatatypeProperty ;
    rdfs:domain ebwv:Address ;
    rdfs:range xsd:string ;
    rdfs:label "full address" ;
    rdfs:comment """<div>the complete address written as a string</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/fulladdress>, <https://w3id.org/ebwv#> ;
    vs:term_status "stable" ;
.

ebwv:fullName a rdf:Property, owl:DatatypeProperty ;
    rdfs:domain ebwv:Person ;
    rdfs:range xsd:string ;
    rdfs:label "full name" ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/fullname>, <https://w3id.org/ebwv#> ;
    vs:term_status "stable" ;
.

ebwv:fullPeriodCovered a rdf:Property, owl:DatatypeProperty ;
    rdfs:domain ebwv:A1Certificate ;
    rdfs:range xsd:boolean ;
    rdfs:label "full period covered" ;
    rdfs:comment """<div>indicates that the PD A1 certificate applies for the entire duration of the cross-border work activity or posting for which the certificate is issued</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/fullperiodcovered>, <https://w3id.org/ebwv#> ;
    vs:term_status "stable" ;
.

ebwv:gender a rdf:Property, owl:DatatypeProperty ;
    rdfs:domain ebwv:Person ;
    rdfs:range xsd:string ;
    rdfs:label "gender" ;
    rdfs:comment """<div>a recorded, declared, or attested classification of a person according to gender in a given administrative, legal, or business context</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/gender>, <https://w3id.org/ebwv#> ;
    vs:term_status "stable" ;
.

ebwv:geographicIdentifier a rdf:Property, owl:DatatypeProperty ;
    rdfs:domain ebwv:Location ;
    rdfs:range xsd:anyURI ;
    rdfs:label "geographic identifier" ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/geographicidentifier>, <https://w3id.org/ebwv#> ;
    vs:term_status "stable" ;
.

ebwv:geographicName a rdf:Property, owl:DatatypeProperty ;
    rdfs:domain ebwv:Location ;
    rdfs:range xsd:string ;
    rdfs:label "geographic name" ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/geographicname>, <https://w3id.org/ebwv#> ;
    vs:term_status "stable" ;
.

ebwv:givenName a rdf:Property, owl:DatatypeProperty ;
    rdfs:domain [ a owl:Class; owl:unionOf (ebwv:NaturalPerson ebwv:Person) ] ;
    rdfs:range xsd:string ;
    rdfs:label "given name" ;
    rdfs:comment """<div>the name(s) that identify the person within a family with a common surname</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/givenname>, <https://w3id.org/ebwv#> ;
    vs:term_status "stable" ;
.

ebwv:hasEmail a rdf:Property, owl:DatatypeProperty ;
    rdfs:domain ebwv:ContactPoint ;
    rdfs:range xsd:string ;
    rdfs:label "email" ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/email>, <https://w3id.org/ebwv#> ;
    vs:term_status "stable" ;
.

ebwv:hash a rdf:Property, owl:DatatypeProperty ;
    rdfs:domain ebwv:GovernanceRulebook ;
    rdfs:range xsd:string ;
    rdfs:label "hash" ;
    rdfs:comment """<div>SHA-256 hash of the rulebook, for quick comparison.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/hash>, <https://w3id.org/ebwv#> ;
    vs:term_status "stable" ;
.

ebwv:hasSite a rdf:Property, owl:ObjectProperty ;
    rdfs:domain ebwv:SocialSecurityContribution ;
    rdfs:range ebwv:Site ;
    rdfs:label "has site" ;
    rdfs:comment """<div>a place, premises or location at which an organisation is present or located</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/site>, <https://w3id.org/ebwv#> ;
    vs:term_status "stable" ;
.

ebwv:hasTelephone a rdf:Property, owl:DatatypeProperty ;
    rdfs:domain ebwv:ContactPoint ;
    rdfs:range xsd:string ;
    rdfs:label "telephone" ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/telephone>, <https://w3id.org/ebwv#> ;
    vs:term_status "stable" ;
.

ebwv:hostEntity a rdf:Property, owl:ObjectProperty ;
    rdfs:domain ebwv:PostedWorkerNotification ;
    rdfs:range ebwv:EconomicOperator ;
    rdfs:label "host entity" ;
    rdfs:comment """<div>an economic operator established or operating in the host country that receives, supervises, coordinates or otherwise benefits from the work carried out by a posted worker during a posting period</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/hostentity>, <https://w3id.org/ebwv#> ;
    vs:term_status "stable" ;
.

ebwv:iban a rdf:Property, owl:DatatypeProperty ;
    rdfs:domain ebwv:BankAccount ;
    rdfs:range ebwv:Iban ;
    rdfs:label "IBAN" ;
    rdfs:comment """<div>an internationally standardised identifier for a payment account, composed of a country code, check digits and a country-specific basic bank account number, used to identify the account to which a payment is to be made or from which a payment is to be collected</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/iban>, <https://w3id.org/ebwv#> ;
    vs:term_status "stable" ;
.

ebwv:identifier a rdf:Property, owl:DatatypeProperty ;
    rdfs:domain [ a owl:Class; owl:unionOf (ebwv:EconomicOperator ebwv:Site ebwv:VATRegistrationUnit ebwv:GLN) ] ;
    rdfs:range [ a owl:Class; owl:unionOf (ebwv:Bic ebwv:ClearingNumber ebwv:Eori ebwv:Excise ebwv:GlobalLocationNumber ebwv:Iban ebwv:Lei ebwv:PeppolId ebwv:Tin ebwv:VatId xsd:anyURI xsd:string) ] ;
    rdfs:label "identifier" ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/identifier>, <https://w3id.org/ebwv#> ;
    vs:term_status "stable" ;
.

ebwv:jobTitle a rdf:Property, owl:DatatypeProperty ;
    rdfs:domain ebwv:Person ;
    rdfs:range xsd:string ;
    rdfs:label "job title" ;
    rdfs:comment """<div>the name or designation of a worker's role, position or function in relation to an employment relationship, posting arrangement or work assignment</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/jobtitle>, <https://w3id.org/ebwv#> ;
    vs:term_status "stable" ;
.

ebwv:jurisdiction a rdf:Property, owl:DatatypeProperty ;
    rdfs:domain [ a owl:Class; owl:unionOf (ebwv:Company ebwv:LegalPerson ebwv:A1Certificate ebwv:WorkAssignment ebwv:PublicSectorBody) ] ;
    rdfs:range ebwv:CountryCode ;
    rdfs:label "jurisdiction" ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/jurisdiction>, <https://w3id.org/ebwv#> ;
    vs:term_status "stable" ;
.

ebwv:legalEntity a rdf:Property, owl:ObjectProperty ;
    rdfs:domain ebwv:LegalRepresentative ;
    rdfs:range ebwv:NaturalPerson, ebwv:LegalPerson ;
    rdfs:label "legal entity recognized by law" ;
    rdfs:comment """<div>A legal entity is any individual, company, or organization recognized by law. It possesses distinct rights and responsibilities, meaning it can own property, enter into contracts, incur debts, pay taxes, and sue or be sued in court.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/legalentity>, <https://w3id.org/ebwv#> ;
    vs:term_status "stable" ;
.

ebwv:legalForm a rdf:Property, owl:DatatypeProperty ;
    rdfs:domain [ a owl:Class; owl:unionOf (ebwv:LegalPerson ebwv:Company) ] ;
    rdfs:range xsd:string ;
    rdfs:label "legal form" ;
    rdfs:comment """<div>the juridical classification of a legal entity according to the law under which it is constituted, determining its legal personality, governance structure, and liability regime</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/legalform>, <https://w3id.org/ebwv#> ;
    vs:term_status "stable" ;
.

ebwv:legalIdentifier a rdf:Property, owl:DatatypeProperty ;
    rdfs:domain [ a owl:Class; owl:unionOf (ebwv:EuropeanBusinessWalletOwner ebwv:LegalPerson ebwv:EconomicOperator ebwv:PublicSectorBody) ] ;
    rdfs:range [ a owl:Class; owl:unionOf (ebwv:PublicSectorBodyId ebwv:Euid) ] ;
    rdfs:label "legal identifier" ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/legalidentifier>, <https://w3id.org/ebwv#> ;
    vs:term_status "stable" ;
.

ebwv:legalName a rdf:Property, owl:DatatypeProperty ;
    rdfs:domain [ a owl:Class; owl:unionOf (ebwv:EuropeanBusinessWalletOwner ebwv:LegalPerson ebwv:EconomicOperator ebwv:PublicSectorBody) ] ;
    rdfs:range xsd:string ;
    rdfs:label "legal name" ;
    rdfs:comment """<div>the name under which the legal entity is legally registered</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/legalname>, <https://w3id.org/ebwv#> ;
    vs:term_status "stable" ;
.

ebwv:legalRepresentative a rdf:Property, owl:ObjectProperty ;
    rdfs:domain ebwv:LimitedLiabilityCompany ;
    rdfs:range ebwv:LegalRepresentative ;
    rdfs:label "legal representative" ;
    rdfs:comment """<div>a natural person or economic operator that has authority, under law, the company's statutes, a register entry or another recognised legal basis, to represent a company in dealings with third parties, authorities or courts</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/legalrepresentative>, <https://w3id.org/ebwv#> ;
    vs:term_status "stable" ;
.

ebwv:legalStatus a rdf:Property, owl:DatatypeProperty ;
    rdfs:domain [ a owl:Class; owl:unionOf (ebwv:Company ebwv:LegalPerson) ] ;
    rdfs:range xsd:string ;
    rdfs:label "status of the company" ;
    rdfs:comment """<div>the officially recorded status of a registered business entity as determined or maintained by the competent register authority</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/legalstatus>, <https://w3id.org/ebwv#> ;
    vs:term_status "stable" ;
.

ebwv:lei a rdf:Property, owl:DatatypeProperty ;
    rdfs:domain ebwv:LegalEntityIdentifier ;
    rdfs:range xsd:string ;
    rdfs:label "legal entity identifier" ;
    rdfs:comment """<div>a globally unique reference code assigned under the Global LEI System to identify a legal entity participating in financial, business or regulatory transactions</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/lei>, <https://w3id.org/ebwv#> ;
    vs:term_status "stable" ;
.

ebwv:leiLastUpdate a rdf:Property, owl:DatatypeProperty ;
    rdfs:domain ebwv:LeiRegistration ;
    rdfs:range xsd:string ;
    rdfs:label "lei last update date" ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/leilastupdate>, <https://w3id.org/ebwv#> ;
    vs:term_status "stable" ;
.

ebwv:leiLegalEntity a rdf:Property, owl:ObjectProperty ;
    rdfs:domain ebwv:LegalEntityIdentifier ;
    rdfs:range ebwv:LegalPerson, ebwv:PublicSectorBody ;
    rdfs:label "legal entity as registered at lei issuer" ;
    rdfs:comment """<div>an organisation, legal person, trust, fund, government body, international organisation or other legally or administratively recognised entity that is eligible to be identified by a Legal Entity Identifier under the Global LEI System</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/leilegalentity>, <https://w3id.org/ebwv#> ;
    vs:term_status "stable" ;
.

ebwv:leiNextRenewal a rdf:Property, owl:DatatypeProperty ;
    rdfs:domain ebwv:LeiRegistration ;
    rdfs:range xsd:string ;
    rdfs:label "lei next renewal" ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/leinextrenewal>, <https://w3id.org/ebwv#> ;
    vs:term_status "stable" ;
.

ebwv:leiRegistration a rdf:Property, owl:ObjectProperty ;
    rdfs:domain ebwv:LegalEntityIdentifier ;
    rdfs:range ebwv:LeiRegistration ;
    rdfs:label "lei registration data" ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/leiregistration>, <https://w3id.org/ebwv#> ;
