    rdfs:domain ebwv:A1Certificate ;
    rdfs:range xsd:boolean ;
    rdfs:label "no fixed place of work" ;
    rdfs:comment """<div>Indicates that no fixed address or fixed place of work exists for the work or self-employment activity covered by the A1 certificate.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/nofixedplaceofwork>, <https://w3id.org/ebwv#> ;
    vs:term_status "stable" ;
.

