ebwv:socialRepresentative a rdf:Property, owl:ObjectProperty ;
    rdfs:domain ebwv:EconomicOperator ;
    rdfs:range ebwv:Person ;
    rdfs:label "social representative" ;
    rdfs:comment """<div>a person or entity designated to represent or assist an employer or posted worker in relation to social security, labour, employment or posting-related obligations during a posting period</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/socialrepresentative>, <https://w3id.org/ebwv#> ;
    vs:term_status "stable" ;
.

ebwv:staffAverage a rdf:Property, owl:DatatypeProperty ;
    rdfs:domain ebwv:SocialSecurityContribution ;
    rdfs:range xsd:integer ;
    rdfs:label "staff average" ;
    rdfs:comment """<div>The average number of staff associated with the employer for the period or reference data used in a social security contribution attestation.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/staffaverage>, <https://w3id.org/ebwv#> ;
    vs:term_status "stable" ;
.

ebwv:startDate a rdf:Property, owl:DatatypeProperty ;
    rdfs:domain ebwv:PeriodOfTime ;
    rdfs:range xsd:date ;
    rdfs:label "start date of period of time" ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/startDate>, <https://w3id.org/ebwv#> ;
    vs:term_status "stable" ;
.

ebwv:stateOfInsurance a rdf:Property, owl:DatatypeProperty ;
    rdfs:domain ebwv:WorkAssignment ;
    rdfs:range ebwv:CountryCode ;
    rdfs:label "state of insurance" ;
    rdfs:comment """<div>In PWN, the "Home Member State" information regarding the Work Assignment</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/stateofinsurance>, <https://w3id.org/ebwv#> ;
    vs:term_status "stable" ;
.

ebwv:statusConfirmation a rdf:Property, owl:DatatypeProperty ;
    rdfs:domain ebwv:A1Certificate ;
    rdfs:range xsd:boolean ;
    rdfs:label "status confirmation" ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/statusconfirmation>, <https://w3id.org/ebwv#> ;
    vs:term_status "stable" ;
.

ebwv:subscribedCapital a rdf:Property, owl:ObjectProperty ;
    rdfs:domain ebwv:LimitedLiabilityCompany ;
    rdfs:range ebwv:MonetaryAmount ;
    rdfs:label "subscribed capital" ;
    rdfs:comment """<div>the total monetary amount of capital that shareholders or members have formally committed to contribute to a company under its constitutive documents</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/subscribedcapital>, <https://w3id.org/ebwv#> ;
    vs:term_status "stable" ;
.

ebwv:supplier a rdf:Property, owl:DatatypeProperty ;
    rdfs:domain ebwv:PaymentTerms ;
    rdfs:range xsd:anyURI ;
    rdfs:label "supplier" ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/supplier>, <https://w3id.org/ebwv#> ;
    vs:term_status "stable" ;
.

ebwv:temporaryAddress a rdf:Property, owl:ObjectProperty ;
    rdfs:domain ebwv:Person ;
    rdfs:range ebwv:Address ;
    rdfs:label "temporary address" ;
    rdfs:comment """<div>an address at which a person resides, stays or can be reached for a limited period, without it being the person's permanent home or domicile address</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/temporaryaddress>, <https://w3id.org/ebwv#> ;
    vs:term_status "stable" ;
.

ebwv:temporaryWorkAgency a rdf:Property, owl:DatatypeProperty ;
    rdfs:domain ebwv:EconomicOperator ;
    rdfs:range xsd:boolean ;
    rdfs:label "temporary work agency" ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/temporaryworkagency>, <https://w3id.org/ebwv#> ;
    vs:term_status "stable" ;
.

ebwv:terms a rdf:Property, owl:ObjectProperty ;
    rdfs:domain ebwv:PaymentTerms ;
    rdfs:range ebwv:Incoterms, [ a owl:Class; owl:oneOf (ebwv:EXW ebwv:FCA ebwv:CPT ebwv:CIP ebwv:DAP ebwv:DPU ebwv:DDP ebwv:FAS ebwv:FOB) ] ;
    rdfs:label "terms" ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/terms>, <https://w3id.org/ebwv#> ;
    vs:term_status "stable" ;
.

ebwv:thoroughfare a rdf:Property, owl:DatatypeProperty ;
    rdfs:domain ebwv:Address ;
    rdfs:range xsd:string ;
    rdfs:label "thoroughfare" ;
    rdfs:comment """<div>the name of a passage or way through from one location to another</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/thoroughfare>, <https://w3id.org/ebwv#> ;
    vs:term_status "stable" ;
.

ebwv:totalPayroll a rdf:Property, owl:ObjectProperty ;
    rdfs:domain ebwv:SocialSecurityContribution ;
    rdfs:range ebwv:MonetaryAmount ;
    rdfs:label "total payroll" ;
    rdfs:comment """<div>The total payroll amount associated with the employer for the reference period used in a social security contribution attestation.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/totalpayroll>, <https://w3id.org/ebwv#> ;
    vs:term_status "stable" ;
.

ebwv:transitionalRules a rdf:Property, owl:DatatypeProperty ;
    rdfs:domain ebwv:A1Certificate ;
    rdfs:range xsd:boolean ;
    rdfs:label "transitional rules" ;
    rdfs:comment """<div>a temporary legal or administrative rule set that applies to a case because the relevant situation falls within a transition from one regime, framework, or procedure to another</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/transitionalrules>, <https://w3id.org/ebwv#> ;
    vs:term_status "stable" ;
.

ebwv:type a rdf:Property, owl:DatatypeProperty ;
    rdfs:domain ebwv:VATRegistrationUnit ;
    rdfs:range xsd:string ;
    rdfs:label "type" ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/type>, <https://w3id.org/ebwv#> ;
    vs:term_status "stable" ;
.

ebwv:typeOfEmployment a rdf:Property, owl:ObjectProperty ;
    rdfs:domain [ a owl:Class; owl:unionOf (ebwv:A1Certificate ebwv:PostedWorkerNotification) ] ;
    rdfs:range ebwv:TypeOfEmployment, [ a owl:Class; owl:oneOf (ebwv:Permanent ebwv:Temporary) ] ;
    rdfs:label "type of employment" ;
    rdfs:comment """<div>the category or form of an employment relationship, indicating how a worker is employed or engaged by an employer</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/typeofemployment>, <https://w3id.org/ebwv#> ;
    vs:term_status "stable" ;
.

ebwv:url a rdf:Property, owl:DatatypeProperty ;
    rdfs:domain ebwv:GovernanceRulebook ;
    rdfs:range xsd:anyURI ;
    rdfs:label "url" ;
    rdfs:comment """<div>Reference (URL) to the online dataspace governance rulebook for the given DSI or DS.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/url>, <https://w3id.org/ebwv#> ;
    vs:term_status "stable" ;
.

ebwv:version a rdf:Property, owl:DatatypeProperty ;
    rdfs:domain ebwv:GovernanceRulebook ;
    rdfs:range xsd:string ;
    rdfs:label "verson" ;
    rdfs:comment """<div>Version of the online rulebook at the time of acceptance.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/version>, <https://w3id.org/ebwv#> ;
    vs:term_status "stable" ;
.

# Class definitions
ebwv:A1Certificate a rdfs:Class ;
    rdfs:subClassOf cred:CredentialSubject ;
    rdfs:label "A1 Certificate" ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/a1certificate>, <https://w3id.org/ebwv#> ;
    vs:term_status "stable" ;
.

ebwv:Address a rdfs:Class ;
    rdfs:label "Address" ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/address>, <https://w3id.org/ebwv#> ;
    vs:term_status "stable" ;
.

ebwv:Agent a rdfs:Class ;
    rdfs:label "Agent" ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/agent>, <https://w3id.org/ebwv#> ;
    vs:term_status "stable" ;
.

ebwv:AttestationLegalCategory a rdfs:Class ;
    rdfs:label "Attestation Legal Category" ;
    rdfs:comment """<div>a categorization of electronic attestations of attributes into three primary types, each associated with a distinct level of assurance and legal effect</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/attestationlegalcategory>, <https://w3id.org/ebwv#> ;
    vs:term_status "stable" ;
.

ebwv:BankAccount a rdfs:Class ;
    rdfs:subClassOf cred:CredentialSubject ;
    rdfs:label "Bank Account" ;
    rdfs:comment """<div>an account held with a credit institution or payment service provider that enables a legal or natural person to receive, hold, and transfer funds</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/bankaccount>, <https://w3id.org/ebwv#> ;
    vs:term_status "stable" ;
.

ebwv:Company a rdfs:Class ;
    rdfs:subClassOf cred:CredentialSubject, ebwv:EconomicOperator ;
    rdfs:label "Company as defined in directive-EU-2025/25" ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/company>, <https://w3id.org/ebwv#> ;
    vs:term_status "stable" ;
.

ebwv:ContactPoint a rdfs:Class ;
    rdfs:label "Contact Point" ;
    rdfs:comment """<div>a designated communication channel or organisational function through which an entity can be contacted for a specific purpose</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/contactpoint>, <https://w3id.org/ebwv#> ;
    vs:term_status "stable" ;
.

ebwv:DataSpaceRole a rdfs:Class ;
    rdfs:label "role of dataspace member" ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/dataspacerole>, <https://w3id.org/ebwv#> ;
    vs:term_status "stable" ;
.

ebwv:EconomicOperator a rdfs:Class ;
    rdfs:label "Economic Operator" ;
    rdfs:comment """<div>any natural or legal person, including but not limited to companies, partnerships, foundations, associations as well as sole-traders and self-employed persons or a group of such persons, acting in a commercial or professional capacity</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/economicoperator>, <https://w3id.org/ebwv#> ;
    vs:term_status "stable" ;
.

ebwv:ElectronicAttestationOfAttributes a rdfs:Class ;
    rdfs:subClassOf cred:VerifiableCredential ;
    rdfs:label "Electronic Attestation Of Attributes" ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/electronicattestationofattributes>, <https://w3id.org/ebwv#> ;
    vs:term_status "stable" ;
.

ebwv:EuropeanBusinessWalletOwner a rdfs:Class ;
    rdfs:subClassOf cred:CredentialSubject ;
    rdfs:label "European Business Wallet Owner" ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/europeanbusinesswalletowner>, <https://w3id.org/ebwv#> ;
    vs:term_status "stable" ;
.

ebwv:GeneralPartner a rdfs:Class ;
    rdfs:label "General Partner" ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/generalpartner>, <https://w3id.org/ebwv#> ;
    vs:term_status "stable" ;
.

ebwv:GLN a rdfs:Class ;
    rdfs:subClassOf cred:CredentialSubject ;
    rdfs:label "Global Location Number" ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/gln>, <https://w3id.org/ebwv#> ;
    vs:term_status "stable" ;
.

ebwv:GovernanceRulebook a rdfs:Class ;
    rdfs:label "Governance rulebook" ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/governancerulebook>, <https://w3id.org/ebwv#> ;
    vs:term_status "stable" ;
.

ebwv:Incoterms a rdfs:Class ;
    rdfs:label "Incoterms" ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/incoterms>, <https://w3id.org/ebwv#> ;
    vs:term_status "stable" ;
.

ebwv:LegalEntityIdentifier a rdfs:Class ;
    rdfs:subClassOf cred:CredentialSubject ;
    rdfs:label "Legal entity identifier" ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/legalentityidentifier>, <https://w3id.org/ebwv#> ;
    vs:term_status "stable" ;
.

ebwv:LegalPerson a rdfs:Class ;
    rdfs:subClassOf cred:CredentialSubject ;
    rdfs:label "Legal Person" ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/legalperson>, <https://w3id.org/ebwv#> ;
    vs:term_status "stable" ;
.

ebwv:LegalRepresentative a rdfs:Class ;
    rdfs:label "Legal representative" ;
    rdfs:comment """<div>a natural person or economic operator that has authority, under law, the company's statutes, a register entry or another recognised legal basis, to represent a company in dealings with third parties, authorities or courts</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/legalrepresentative>, <https://w3id.org/ebwv#> ;
    vs:term_status "stable" ;
.

ebwv:LeiRegistration a rdfs:Class ;
    rdfs:label "LEI Registration" ;
    rdfs:comment """<div>Registration Meta Data of LEI provided and maintained by LEI issuer</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/registration>, <https://w3id.org/ebwv#> ;
    vs:term_status "stable" ;
.

ebwv:LimitedLiabilityCompany a rdfs:Class ;
    rdfs:subClassOf ebwv:Company ;
    rdfs:label "limited liability company" ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/limitedliabilitycompany>, <https://w3id.org/ebwv#> ;
    vs:term_status "stable" ;
.

ebwv:LimitedPartner a rdfs:Class ;
    rdfs:label "Limited Partner" ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/limitedpartner>, <https://w3id.org/ebwv#> ;
    vs:term_status "stable" ;
.

ebwv:Location a rdfs:Class ;
    rdfs:label "Location" ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/location>, <https://w3id.org/ebwv#> ;
    vs:term_status "stable" ;
.

ebwv:Membership a rdfs:Class ;
    rdfs:subClassOf cred:CredentialSubject ;
    rdfs:label "Membership" ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/membership>, <https://w3id.org/ebwv#> ;
    vs:term_status "stable" ;
.

ebwv:MonetaryAmount a rdfs:Class ;
    rdfs:label "Monetary Amount" ;
    rdfs:comment """<div>A structured representation of a sum of money, consisting at minimum of a numeric amount and the currency in which that amount is expressed. It is used in business attestations, credentials, invoices, payments, taxes, fees, capital, turnover, balances, and other economic or financial statements where the monetary value must be interpreted unambiguously across systems and jurisdictions.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/monetaryamount>, <https://w3id.org/ebwv#> ;
    vs:term_status "stable" ;
.

ebwv:NaturalPerson a rdfs:Class ;
    rdfs:subClassOf cred:CredentialSubject ;
    rdfs:label "Natural Person Identification Data" ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/naturalperson>, <https://w3id.org/ebwv#> ;
    vs:term_status "stable" ;
.

ebwv:Partnership a rdfs:Class ;
    rdfs:subClassOf ebwv:Company ;
    rdfs:label "partnership" ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/partnership>, <https://w3id.org/ebwv#> ;
    vs:term_status "stable" ;
.

ebwv:PaymentTerms a rdfs:Class ;
    rdfs:subClassOf cred:CredentialSubject ;
    rdfs:label "terms of payment" ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/paymentterms>, <https://w3id.org/ebwv#> ;
    vs:term_status "stable" ;
.

ebwv:PeriodOfTime a rdfs:Class ;
    rdfs:label "Period of Time" ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/periodoftime>, <https://w3id.org/ebwv#> ;
    vs:term_status "stable" ;
.

ebwv:Person a rdfs:Class ;
    rdfs:label "Person" ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/person>, <https://w3id.org/ebwv#> ;
    vs:term_status "stable" ;
.

ebwv:Platform a rdfs:Class ;
    rdfs:label "Platform" ;
    rdfs:comment """<div>Data sharing initiative that onboarded the member</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/platform>, <https://w3id.org/ebwv#> ;
    vs:term_status "stable" ;
.

ebwv:PostedWorkerNotification a rdfs:Class ;
    rdfs:subClassOf cred:CredentialSubject ;
    rdfs:label "Posted Worker Notification" ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/postedworkernotification>, <https://w3id.org/ebwv#> ;
    vs:term_status "stable" ;
.

ebwv:PublicSectorBody a rdfs:Class ;
    rdfs:label "public sector body" ;
    rdfs:comment """<div>public sector body’ means a Union entity, a national, state, regional or local authority, a body governed by public law or an association formed by one or several such entities or bodies , or a private entity mandated by at least one such entities, authorities, bodies or associations to provide public services, when acting under such a mandate</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/publicsectorbody>, <https://w3id.org/ebwv#> ;
    vs:term_status "stable" ;
.

ebwv:ScopeOfAuthorization a rdfs:Class ;
    rdfs:label "Scope Of Authorization" ;
    rdfs:comment """<div>the actions, matters, transactions, roles or circumstances for which an agent is authorised to act on behalf of another person or entity</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/scopeofauthorization>, <https://w3id.org/ebwv#> ;
    vs:term_status "stable" ;
.

ebwv:Site a rdfs:Class ;
    rdfs:label "Site" ;
    rdfs:comment """<div>a place, premises or location at which an organisation is present or located</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/site>, <https://w3id.org/ebwv#> ;
    vs:term_status "stable" ;
.

ebwv:SocialSecurityContribution a rdfs:Class ;
    rdfs:subClassOf cred:CredentialSubject ;
    rdfs:label "Social Security Contribution" ;
    rdfs:comment """<div>A social security contribution attestation is an attestation issued by a competent authority or authorized body confirming information about an employer’s fulfilment of obligations related to social security contributions arising from the employment of workers.</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/socialsecuritycontribution>, <https://w3id.org/ebwv#> ;
    vs:term_status "stable" ;
.

ebwv:StatutoryPartner a rdfs:Class ;
    rdfs:label "Statutory Partner" ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/statutorypartner>, <https://w3id.org/ebwv#> ;
    vs:term_status "stable" ;
.

ebwv:TypeOfEmployment a rdfs:Class ;
    rdfs:label "Type Of Employment" ;
    rdfs:comment """<div>the category or form of an employment relationship, indicating how a worker is employed or engaged by an employer</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/typeofemployment>, <https://w3id.org/ebwv#> ;
    vs:term_status "stable" ;
.

ebwv:VATRegistrationUnit a rdfs:Class ;
    rdfs:label "VAT Registration Unit" ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/vatregistrationunit>, <https://w3id.org/ebwv#> ;
    vs:term_status "stable" ;
.

ebwv:Vessel a rdfs:Class ;
    rdfs:label "Vessel" ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/vessel>, <https://w3id.org/ebwv#> ;
    vs:term_status "stable" ;
.

ebwv:WorkAssignment a rdfs:Class ;
    rdfs:subClassOf schema:Thing ;
    rdfs:label "Work Assignment" ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/workassignment>, <https://w3id.org/ebwv#> ;
    vs:term_status "stable" ;
.



# Definitions of individuals
ebwv:Alone a ebwv:ScopeOfAuthorization ;
    rdfs:label "scope of authorization Alone" ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/Alone>, <https://w3id.org/ebwv#> ;
    vs:term_status "stable" ;
.

ebwv:CIP a ebwv:Incoterms ;
    rdfs:label "Carriage & Insurance Paid To" ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/cip>, <https://w3id.org/ebwv#> ;
    vs:term_status "stable" ;
.

ebwv:CPT a ebwv:Incoterms ;
    rdfs:label "Carriage Paid To" ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/cpt>, <https://w3id.org/ebwv#> ;
    vs:term_status "stable" ;
.

ebwv:DAP a ebwv:Incoterms ;
    rdfs:label "Delivered At Place" ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/dap>, <https://w3id.org/ebwv#> ;
    vs:term_status "stable" ;
.

ebwv:DataConsumer a ebwv:DataSpaceRole ;
    rdfs:label "Partner that wants to use data, e.g. by calling an API." ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/dataconsumer>, <https://w3id.org/ebwv#> ;
    vs:term_status "stable" ;
.

ebwv:DataProvider a ebwv:DataSpaceRole ;
    rdfs:label "Partner that enables sharing data, e.g. via an API." ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/dataprovider>, <https://w3id.org/ebwv#> ;
    vs:term_status "stable" ;
.

ebwv:DataRightsHolder a ebwv:DataSpaceRole ;
    rdfs:label "Owns the rights to the data (e.g. farmers) and can consent to data being shared from a data provider to a data consumer." ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/datarightsholder>, <https://w3id.org/ebwv#> ;
    vs:term_status "stable" ;
.

ebwv:DDP a ebwv:Incoterms ;
    rdfs:label "Delivered Duty Paid" ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/ddp>, <https://w3id.org/ebwv#> ;
    vs:term_status "stable" ;
.

ebwv:DPU a ebwv:Incoterms ;
    rdfs:label "Delivered Place Unloaded" ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/dpu>, <https://w3id.org/ebwv#> ;
    vs:term_status "stable" ;
.

ebwv:EAA a ebwv:AttestationLegalCategory ;
    rdfs:label "electronic attestation of attributes" ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/EAA>, <https://w3id.org/ebwv#> ;
    vs:term_status "stable" ;
.

ebwv:EXW a ebwv:Incoterms ;
    rdfs:label "Ex Works" ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/exw>, <https://w3id.org/ebwv#> ;
    vs:term_status "stable" ;
.

ebwv:FAS a ebwv:Incoterms ;
    rdfs:label "Free Alongside Ship" ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/fas>, <https://w3id.org/ebwv#> ;
    vs:term_status "stable" ;
.

ebwv:FCA a ebwv:Incoterms ;
    rdfs:label "Free Carrier" ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/fca>, <https://w3id.org/ebwv#> ;
    vs:term_status "stable" ;
.

ebwv:FOB a ebwv:Incoterms ;
    rdfs:label "Free On Board" ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/fob>, <https://w3id.org/ebwv#> ;
    vs:term_status "stable" ;
.

ebwv:Jointly a ebwv:ScopeOfAuthorization ;
    rdfs:label "scope of authorization Jointly" ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/Jointly>, <https://w3id.org/ebwv#> ;
    vs:term_status "stable" ;
.

ebwv:OnboardingServiceProvider a ebwv:DataSpaceRole ;
    rdfs:label "Partner that onboards members into Agri-X; may be a DSI or another technology partner." ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/onboardingserviceprovider>, <https://w3id.org/ebwv#> ;
    vs:term_status "stable" ;
.

ebwv:Operator a ebwv:DataSpaceRole ;
    rdfs:label "Partner providing DSSC building-block services (identity management, consent management, logging, …)." ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/operator>, <https://w3id.org/ebwv#> ;
    vs:term_status "stable" ;
.

ebwv:Permanent a ebwv:TypeOfEmployment ;
    rdfs:label "type of employment Permanent" ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/permanent>, <https://w3id.org/ebwv#> ;
    vs:term_status "stable" ;
.

ebwv:Pub-EAA a ebwv:AttestationLegalCategory ;
