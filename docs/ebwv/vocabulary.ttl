    rdfs:label "place of birth" ;
    rdfs:comment """<div>the location where a person was born</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/placeofbirth>, <https://w3id.org/ebwv#> ;
