    rdfs:domain [ a owl:Class; owl:unionOf (ebwv:LegalRepresentative ebwv:StatutoryPartner ebwv:Membership) ] ;
    rdfs:range [ a owl:Class; owl:unionOf (xsd:string ebwv:DataSpaceRole) ] ;
