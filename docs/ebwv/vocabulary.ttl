ebwv:owner a rdf:Property, owl:ObjectProperty ;
    rdfs:domain ebwv:BankAccount ;
    rdfs:range [ a owl:Class; owl:unionOf (ebwv:LegalPerson ebwv:EconomicOperator ebwv:NaturalPerson ebwv:Person) ] ;
    rdfs:label "owner" ;
    rdfs:comment """<div>an agent that holds an ownership right, title or legally recognised control over an asset, resource, business entity, credential, account, property or other object</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/owner>, <https://w3id.org/ebwv#> ;
    vs:term_status "stable" ;
.

ebwv:partner a rdf:Property, owl:ObjectProperty ;
    rdfs:domain ebwv:Partnership ;
    rdfs:range [ a owl:Class; owl:unionOf (ebwv:GeneralPartner ebwv:LimitedPartner ebwv:StatutoryPartner) ] ;
    rdfs:label "partner" ;
    rdfs:comment """<div>a person or legal entity that is a member of a partnership or comparable company-law entity and whose status as partner is recorded or recognised by the competent business register or company register</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/partner>, <https://w3id.org/ebwv#> ;
    vs:term_status "stable" ;
.

