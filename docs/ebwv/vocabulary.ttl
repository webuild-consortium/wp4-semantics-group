    vs:term_status "stable" ;
.

ebwv:hasTelephone a rdf:Property, owl:DatatypeProperty ;
    rdfs:domain ebwv:ContactPoint ;
    rdfs:range xsd:string ;
    rdfs:label "telephone" ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/telephone>, <https://webuild-consortium.github.io/wp4-semantics-group/ebwv/vocabulary.html#> ;
    vs:term_status "stable" ;
.

ebwv:identifier a rdf:Property ;
    rdfs:domain ebwv:Person ;
    rdfs:range ebwv:Identifier ;
    rdfs:label "identifier" ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/identifier>, <https://webuild-consortium.github.io/wp4-semantics-group/ebwv/vocabulary.html#> ;
    vs:term_status "stable" ;
.

ebwv:legalName a rdf:Property, owl:DatatypeProperty ;
    rdfs:domain [ a owl:Class; owl:unionOf (ebwv:LegalPersonIdentificationData ebwv:EuropeanBusinessWalletOwnerId ebwv:EuccLimitLiabilityCompany ebwv:EuccPartnership) ] ;
    rdfs:range xsd:string ;
    rdfs:label "legal name" ;
    rdfs:comment """<div>a name under which the legal entity is registered</div>"""^^rdf:HTML ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/legalname>, <https://webuild-consortium.github.io/wp4-semantics-group/ebwv/vocabulary.html#> ;
    vs:term_status "stable" ;
.

ebwv:legalIdentifier a rdf:Property, owl:ObjectProperty ;
    rdfs:domain [ a owl:Class; owl:unionOf (ebwv:LegalPersonIdentificationData ebwv:EuropeanBusinessWalletOwnerId ebwv:EuccLimitLiabilityCompany ebwv:EuccPartnership) ] ;
    rdfs:range ebwv:PublicBodyId, ebwv:Euid ;
    rdfs:label "legal identifier" ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/legalidentifier>, <https://webuild-consortium.github.io/wp4-semantics-group/ebwv/vocabulary.html#> ;
    vs:term_status "stable" ;
.

ebwv:legalRepresentative a rdf:Property, owl:ObjectProperty ;
    rdfs:domain ebwv:EuccLimitLiabilityCompany ;
    rdfs:range ebwv:LegalRepresentative ;
    rdfs:label "legal representative" ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/legalrepresentative>, <https://webuild-consortium.github.io/wp4-semantics-group/ebwv/vocabulary.html#> ;
    vs:term_status "stable" ;
.

ebwv:legalRepresentativeId a rdf:Property, owl:DatatypeProperty ;
    rdfs:domain ebwv:LegalRepresentative ;
    rdfs:range xsd:anyURI ;
    rdfs:label "unique ID of the identity of the representative" ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/legalrepresentativeid>, <https://webuild-consortium.github.io/wp4-semantics-group/ebwv/vocabulary.html#> ;
    vs:term_status "stable" ;
.

ebwv:lei a rdf:Property, owl:DatatypeProperty ;
    rdfs:domain ebwv:LegalPersonIdentificationData ;
    rdfs:range xsd:string ;
    rdfs:label "legal entity identifier" ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/lei>, <https://webuild-consortium.github.io/wp4-semantics-group/ebwv/vocabulary.html#> ;
    vs:term_status "stable" ;
.

ebwv:liabilityOrContribution a rdf:Property, owl:ObjectProperty ;
    rdfs:domain ebwv:LimitedPartner ;
    rdfs:range ebwv:Capital ;
    rdfs:label "liability or contribution of the limited partner" ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/liabilityorcontribution>, <https://webuild-consortium.github.io/wp4-semantics-group/ebwv/vocabulary.html#> ;
    vs:term_status "stable" ;
.

ebwv:locatorDesignator a rdf:Property, owl:DatatypeProperty ;
    rdfs:domain ebwv:Address ;
    rdfs:range xsd:string, xsd:integer ;
    rdfs:label "locator designator" ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/locatordesignator>, <https://webuild-consortium.github.io/wp4-semantics-group/ebwv/vocabulary.html#> ;
