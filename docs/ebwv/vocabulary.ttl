    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/partner>, <https://webuild-consortium.github.io/wp4-semantics-group/ebwv/vocabulary.html#> ;
    vs:term_status "stable" ;
.

ebwv:partnerId a rdf:Property, owl:DatatypeProperty ;
    rdfs:domain [ a owl:Class; owl:unionOf (ebwv:GeneralPartner ebwv:LimitedPartner ebwv:StatutoryPartner) ] ;
