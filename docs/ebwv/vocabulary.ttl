ebwv:placeOfWork a rdf:Property ;
    rdfs:domain [ a owl:Class; owl:unionOf (ebwv:A1Certificate ebwv:WorkAssignment) ] ;
    rdfs:range [ a owl:Class; owl:unionOf (ebwv:Address ebwv:CountryCode ebwv:EconomicOperator ebwv:Vessel) ] ;
    rdfs:label "place of work" ;
