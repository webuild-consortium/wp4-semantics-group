        "@id": "ebwv:CountryCode",
        "@type": "rdfs:Datatype",
        "rdfs:subClassOf": ["xsd:string"],
        "owl:onDatatype": "xsd:string",
        "owl:withRestrictions": {
            "@list": [{
                "xsd:pattern": "[A-Z]{2}(-.*)?"
            }]
        },
        "rdfs:label": "Country Code",
        "rdfs:comment": {
            "@value": "<div>2 letter country code according to ISO-3166</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "rdfs:isDefinedBy": "https://www.iso.org/iso-3166-country-codes.html",
        "vs:term_status": "stable",
        "mentioned": [{
            "@id": "https://w3id.org/ebwv/v0.1",
            "@type": "jsonld:Context"
        }]
    }, {
        "@id": "ebwv:Bic",
        "@type": "rdfs:Datatype",
        "rdfs:subClassOf": ["xsd:string"],
        "owl:onDatatype": "xsd:string",
        "owl:withRestrictions": {
            "@list": [{
                "xsd:pattern": "[A-Z]{6}[A-Z0-9]{2}([A-Z0-9]{3})"
            }]
        },
        "rdfs:label": "Business Identifier Code aka Swift Code",
        "rdfs:comment": {
            "@value": "<div>International code (i.e. BIC or SWIFT code), as defined in ISO 9362, of the financial institution</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "rdfs:isDefinedBy": "https://www.iso.org/standard/84108.html",
        "vs:term_status": "stable",
        "mentioned": [{
