        "@type": "rdfs:Datatype",
        "rdfs:subClassOf": ["xsd:string"],
        "rdfs:label": "ClearingNumber",
        "rdfs:comment": {
            "@value": "<div>Clearing number, only used in some countries, of the identification of the financial institution.</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "vs:term_status": "stable",
        "mentioned": [{
            "@id": "https://w3id.org/ebwv/v0.1",
            "@type": "jsonld:Context"
        }]
    }, {
