        "@type": "rdfs:Datatype",
        "rdfs:subClassOf": ["xsd:string"],
        "rdfs:label": "legal entity identifier",
        "rdfs:comment": {
            "@value": "<div>a globally unique reference code assigned under the Global LEI System to identify a legal entity participating in financial, business or regulatory transactions</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "rdfs:isDefinedBy": "https://sanastot.suomi.fi/en/terminology/webuild/concept/lei",
        "vs:term_status": "stable",
        "mentioned": [{
            "@id": "https://w3id.org/ebwv/v0.1",
            "@type": "jsonld:Context"
        }]
    }, {
        "@id": "ebwv:Nace21",
        "@type": "rdfs:Datatype",
        "rdfs:subClassOf": ["xsd:string"],
        "rdfs:label": "Nace Rev. 2.1",
        "rdfs:comment": {
            "@value": "<div>notation of the main activity of the company according to the European controlled vocabulary 'Nace Rev. 2.1'</div>",
            "@type": "http://www.w3.org/1999/02/22-rdf-syntax-ns#HTML"
        },
        "rdfs:isDefinedBy": ["https://op.europa.eu/en/web/eu-vocabularies/concept-scheme/-/resource?uri=http://data.europa.eu/ux2/nace2.1/nace2.1", "http://data.europa.eu/ux2/nace2.1/nace2.1"],
        "vs:term_status": "stable",
        "mentioned": [{
            "@id": "https://w3id.org/ebwv/v0.1",
            "@type": "jsonld:Context"
        }]
    }, {
