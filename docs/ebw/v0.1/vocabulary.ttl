    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/nacedescription>, <https://ebw-vocabulary.spherity.dev/ebw#> ;
    vs:term_status "stable" ;
.

ebw:partner a rdf:Property, owl:ObjectProperty ;
    rdfs:domain ebw:EuccPartnership ;
    rdfs:range ebw:GeneralPartner, ebw:LimitedPartner, ebw:StatutoryPartner ;
    rdfs:label "partner" ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/partner>, <https://ebw-vocabulary.spherity.dev/ebw#> ;
    vs:term_status "stable" ;
.

