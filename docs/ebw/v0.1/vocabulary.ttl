# Ontology definition
ebw: a owl:Ontology ;
    dc:title """European Business Wallet Vocabulary v0.1"""@en ;
    dc:description """Vocabulary used by the Verifiable Credentials of the European Business Wallet Framework"""^^rdf:HTML ;
    rdfs:seeAlso <https://ebw-vocabulary.spherity.dev/ebw> ;
    dc:date "2026-02-27"^^xsd:date ;
.

# Property definitions
ebw:thoroughfare a rdf:Property, owl:DatatypeProperty ;
    rdfs:domain ebw:Address ;
    rdfs:range xsd:string ;
    rdfs:label "thoroughfare" ;
    rdfs:isDefinedBy <https://sanastot.suomi.fi/en/terminology/webuild/concept/thoroughfare>, <https://ebw-vocabulary.spherity.dev/ebw#> ;
    vs:term_status "stable" ;
.

