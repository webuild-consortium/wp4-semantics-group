<http://data.webuildconsortium.eu/top.ttl>
  a owl:Ontology ;
  owl:imports <http://www.braindex.nl/data/PRIMER> ;
  owl:versionInfo "Created with TopBraid Composer" ;
.
auth:Aspect
  a primer:Class ;
  primer:definition "A Role (e.g., a student role, or the role of a bearing as 'driven end bearing') is a contingent property that is not essential to the bearer's existence. Roles must be modeled as Dependent Continuants. The specific kind of role usually falls under Specifically Dependent Continuant because it depends on one unique object (like a person or a specific machine component)."@en ;
  primer:prefLabel "Aspect"@en ;
  rdfs:isDefinedBy auth: ;
  rdfs:subClassOf auth:DependentContinuant ;
.
